+// TestIncrementalMultiTransition proves the dominant edit classes are no-fallback
+// even for real-Soong-style multi-variantized modules (arch x os combos): the
+// in-place re-derive re-runs every transition's _mutate on each combo variant.
+func TestIncrementalMultiTransition(t *testing.T) {
+	bp := func(outA string) string {
+		return `
+			arch_module { name: "A", variants: ["arm", "x86"], os_variants: ["android", "linux"], outputs: ["` + outA + `"], deps: ["B"] }
+			arch_module { name: "B", variants: ["arm", "x86"], os_variants: ["android", "linux"], outputs: ["outB"], exported: "v1" }
+		`
+	}
+	full := func(s string) string {
+		ctx := newMultiTransitionCtx(t, s)
+		if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+			t.Fatalf("full resolve: %v", errs)
+		}
+		if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+			t.Fatalf("full prepare: %v", errs)
+		}
+		return writeModuleNinja(t, ctx)
+	}
+
+	ctx := newMultiTransitionCtx(t, bp("outA1"))
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+	rp := newMultiTransitionCtx(t, bp("outA2"))
+	edits := map[string][]interface{}{"A": rp.moduleGroupFromName("A", nil).modules[0].properties}
+	if errs := ctx.ReMutate(nil, edits); len(errs) > 0 {
+		t.Fatalf("ReMutate (multi-transition property edit should be in-place): %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	got := writeModuleNinja(t, ctx)
+	want := full(bp("outA2"))
+	if got != want {
+		t.Errorf("multi-transition in-place ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+	}
+}
