+// newArchCtx builds a Context with a transition (arch-like) mutator + the deps
+// mutator, parsed but not mutated.
+func newArchCtx(t *testing.T, bp string) *Context {
+	t.Helper()
+	ctx := NewContext()
+	ctx.MockFileSystem(map[string][]byte{"Android.bp": []byte(bp)})
+	ctx.RegisterModuleType("arch_module", newArchProvModule)
+	// depsMutator adds dependencies, so flag it accordingly; this excludes it from
+	// the in-place property re-run (it is structural, not a property transform).
+	ctx.RegisterBottomUpMutator("deps", depsMutator).MutatesDependencies()
+	ctx.RegisterTransitionMutator("arch", archLikeMutator{})
+	if _, errs := ctx.ParseBlueprintsFiles("Android.bp", nil); len(errs) > 0 {
+		t.Fatalf("parse errors: %v", errs)
+	}
+	return ctx
+}
+
+// newIncCtx builds a Context with the test module types + the bottom-up deps
+// mutator registered, and the given Android.bp parsed but not yet mutated.
+func newIncCtx(t *testing.T, bp string) *Context {
+	t.Helper()
+	ctx := NewContext()
+	ctx.MockFileSystem(map[string][]byte{"Android.bp": []byte(bp)})
+	ctx.RegisterModuleType("foo_module", newFooModule)
+	ctx.RegisterModuleType("bar_module", newBarModule)
+	ctx.RegisterModuleType("prov_module", newProvModule)
+	ctx.RegisterBottomUpMutator("deps", depsMutator)
+	if _, errs := ctx.ParseBlueprintsFiles("Android.bp", nil); len(errs) > 0 {
+		t.Fatalf("parse errors: %v", errs)
+	}
+	return ctx
+}
+
+// writeModuleNinja renders all module build actions to a string for byte
+// comparison.
+func writeModuleNinja(t *testing.T, ctx *Context) string {
+	t.Helper()
+	buf := bytes.NewBuffer(nil)
+	w := newNinjaWriter(buf)
+	if err := ctx.writeAllModuleActions(w, false, "test.ninja"); err != nil {
+		t.Fatalf("writeAllModuleActions: %v", err)
+	}
+	return buf.String()
+}
+
+// fullBuildNinja parses bp, runs the full analysis pipeline, and returns the
+// module ninja. This is the ground truth a warm incremental rebuild must match.
+func fullBuildNinja(t *testing.T, bp string) string {
+	t.Helper()
+	ctx := newIncCtx(t, bp)
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("resolve errors: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("prepare errors: %v", errs)
+	}
+	return writeModuleNinja(t, ctx)
+}
+
+// reparseModuleProps parses bp in a throwaway context and returns the parsed
+// (pre-mutation) properties of the named module, simulating a re-parse of an
+// edited Android.bp.
+func reparseModuleProps(t *testing.T, bp, moduleName string) []interface{} {
+	t.Helper()
+	ctx := newIncCtx(t, bp)
+	group := ctx.moduleGroupFromName(moduleName, nil)
+	if group == nil {
+		t.Fatalf("reparseModuleProps: module %q not found", moduleName)
+	}
+	return group.modules[0].properties
+}
+
+// incrementalRebuildNinja simulates a resident warm rebuild: cold-build origBP,
+// then apply the edit (re-parse changedNames out of editedBP) via incremental
+// re-mutation + targeted generate, and return the resulting module ninja.
+func incrementalRebuildNinja(t *testing.T, origBP, editedBP string, changedNames []string) string {
+	t.Helper()
+	ctx := newIncCtx(t, origBP)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve errors: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare errors: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+
+	// Apply the edit: feed the re-parsed properties for each changed module.
+	for _, name := range changedNames {
+		props := reparseModuleProps(t, editedBP, name)
+		if err := ctx.SetBaselineProperties(name, props); err != nil {
+			t.Fatalf("SetBaselineProperties(%q): %v", name, err)
+		}
+	}
+	if errs := ctx.ReMutateModules(nil, changedNames); len(errs) > 0 {
+		t.Fatalf("ReMutateModules: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare errors: %v", errs)
+	}
+	return writeModuleNinja(t, ctx)
+}
+
+// assertByteIdentical fails if the incremental rebuild of origBP->editedBP does
+// not exactly match a full build of editedBP.
+func assertByteIdentical(t *testing.T, origBP, editedBP string, changedNames []string) {
+	t.Helper()
+	want := fullBuildNinja(t, editedBP)
+	got := incrementalRebuildNinja(t, origBP, editedBP, changedNames)
+	if got != want {
+		t.Errorf("incremental ninja != full build ninja\n--- want (full build of edited) ---\n%s\n--- got (incremental) ---\n%s", want, got)
+	}
+}
+
+// TestIncrementalReMutation drives a corpus of Android.bp edits through the
+// incremental re-mutation path and asserts the resulting ninja is byte-identical
+// to a full build of the edited graph. Each case must hold for "no fallback,
+// zero bugs" on the supported edit classes.
+func TestIncrementalReMutation(t *testing.T) {
+	cases := []struct {
+		name    string
+		orig    string
+		edited  string
+		changed []string
+	}{
+		{
+			name: "leaf_output_edit",
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+				bar_module { name: "B", outputs: ["outB1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA2"], deps: ["B"] }
+				bar_module { name: "B", outputs: ["outB1"] }
+			`,
+			changed: []string{"A"},
+		},
+		{
+			name: "edit_dep_leaf_unaffected",
+			// Edit the depended-on leaf B; A (its dependent) must stay byte-identical.
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+				bar_module { name: "B", outputs: ["outB1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+				bar_module { name: "B", outputs: ["outB2"] }
+			`,
+			changed: []string{"B"},
+		},
+		{
+			name: "extra_outputs_added",
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA1"], extra_outputs: ["outAx"] }
+			`,
+			changed: []string{"A"},
+		},
+		{
+			name: "order_only_edit",
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"], order_only: ["ooA1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA1"], order_only: ["ooA2"] }
+			`,
+			changed: []string{"A"},
+		},
+		{
+			name: "add_dependency_edge",
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"] }
+				bar_module { name: "B", outputs: ["outB1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+				bar_module { name: "B", outputs: ["outB1"] }
+			`,
+			changed: []string{"A"},
+		},
+		{
+			name: "remove_dependency_edge",
+			orig: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
