+
+package incr
+
+import (
+	"bytes"
+	"fmt"
+	"strings"
+)
+
+// blueprint_go_binary is the Soong build-itself type for a Go binary that
+// minibp links during the bootstrap stage (bpfmt, bpfix, soong_build,
+// loadplugins, gotestmain, gotestrunner, etc.). It is structurally a
+// bootstrap_go_package that additionally runs g.bootstrap.link to produce a
+// host binary at out/host/linux-x86/bin/<name>.
+//
+// What the emitter captures here:
+//
+//   - srcs are the .go files that make up the main package.
+//   - deps are other bootstrap_go_package archives the link step pulls in;
+//     a change to any of them must propagate to this binary, which is exactly
+//     what threading depHashes into the resolved hash gives us.
+//   - The install path is out/host/linux-x86/bin/<name>, matching what the
+//     real bootstrap.ninja emits, so a textual diff against ninja is meaningful.
+func emitBlueprintGoBinary(name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	id := fmt.Sprintf("%016x", hashBytes(resolvedDef))
+	dep := fmt.Sprintf("%016x", hashBytes(depHashes))
+	srcs := strings.TrimSpace(res.props["srcs"])
+
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "# module %s (blueprint_go_binary)\n", name)
+	fmt.Fprintf(&b, "build out/host/linux-x86/bin/go/%s/pkg/%s.a: g.bootstrap.compile\n", name, name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	if srcs != "" {
+		fmt.Fprintf(&b, "    srcs = %s\n", srcs)
+	}
+	fmt.Fprintf(&b, "build out/host/linux-x86/bin/%s: g.bootstrap.link out/host/linux-x86/bin/go/%s/pkg/%s.a\n", name, name, name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	return b.Bytes()
+}
+
+func init() {
+	registerEmitter("blueprint_go_binary", emitBlueprintGoBinary)
+}
