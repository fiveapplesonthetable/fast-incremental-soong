+// TestEndToEndIncrementalRebuild drives the complete warm-rebuild pipeline the
+// resident server uses: cold build, then on an edit re-parse the tree, diff
+// against the baselines (DiffParsedModules), feed the change set to ReMutate, and
+// regenerate -- with NO hand-fed module names. The result must be byte-identical
+// to a full build of the edited tree, and added/removed modules must be reported
+// for a full-rebuild fallback.
+func TestEndToEndIncrementalRebuild(t *testing.T) {
+	cold := `
+		foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+		bar_module { name: "B", outputs: ["outB1"] }
+		prov_module { name: "C", outputs: ["outC"], deps: ["B"] }
+	`
+	// Property edit to A and a no-op-to-structure change: byte-identical fast path.
+	edited := `
+		foo_module { name: "A", outputs: ["outA2"], deps: ["B"] }
+		bar_module { name: "B", outputs: ["outB1"] }
+		prov_module { name: "C", outputs: ["outC"], deps: ["B"] }
+	`
+
+	ctx := newIncCtx(t, cold)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+
+	// Re-parse the edited tree into a throwaway context (what the front-end does).
+	reparsed := newIncCtx(t, edited)
+
+	changed, added, removed, err := ctx.DiffParsedModules(reparsed)
+	if err != nil {
+		t.Fatalf("DiffParsedModules: %v", err)
+	}
+	if len(added) != 0 || len(removed) != 0 {
+		t.Fatalf("unexpected added=%v removed=%v", added, removed)
+	}
+	if len(changed) != 1 || changed["A"] == nil {
+		t.Fatalf("expected only A changed, got %v", keysOf(changed))
+	}
+
+	if errs := ctx.ReMutate(nil, changed); len(errs) > 0 {
+		t.Fatalf("ReMutate: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	got := writeModuleNinja(t, ctx)
+	want := fullBuildNinja(t, edited)
+	if got != want {
+		t.Errorf("end-to-end not byte-identical\n--- want ---\n%s\n--- got ---\n%s", want, got)
+	}
+
+	// Now verify added/removed detection on a structural tree change.
+	addedTree := cold + `
+		bar_module { name: "D", outputs: ["outD"] }
+	`
+	reparsed2 := newIncCtx(t, addedTree)
+	_, added2, _, err := ctx.DiffParsedModules(reparsed2)
+	if err != nil {
+		t.Fatalf("DiffParsedModules add: %v", err)
+	}
+	if len(added2) != 1 || added2[0] != "D" {
+		t.Fatalf("expected added=[D], got %v", added2)
+	}
+}
+
+func keysOf(m map[string][]interface{}) []string {
+	var k []string
+	for n := range m {
+		k = append(k, n)
+	}
+	return k
+}
