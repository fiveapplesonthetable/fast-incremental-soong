+			// A -> B -> D, A -> C -> D; edit sink D's exported value. B, C, A all
+			// read it transitively and must regenerate.
+			orig: `
+				prov_module { name: "A", outputs: ["outA"], deps: ["B", "C"], exported: "ea" }
