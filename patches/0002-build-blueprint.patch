index 0000000..d06fd2c
--- /dev/null
+++ b/incr/cmd/qbuild/main.go
@@ -0,0 +1,396 @@
+// Copyright 2026 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+// qbuild demonstrates the content-addressed incremental analysis engine on real
+// frameworks/base Android.bp files.
+//
+//	go run ./incr/cmd/qbuild <bp-file> [<bp-file> ...]
+//
+// It does a cold build, a warm no-op build, then mutates one module in one file
+// in memory and rebuilds -- reporting how many queries recompute and verifying
+// the warm manifest is byte-identical to a cold build of the edited inputs.
+package main
+
+import (
+	"fmt"
+	"os"
+	"regexp"
+	"strings"
+	"time"
+
+	"github.com/google/blueprint/incr"
+)
+
+func main() {
+	files := os.Args[1:]
+	if len(files) == 0 {
+		fmt.Fprintln(os.Stderr, "usage: qbuild <Android.bp> [<Android.bp> ...]")
+		os.Exit(2)
+	}
+
+	// Load every file's bytes from disk up front (these are the engine inputs).
+	content := map[string][]byte{}
+	for _, f := range files {
+		b, err := os.ReadFile(f)
+		if err != nil {
+			fmt.Fprintf(os.Stderr, "read %s: %v\n", f, err)
+			os.Exit(1)
+		}
+		content[f] = b
+	}
+
+	e := incr.New()
+	p := incr.NewPipeline(e, files)
+	for f, b := range content {
+		p.SetFile(f, b)
+	}
+
+	// --- Cold build -------------------------------------------------------
+	t0 := time.Now()
+	cold, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "cold build: %v\n", err)
+		os.Exit(1)
+	}
+	coldDur := time.Since(t0)
+	fmt.Printf("COLD     %6s  nodes=%d  recomputed=%d  manifest=%d bytes\n",
+		coldDur.Round(time.Microsecond), e.NodeCount(), e.Recomputed, len(cold.Bytes))
+
+	// --- Warm no-op (nothing changed) ------------------------------------
+	t0 = time.Now()
+	if _, err := e.Build("manifest"); err != nil {
+		fmt.Fprintf(os.Stderr, "warm no-op: %v\n", err)
+		os.Exit(1)
+	}
+	fmt.Printf("NO-OP    %6s  recomputed=%d  verified=%d  (expect recomputed=0)\n",
+		time.Since(t0).Round(time.Microsecond), e.Recomputed, e.Verified)
+
+	// --- Edit one module in one file (in memory) -------------------------
+	target, before, after, ok := pickEdit(content)
+	if !ok {
+		fmt.Println("no editable srcs list found in inputs; skipping edit phase")
+		return
+	}
+	edited := map[string][]byte{}
+	for f, b := range content {
+		edited[f] = b
+	}
+	edited[target.file] = swapBytes(content[target.file], before, after)
+
+	p.SetFile(target.file, edited[target.file]) // changes exactly one input
+	t0 = time.Now()
+	warm, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "warm edit: %v\n", err)
+		os.Exit(1)
+	}
+	warmDur := time.Since(t0)
+	fmt.Printf("EDIT     %6s  recomputed=%d  cutoff=%d  (reordered srcs in %s, file %s)\n",
+		warmDur.Round(time.Microsecond), e.Recomputed, e.Cutoff, target.module, target.file)
+
+	// --- Correctness: cold build of the edited inputs, byte-compared ------
+	e2 := incr.New()
+	p2 := incr.NewPipeline(e2, files)
+	for f, b := range edited {
+		p2.SetFile(f, b)
+	}
+	coldEdited, err := e2.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "cold-of-edited: %v\n", err)
+		os.Exit(1)
+	}
+
+	identical := string(warm.Bytes) == string(coldEdited.Bytes)
+	changedVsOrig := string(warm.Bytes) != string(cold.Bytes)
+	fmt.Printf("VERIFY   warm==cold(edited): %v   warm!=cold(orig): %v\n", identical, changedVsOrig)
+	if coldDur > 0 {
+		fmt.Printf("SPEEDUP  cold/edit = %.0fx\n", float64(coldDur)/float64(warmDur))
+	}
+	ok1 := identical && changedVsOrig
+
+	// --- Cross-module edit: change a widely-used `defaults:` module ----------
+	// This is the case Soong falls back on (a real module edit). The engine
+	// re-resolves only the edited defaults module and its transitive users; every
+	// unrelated module early-cuts off.
+	ok2 := demoDefaultsEdit(files)
+
+	// --- Add a new module (the other real edit type) ------------------------
+	ok3 := demoAddModule(files)
+
+	if !ok1 || !ok2 || !ok3 {
+		os.Exit(1) // correctness gate
+	}
+}
+
+// demoAddModule appends a brand-new module to one file and verifies the warm
+// rebuild is byte-identical to a cold build of the edited tree, recomputing only
+// the new module's chain (the existing modules early-cut off).
+func demoAddModule(files []string) bool {
+	content := map[string][]byte{}
+	for _, f := range files {
+		if b, err := os.ReadFile(f); err == nil {
+			content[f] = b
+		}
+	}
+	var target string
+	for _, f := range files {
+		if _, ok := content[f]; ok {
+			target = f
+			break
+		}
+	}
+	if target == "" {
+		return true
+	}
+
+	e := incr.New()
+	p := incr.NewPipeline(e, files)
+	for f, b := range content {
+		p.SetFile(f, b)
+	}
+	cold, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "addmod cold: %v\n", err)
+		return false
+	}
+
+	added := append(append([]byte{}, content[target]...),
+		[]byte("\n\nfilegroup {\n    name: \"incr-probe-added-module\",\n    srcs: [\"Android.bp\"],\n}\n")...)
+	p.SetFile(target, added)
+	t0 := time.Now()
+	warm, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "addmod warm: %v\n", err)
+		return false
+	}
+	dur := time.Since(t0)
+
+	e2 := incr.New()
+	p2 := incr.NewPipeline(e2, files)
+	for f, b := range content {
+		if f == target {
+			p2.SetFile(f, added)
+		} else {
+			p2.SetFile(f, b)
+		}
+	}
+	coldEdited, _ := e2.Build("manifest")
+
+	identical := string(warm.Bytes) == string(coldEdited.Bytes)
+	changed := string(warm.Bytes) != string(cold.Bytes)
+	fmt.Printf("ADDMOD   %6s  recomputed=%d  cutoff=%d  (added a filegroup to %s)\n",
+		dur.Round(time.Microsecond), e.Recomputed, e.Cutoff, target)
+	fmt.Printf("ADDMOD   warm==cold(edited): %v   warm!=cold(orig): %v\n", identical, changed)
+	return identical && changed
+}
+
+// demoDefaultsEdit finds a defaults module referenced by other modules, edits it
+// on a fresh engine, and verifies the warm rebuild is byte-identical to a cold
+// build of the edited tree while recomputing only the affected subgraph.
+func demoDefaultsEdit(files []string) bool {
+	content := map[string][]byte{}
+	for _, f := range files {
+		if b, err := os.ReadFile(f); err == nil {
+			content[f] = b
+		}
+	}
+	file, name, ok := pickDefaultsModule(content)
+	if !ok {
+		fmt.Println("DEFAULTS no referenced defaults module found; skipping")
+		return true
+	}
+
+	e := incr.New()
+	p := incr.NewPipeline(e, files)
+	for f, b := range content {
+		p.SetFile(f, b)
+	}
+	cold, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "defaults cold: %v\n", err)
+		return false
+	}
+
+	// Inject a property into the defaults module so every user's merged def changes.
+	edited := injectProp(content[file], name, `    cflags: ["-DINCR_PROBE"],`)
+	p.SetFile(file, edited)
+	t0 := time.Now()
+	warm, err := e.Build("manifest")
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "defaults warm: %v\n", err)
+		return false
+	}
+	dur := time.Since(t0)
+
+	e2 := incr.New()
+	p2 := incr.NewPipeline(e2, files)
+	for f, b := range content {
+		if f == file {
+			p2.SetFile(f, edited)
+		} else {
+			p2.SetFile(f, b)
+		}
+	}
+	coldEdited, _ := e2.Build("manifest")
+
+	identical := string(warm.Bytes) == string(coldEdited.Bytes)
+	changed := string(warm.Bytes) != string(cold.Bytes)
+	fmt.Printf("DEFAULTS %6s  recomputed=%d  cutoff=%d  (edited defaults %q in %s)\n",
+		dur.Round(time.Microsecond), e.Recomputed, e.Cutoff, name, file)
+	fmt.Printf("DEFAULTS warm==cold(edited): %v   warm!=cold(orig): %v\n", identical, changed)
+	return identical && changed
+}
+
+// pickDefaultsModule finds a module name that appears in some module's
+// `defaults: [...]` list AND is itself defined, returning its file and name.
+func pickDefaultsModule(content map[string][]byte) (string, string, bool) {
+	var order []string
+	for f := range content {
+		order = append(order, f)
+	}
+	sortStrings(order)
+	// Collect referenced defaults names.
+	referenced := map[string]bool{}
+	for _, f := range order {
+		for _, m := range defaultsRe.FindAllStringSubmatch(string(content[f]), -1) {
+			for _, n := range quoted.FindAllStringSubmatch(m[1], -1) {
+				referenced[n[1]] = true
+			}
+		}
+	}
+	// Find one that is defined.
+	for _, f := range order {
+		for _, m := range nameRe.FindAllStringSubmatch(string(content[f]), -1) {
+			if referenced[m[1]] {
+				return f, m[1], true
+			}
+		}
+	}
+	return "", "", false
+}
+
+var defaultsRe = regexp.MustCompile(`(?s)defaults:\s*\[(.*?)\]`)
+var quoted = regexp.MustCompile(`"([^"]+)"`)
+
+// injectProp inserts a property line right after the `name: "<name>"` line of the
+// named module.
+func injectProp(src []byte, name, line string) []byte {
+	lines := splitLines(src)
+	target := `name: "` + name + `"`
+	for i, l := range lines {
+		if strings.Contains(l, target) {
+			out := append([]string{}, lines[:i+1]...)
+			out = append(out, line)
+			out = append(out, lines[i+1:]...)
+			return []byte(strings.Join(out, "\n"))
+		}
+	}
+	return src
+}
+
+type editTarget struct {
+	file, module string
+}
+
+// srcLine matches a single quoted source entry line (no backreference; RE2-safe).
+var srcLine = regexp.MustCompile(`^(\s*)"[^"]+\.(?:java|kt|aidl|proto|logtags|cpp|cc|c|h)",\s*$`)
+var nameRe = regexp.MustCompile(`name:\s*"([^"]+)"`)
+
+// pickEdit scans for two adjacent, identically-indented source entries to swap
+// (a real reorder edit) and returns the file, the enclosing module name, and the
+// exact before/after byte snippets to swap.
+func pickEdit(content map[string][]byte) (editTarget, []byte, []byte, bool) {
+	var order []string
+	for f := range content {
+		order = append(order, f)
+	}
+	sortStrings(order)
+	for _, f := range order {
+		lines := splitLines(content[f])
+		for i := 0; i+1 < len(lines); i++ {
+			ma := srcLine.FindStringSubmatch(lines[i])
+			mb := srcLine.FindStringSubmatch(lines[i+1])
+			if ma == nil || mb == nil || ma[1] != mb[1] || lines[i] == lines[i+1] {
+				continue
+			}
+			before := []byte(lines[i] + "\n" + lines[i+1])
+			after := []byte(lines[i+1] + "\n" + lines[i])
+			return editTarget{file: f, module: nearestModuleName(lines, i)}, before, after, true
+		}
+	}
+	return editTarget{}, nil, nil, false
+}
+
+func nearestModuleName(lines []string, idx int) string {
+	for j := idx; j >= 0; j-- {
+		if m := nameRe.FindStringSubmatch(lines[j]); m != nil {
+			return m[1]
+		}
+	}
+	return "?"
+}
+
+func splitLines(b []byte) []string {
+	return splitOn(string(b), '\n')
+}
+
+func splitOn(s string, sep byte) []string {
+	var out []string
+	start := 0
+	for i := 0; i < len(s); i++ {
+		if s[i] == sep {
+			out = append(out, s[start:i])
+			start = i + 1
+		}
+	}
+	out = append(out, s[start:])
+	return out
+}
+
+func swapBytes(src, before, after []byte) []byte {
+	i := indexOf(src, before)
+	if i < 0 {
+		return src
+	}
+	out := make([]byte, 0, len(src))
+	out = append(out, src[:i]...)
+	out = append(out, after...)
+	out = append(out, src[i+len(before):]...)
+	return out
+}
+
+func indexOf(haystack, needle []byte) int {
+	return indexBytes(haystack, needle)
+}
+
+func indexBytes(h, n []byte) int {
+outer:
+	for i := 0; i+len(n) <= len(h); i++ {
+		for j := 0; j < len(n); j++ {
+			if h[i+j] != n[j] {
+				continue outer
+			}
+		}
+		return i
+	}
+	return -1
+}
+
+func sortStrings(s []string) {
+	for i := 1; i < len(s); i++ {
+		for j := i; j > 0 && s[j-1] > s[j]; j-- {
+			s[j-1], s[j] = s[j], s[j-1]
+		}
+	}
+}
