+// archReMutateNinja cold-builds origBP with the arch pipeline, then drives the
+// edit through the ReMutate auto-dispatch (which gates structure-neutrality and
+// chooses in-place vs fallback). Returns the ninja and the ReMutate error.
+func archReMutateNinja(t *testing.T, origBP, editedBP string, changed []string) (string, []error) {
+	t.Helper()
+	ctx := newArchCtx(t, origBP)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+	edits := map[string][]interface{}{}
+	for _, name := range changed {
+		edits[name] = reparseArchProps(t, editedBP, name)
+	}
+	if errs := ctx.ReMutate(nil, edits); len(errs) > 0 {
+		return "", errs
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	return writeModuleNinja(t, ctx), nil
+}
