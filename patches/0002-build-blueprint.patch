+// TestReMutateAutoDispatch verifies the ReMutate entry point: structure-neutral
+// edits to transition-variantized modules take the fast path and are byte-
+// identical; structural edits (changed variants or deps) return a fallback signal.
+func TestReMutateAutoDispatch(t *testing.T) {
+	base := func(variants, outA, deps string) string {
+		return `
+			arch_module { name: "A", variants: [` + variants + `], outputs: ["` + outA + `"]` + deps + ` }
+			arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB1"], exported: "v1" }
+		`
+	}
+
+	t.Run("neutral_output_edit_fast_path", func(t *testing.T) {
+		got, errs := archReMutateNinja(t, base(`"arm", "x86"`, "outA1", `, deps: ["B"]`),
+			base(`"arm", "x86"`, "outA2", `, deps: ["B"]`), []string{"A"})
+		if len(errs) > 0 {
+			t.Fatalf("ReMutate unexpected error: %v", errs)
+		}
+		want := archFullBuildNinja(t, base(`"arm", "x86"`, "outA2", `, deps: ["B"]`))
+		if got != want {
+			t.Errorf("not byte-identical\n--- want ---\n%s\n--- got ---\n%s", want, got)
+		}
+	})
+
+	t.Run("variant_add_surgery", func(t *testing.T) {
+		// A gains a "mips" variant. B already offers mips, so A_mips -> B_mips
+		// resolves and the variant-set surgery handles it without a full rebuild.
+		bp := func(av string) string {
+			return `
+				arch_module { name: "A", variants: [` + av + `], outputs: ["outA"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86", "mips"], outputs: ["outB"], exported: "v1" }
+			`
+		}
+		got, errs := archReMutateNinja(t, bp(`"arm", "x86"`), bp(`"arm", "x86", "mips"`), []string{"A"})
+		if len(errs) > 0 {
+			t.Fatalf("variant add should be handled by surgery, got %v", errs)
+		}
+		want := archFullBuildNinja(t, bp(`"arm", "x86", "mips"`))
+		if got != want {
+			t.Errorf("variant-add surgery ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+		}
+	})
+
+	t.Run("variant_remove_surgery", func(t *testing.T) {
+		// A drops its "mips" variant. No dependent requests mips, so it is removed
+		// cleanly by the surgery -- byte-identical, no full rebuild.
+		bp := func(av string) string {
+			return `
+				arch_module { name: "A", variants: [` + av + `], outputs: ["outA"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86", "mips"], outputs: ["outB"], exported: "v1" }
+			`
+		}
+		got, errs := archReMutateNinja(t, bp(`"arm", "x86", "mips"`), bp(`"arm", "x86"`), []string{"A"})
+		if len(errs) > 0 {
+			t.Fatalf("variant remove should be handled by surgery, got %v", errs)
+		}
+		want := archFullBuildNinja(t, bp(`"arm", "x86"`))
+		if got != want {
+			t.Errorf("variant-remove surgery ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+		}
+	})
+
+	t.Run("dep_change_handled_in_place", func(t *testing.T) {
+		// Removing A's dependency on B is NOT a variant-structure change, so the
+		// in-place re-derive handles it (it re-runs the dependency mutators per
+		// variant) -- no fallback, byte-identical.
+		got, errs := archReMutateNinja(t, base(`"arm", "x86"`, "outA1", `, deps: ["B"]`),
+			base(`"arm", "x86"`, "outA1", ``), []string{"A"})
+		if len(errs) > 0 {
+			t.Fatalf("dep change should be handled in place, got %v", errs)
+		}
+		want := archFullBuildNinja(t, base(`"arm", "x86"`, "outA1", ``))
+		if got != want {
+			t.Errorf("dep-change in-place ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+		}
+	})
+
+	t.Run("non_coalescable_property_mutator_handled", func(t *testing.T) {
+		// A pipeline with a non-coalescable mutator that ALSO contributes a property
+		// (sanitizeLikeMutator, models real Soong sanitizer/lto). The in-place
+		// re-derive re-runs ALL bottom-up mutators on the existing variants, so the
+		// contribution is captured -- no fallback, byte-identical to a full build.
+		newSanitizeCtx := func(bp string) *Context {
+			ctx := NewContext()
+			ctx.MockFileSystem(map[string][]byte{"Android.bp": []byte(bp)})
+			ctx.RegisterModuleType("arch_module", newArchProvModule)
+			ctx.RegisterBottomUpMutator("deps", depsMutator).MutatesDependencies()
+			ctx.RegisterTransitionMutator("arch", archLikeMutator{})
+			ctx.RegisterBottomUpMutator("sanitize", sanitizeLikeMutator).MutatesDependencies()
+			if _, errs := ctx.ParseBlueprintsFiles("Android.bp", nil); len(errs) > 0 {
+				t.Fatalf("parse: %v", errs)
+			}
+			return ctx
+		}
+		fullSanitize := func(bp string) string {
+			ctx := newSanitizeCtx(bp)
+			if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+				t.Fatalf("full resolve: %v", errs)
+			}
+			if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+				t.Fatalf("full prepare: %v", errs)
+			}
+			return writeModuleNinja(t, ctx)
+		}
+
+		ctx := newSanitizeCtx(base(`"arm", "x86"`, "outA1", ``))
+		ctx.SetKeepPristineModules(true)
+		if err := ctx.SnapshotPreMutationState(); err != nil {
+			t.Fatalf("snapshot: %v", err)
+		}
+		if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+			t.Fatalf("resolve: %v", errs)
+		}
+		if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+			t.Fatalf("prepare: %v", errs)
+		}
+		ctx.SnapshotInterfaceHashes()
+		rp := newSanitizeCtx(base(`"arm", "x86"`, "outA2", ``))
+		edits := map[string][]interface{}{"A": rp.moduleGroupFromName("A", nil).modules[0].properties}
+		if errs := ctx.ReMutate(nil, edits); len(errs) > 0 {
+			t.Fatalf("ReMutate unexpectedly failed (should handle non-coalescable mutator): %v", errs)
+		}
+		if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+			t.Fatalf("warm prepare: %v", errs)
+		}
+		got := writeModuleNinja(t, ctx)
+		want := fullSanitize(base(`"arm", "x86"`, "outA2", ``))
+		if got != want {
+			t.Errorf("non-coalescable in-place ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+		}
+	})
+}
