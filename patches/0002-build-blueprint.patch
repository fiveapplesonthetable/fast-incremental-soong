+// archFullBuildNinja runs a full build of bp with the arch (transition) pipeline.
+func archFullBuildNinja(t *testing.T, bp string) string {
+	t.Helper()
+	ctx := newArchCtx(t, bp)
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("arch resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("arch prepare: %v", errs)
+	}
+	return writeModuleNinja(t, ctx)
+}
+
+func reparseArchProps(t *testing.T, bp, name string) []interface{} {
+	t.Helper()
+	ctx := newArchCtx(t, bp)
+	group := ctx.moduleGroupFromName(name, nil)
+	if group == nil {
+		t.Fatalf("reparseArchProps: %q not found", name)
+	}
+	return group.modules[0].properties
+}
+
+// archInPlaceNinja cold-builds origBP with the arch pipeline, applies a
+// structure-neutral edit via ReMutateModulesInPlace, and returns the module ninja.
+func archInPlaceNinja(t *testing.T, origBP, editedBP string, changed []string) string {
+	t.Helper()
+	ctx := newArchCtx(t, origBP)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+	for _, name := range changed {
+		if err := ctx.SetBaselineProperties(name, reparseArchProps(t, editedBP, name)); err != nil {
+			t.Fatalf("SetBaselineProperties(%q): %v", name, err)
+		}
+	}
+	if errs := ctx.ReMutateModulesInPlace(nil, changed); len(errs) > 0 {
+		t.Fatalf("ReMutateModulesInPlace: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	return writeModuleNinja(t, ctx)
+}
