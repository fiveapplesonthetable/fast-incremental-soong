+// TestIncrementalProviderHashAggregate verifies that the O(edit) incremental
+// update of the global provider-hash aggregate (updateProvidersHashesIncremental)
+// produces byte-identical results to a full O(tree) recompute
+// (calculateProvidersHashes), across the three delta kinds a warm edit can make to
+// a module's provider hashes: change a value, set one from zero, and clear one to
+// zero. This is the soundness gate for skipping the O(tree) singleton fold on warm
+// rebuilds -- if the aggregate ever drifted, a singleton would wrongly restore from
+// cache and emit stale output.
+func TestIncrementalProviderHashAggregate(t *testing.T) {
+	pid := IncrementalTestProviderKey.id
+	if providerRegistry[pid].mutator == singletonTag {
+		t.Fatalf("test provider unexpectedly registered as a singleton provider")
+	}
+
+	build := func() (*Context, []*moduleInfo) {
+		ctx := newArchCtx(t, genArchTree(12, "outA"))
+		if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+			t.Fatalf("resolve: %v", errs)
+		}
+		var mods []*moduleInfo
+		v := uint64(1)
+		for m := range ctx.iterateAllVariants() {
+			m.providerInitialValueHashes = make([]uint64, len(providerRegistry))
+			// Give roughly half the modules a non-zero value so the "set from zero"
+			// and "clear to zero" deltas exercise both transitions.
+			if v%2 == 0 {
+				m.providerInitialValueHashes[pid] = v * 1000003
+			}
+			mods = append(mods, m)
+			v++
+		}
+		ctx.calculateProvidersHashes()
+		if !ctx.providerHashesFolded {
+			t.Fatalf("expected providerHashesFolded after cold fold")
+		}
+		return ctx, mods
+	}
+
+	// edit applies a delta to one module, updates the aggregate incrementally, then
+	// asserts it equals a full recompute of the same final state.
+	edit := func(name string, mutate func(m *moduleInfo)) {
+		ctx, mods := build()
+		var target *moduleInfo
+		for _, m := range mods {
+			if m.group.name == name {
+				target = m
+				break
+			}
+		}
+		if target == nil {
+			t.Fatalf("module %q not found", name)
+		}
+		mutate(target)
+		ctx.dirtyModules = map[*moduleInfo]bool{target: true}
+		ctx.membershipChanged = false
+		ctx.updateProvidersHashesIncremental()
+		got := slices.Clone(ctx.providerValueHashes)
+
+		ctx.calculateProvidersHashes() // ground-truth full recompute of final state
+		want := ctx.providerValueHashes
+		if !slices.Equal(got, want) {
+			t.Errorf("%s: incremental aggregate != full recompute\n got=%v\nwant=%v", name, got, want)
+		}
+	}
+
+	// Change an existing value.
+	edit("m2", func(m *moduleInfo) { m.providerInitialValueHashes[pid] = 0xDEADBEEF })
+	// Set a value from zero (m1 got an odd index -> zero above).
+	edit("m1", func(m *moduleInfo) { m.providerInitialValueHashes[pid] = 0xFEEDFACE })
+	// Clear a value to zero.
+	edit("m4", func(m *moduleInfo) { m.providerInitialValueHashes[pid] = 0 })
+	// No-op edit (dirty but unchanged) must leave the aggregate untouched.
+	edit("m6", func(m *moduleInfo) {})
+}
