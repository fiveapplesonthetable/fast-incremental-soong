+// TestIncrementalProviderHashAggregateLifecycle drives the FULL production warm
+// path -- cold fold, BeginIncrementalBuild, ReMutateModules (which resets and
+// replaces the edited module's *moduleInfo), targeted regenerate (which propagates
+// the provider change up the chain to readers that are NOT in c.dirtyModules), then
+// the incremental fold -- and asserts the resulting aggregate is byte-identical to
+// a full recompute of the final state.
+//
+// This is the regression test the arithmetic unit test cannot be: it exercises the
+// three ways the naive design drifts -- (1) resetModuleBuildActions clears the
+// per-module snapshot, (2) ReMutateModules replaces the *moduleInfo object, and
+// (3) propagation regenerates readers (B, A) whose provider hashes change but which
+// never enter c.dirtyModules. All three are covered by anchoring snapshots to
+// stable identity and folding over the regenerated set.
+func TestIncrementalProviderHashAggregateLifecycle(t *testing.T) {
+	orig := `
+		chain_module { name: "C", outputs: ["oC"], exported: "c1" }
+		chain_module { name: "B", outputs: ["oB"], exported: "b1", deps: ["C"] }
+		chain_module { name: "A", outputs: ["oA"], exported: "a1", deps: ["B"] }
+	`
+	edited := `
+		chain_module { name: "C", outputs: ["oC"], exported: "c2" }
+		chain_module { name: "B", outputs: ["oB"], exported: "b1", deps: ["C"] }
+		chain_module { name: "A", outputs: ["oA"], exported: "a1", deps: ["B"] }
+	`
+
+	ctx := newChainCtx(t, orig)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare: %v", errs)
+	}
+	ctx.calculateProvidersHashes() // the cold fold the resident server performs
+	ctx.SnapshotInterfaceHashes()
+
+	// Sanity: editing C must change C, B and A's provider values (a real chain).
+	beforeIDs := map[string][]uint64{}
+	for k, v := range ctx.foldedProviderHashes {
+		beforeIDs[k] = slices.Clone(v)
+	}
+
+	ctx.BeginIncrementalBuild()
+	props := reparseChainProps(t, edited, "C")
+	if err := ctx.SetBaselineProperties("C", props); err != nil {
+		t.Fatalf("SetBaselineProperties: %v", err)
+	}
+	if errs := ctx.ReMutateModules(nil, []string{"C"}); len(errs) > 0 {
+		t.Fatalf("ReMutateModules: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	if len(ctx.regeneratedModules) < 3 {
+		t.Fatalf("expected the chain (C,B,A) to regenerate, got %d modules", len(ctx.regeneratedModules))
+	}
+	ctx.updateProvidersHashesIncremental() // the warm fold the resident server performs
+	got := slices.Clone(ctx.providerValueHashes)
+
+	ctx.calculateProvidersHashes() // ground truth: full recompute of the final state
+	want := ctx.providerValueHashes
+	if !slices.Equal(got, want) {
+		t.Errorf("warm incremental aggregate != full recompute after real lifecycle\n got=%v\nwant=%v", got, want)
+	}
+}
