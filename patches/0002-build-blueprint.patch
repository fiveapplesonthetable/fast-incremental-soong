+// providerTerm folds a module's stable identity salt together with the hash of a
+// single provider value into one term. The global per-provider aggregate is the
+// commutative sum of these terms across all modules, which makes it incrementally
+// updatable: when a module's value changes we subtract its old term and add its
+// new one. Folding the salt in means two distinct modules whose values happen to
+// swap cannot net to zero (their terms are different functions), so the aggregate
+// still flips when content actually changes.
+func providerTerm(salt, valueHash uint64) uint64 {
+	h := fnv.New64a()
+	var b [16]byte
+	binary.LittleEndian.PutUint64(b[0:8], salt)
+	binary.LittleEndian.PutUint64(b[8:16], valueHash)
+	h.Write(b[:])
+	return h.Sum64()
