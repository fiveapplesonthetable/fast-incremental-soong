 }
 
+// SetBuildActionCache injects a pre-created BuildActionCache (e.g. an in-memory
+// cache reused across builds by a resident soong_build server) instead of
+// letting PrepareBuildActions open the on-disk cache lazily. It also wires up
+// the EncContext, which PrepareBuildActions would otherwise initialize in the
+// same lazy block. Must be called before PrepareBuildActions.
+func (c *Context) SetBuildActionCache(cache *BuildActionCache) {
+	c.buildActionsCache = cache
+	c.EncContext = gobtools.NewEncContext(cache.referencesDb)
+}
+
+// DependenciesReady reports whether ResolveDependencies (parse + dep resolution
+// + mutators + variant creation) has already completed on this Context. A
+// resident server uses this to decide whether the resolved+mutated graph can be
+// reused for an incremental re-analysis (graph residency).
+func (c *Context) DependenciesReady() bool {
+	return c.dependenciesReady
+}
+
+// ResetBuildActionsForReanalysis clears the per-module build actions generated by
+// the previous PrepareBuildActions pass, while preserving the resolved
+// dependency graph and module variants (dependenciesReady stays true). After
+// calling this, PrepareBuildActions can be run again on the same Context and
+// will skip ResolveDependencies (the ~34.5s phase on a full tree), only
+// re-generating build actions -- this is the core of "graph residency".
+//
+// EXPERIMENTAL / INCOMPLETE: this does NOT re-parse changed Android.bp files or
+// re-run mutators, so modules are regenerated from the property state captured
+// during the last full analysis. It is therefore only correct when the resolved
+// graph is unchanged (same module set, same dependencies/variants) AND edited
+// properties are re-applied to the module property structs by the caller before
+// regeneration. Structural edits (added/removed modules or deps, or changes to
+// mutator-consumed properties) must fall back to a fresh Context. Callers must
+// gate this behind that safety check and byte-verify the resulting ninja.
+func (c *Context) ResetBuildActionsForReanalysis() {
+	parallelVisit(c.iterateAllVariants(), unorderedVisitorImpl{}, parallelVisitLimit,
+		func(module *moduleInfo, pause pauseFunc) bool {
+			c.resetModuleBuildActions(module)
+			return false
+		})
+	c.buildActionsReady = false
+}
+
+// resetModuleBuildActions restores a single module to its pristine, pre-generate
+// state so its GenerateBuildActions can be run again on the resident Context.
+func (c *Context) resetModuleBuildActions(module *moduleInfo) {
+	// Module.GenerateBuildActions is single-use: a logicModule that already
+	// generated build actions caches internal state and cannot be run again.
+	// Restore a fresh logicModule from the pristine pre-generate snapshot captured
+	// in cloneModules, so the next generate pass runs on a clean object. (Cloning
+	// the post-generate module instead would fail, because GenerateBuildActions can
+	// append to the properties slice.)
+	module.logicModule, module.properties = c.restorePristineLogicModule(module)
+	module.logicModule.setInfo(module)
+
+	// Some module implementations cache generate-time state in non-property fields
+	// that CopyProperties does not reset (e.g. SingletonModule's single-variant
+	// guard), and a few factories return a shared instance rather than a fresh
+	// object. Give such modules a chance to clear that state before regeneration.
+	if r, ok := module.logicModule.(interface{ ResetBuildActionsState() }); ok {
+		r.ResetBuildActionsState()
+	}
+
+	module.actionDefs = localBuildActions{}
+	module.buildParams = nil
+	module.startedGenerateBuildActions = false
+	module.finishedGenerateBuildActions = false
+	// Restore the post-mutator provider state: keep providers set by mutators
+	// (which the regenerate pass does not re-run) and drop generate-set ones so the
+	// regenerate pass can set them again without a double-set. The values and the
+	// initial-value hashes are rebuilt by generate as needed.
+	module.providerInfo = providerInfo{
+		providers: append([]interface{}(nil), module.pristineProviders...),
+	}
+	// Drop per-module incremental bookkeeping (cache key, input hash, restored
+	// providers/globs); it is recomputed during regeneration.
+	module.incrementalInfo = incrementalInfo{}
+	// Keep modules live across regenerations. FreeModuleAfterGenerateBuildActions
+	// nils logicModule after generate (a memory optimization); if left set, the
+	// regenerate pass would re-free modules mid-flight and a dependent module would
+	// then visit a nil dependency. The resident graph keeps modules in memory
+	// anyway, so disabling the free is both correct and desirable. Also clear the
+	// proxy name caches, which are only populated when a module is freed.
+	module.freeAfterGenerateBuildActions = false
+	module.cachedName = ""
+	module.cachedString = ""
+	module.cachedUniqueName = ""
+}
+
+// MarkModulesDirty configures the Context for a targeted incremental regenerate.
+// The named modules and their transitive reverse-dependency closure are marked
+// dirty and reset to pristine; a following PrepareBuildActions regenerates only
+// those (generateModuleBuildActions skips clean modules) and keeps every clean
+// module's existing build actions and globals. This is the minimal-work path:
+// only the modules whose inputs changed (plus dependents that may read their
+// changed providers) are re-run. Returns the number of dirty module variants.
+//
+// The reverse-dependency closure is conservative (every transitive dependent),
+// which is always correct; provider-hash comparison can prune it later so that
+// dependents whose inputs did not actually change are left clean.
+func (c *Context) MarkModulesDirty(changedModuleNames []string) int {
+	changed := make(map[string]bool, len(changedModuleNames))
+	for _, n := range changedModuleNames {
+		changed[n] = true
+	}
+
+	dirty := map[*moduleInfo]bool{}
+	var worklist []*moduleInfo
+	for module := range c.iterateAllVariants() {
+		if changed[module.group.name] && !dirty[module] {
+			dirty[module] = true
+			worklist = append(worklist, module)
+		}
+	}
+	for len(worklist) > 0 {
+		m := worklist[len(worklist)-1]
+		worklist = worklist[:len(worklist)-1]
+		for _, rdep := range m.reverseDeps {
+			if !dirty[rdep] {
+				dirty[rdep] = true
+				worklist = append(worklist, rdep)
+			}
+		}
+	}
+
+	for m := range dirty {
+		c.resetModuleBuildActions(m)
+	}
+
+	c.dirtyModules = dirty
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return len(dirty)
+}
+
+// singletonsNeedRegen reports whether singletons must be regenerated. In a full
+// build (dirtyModules == nil) they always run. In a targeted incremental build
+// singletons run only on a full (cold) build. On a targeted resident rebuild
+// (dirtyModules != nil) they are kept: a singleton is single-use and aggregates
+// state across the whole module set (VisitAllModules + provider reads), so it
+// cannot be faithfully re-run on the resident Context after the fact -- re-running
+// it would double-set its providers and read incomplete state, producing wrong or
+// empty output. Keeping the prior build's singleton actions is correct for the
+// common case where the edit does not change any singleton's inputs. An edit that
+// *does* change a singleton input (e.g. adding an aconfig flag) is not yet handled
+// incrementally and must be caught by the byte-verification gate / fall back to a
+// full build. See docs/resident_incremental_build.md.
+func (c *Context) singletonsNeedRegen() bool {
+	// On a membership change (add/remove) the whole-graph aggregations change, so
+	// singletons must regenerate over the new module set. generateSingletonBuildActions
+	// resets each singleton's single-use generate-state first so the re-run is clean.
+	// A stable-module-set targeted rebuild keeps the prior build's singleton actions.
+	return c.dirtyModules == nil || c.membershipChanged
+}
+
+// incrementalPureAdd reports whether this warm rebuild only added modules (no
+// pre-existing module changed). When true, an additive whole-graph singleton may
+// keep its cached aggregate and fold in only the added modules
