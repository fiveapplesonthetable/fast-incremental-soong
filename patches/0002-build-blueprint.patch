+
+package incr
+
+import (
+	"bytes"
+	"fmt"
+	"strings"
+)
+
+// bootstrap_go_package is the Soong build-itself type for a Go package that
+// minibp compiles during the bootstrap stage (everything under build/soong/,
+// build/blueprint/, system/tools/aidl/build/, etc. that ships as part of the
+// build binary itself). The ninja Soong emits has two statements per package:
+// a generateSerializers stamp that runs gob codegen over the srcs, and a
+// compile of the srcs (plus dep .a archives) into pkg/<pkgPath>.a.
+//
+// What the emitter captures here:
+//
+//   - pkgPath is the install path under out/host/linux-x86/bin/go/<name>/pkg/
+//     and a key part of the module's identity (two packages with the same name
+//     but different pkgPath produce distinct .a files).
+//   - srcs is the canonical list of .go files compiled (testSrcs are emitted
+//     into the .a too in Soong's host-test-only world; we keep them in their
+//     own line so a srcs-only edit and a testSrcs-only edit are distinguishable
+//     in the fragment).
+//   - deps are other bootstrap_go_package archives that must be on the import
+//     path; depHashes already captures each dep's resolved identity, so changes
+//     to a dep's srcs/pkgPath propagate here through the engine.
+//
+// The output stanza is content-addressed by the resolved def hash so the
+// fragment is stable across reorderings; the rule keyword and pkgPath string
+// match the Soong-emitted rule names so a future textual diff against a real
+// bootstrap.ninja can be done by simple substring search.
+func emitBootstrapGoPackage(name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	id := fmt.Sprintf("%016x", hashBytes(resolvedDef))
+	dep := fmt.Sprintf("%016x", hashBytes(depHashes))
+	pkgPath := strings.Trim(res.props["pkgPath"], "\"")
+	if pkgPath == "" {
+		pkgPath = name
+	}
+	srcs := strings.TrimSpace(res.props["srcs"])
+	testSrcs := strings.TrimSpace(res.props["testSrcs"])
+
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "# module %s (bootstrap_go_package)\n", name)
+	fmt.Fprintf(&b, "# pkgPath %s\n", pkgPath)
+	fmt.Fprintf(&b, "build out/host/linux-x86/bin/go/%s/pkg/%s.a: g.bootstrap.compile\n", name, pkgPath)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	if srcs != "" {
+		fmt.Fprintf(&b, "    srcs = %s\n", srcs)
+	}
+	if testSrcs != "" {
+		fmt.Fprintf(&b, "    test_srcs = %s\n", testSrcs)
+	}
+	return b.Bytes()
+}
+
+func init() {
+	registerEmitter("bootstrap_go_package", emitBootstrapGoPackage)
+}
diff --git a/incr/emit_droidstubs.go b/incr/emit_droidstubs.go
