+// TestIncrementalTransitionInPlace covers structure-neutral edits to
+// transition-variantized (arch/os-like) modules: the in-place fast path must
+// reproduce a full build byte-for-byte across all variants.
+func TestIncrementalTransitionInPlace(t *testing.T) {
+	cases := []struct {
+		name    string
+		orig    string
+		edited  string
+		changed []string
+	}{
+		{
+			name: "output_edit_all_variants",
+			orig: `
+				arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA1"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB1"], exported: "v1" }
+			`,
+			edited: `
+				arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA2"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB1"], exported: "v1" }
+			`,
+			changed: []string{"A"},
+		},
+		{
+			name: "exported_edit_propagates_across_variants",
+			// Editing B's exported value must regenerate A's matching variants.
+			orig: `
+				arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA1"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB1"], exported: "v1" }
+			`,
+			edited: `
+				arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA1"], deps: ["B"] }
+				arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB1"], exported: "v2" }
+			`,
+			changed: []string{"B"},
+		},
+		{
+			name: "single_variant_module",
+			orig: `
+				arch_module { name: "A", outputs: ["outA1"] }
+			`,
+			edited: `
+				arch_module { name: "A", outputs: ["outA2"] }
+			`,
+			changed: []string{"A"},
+		},
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			want := archFullBuildNinja(t, tc.edited)
+			got := archInPlaceNinja(t, tc.orig, tc.edited, tc.changed)
+			if got != want {
+				t.Errorf("in-place transition ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+			}
+		})
+	}
+}
