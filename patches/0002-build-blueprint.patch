+// TestIncrementalAddAndChangeSameBuild exercises a single warm build that BOTH
+// adds a module and re-mutates an existing one that now depends on it (the
+// runBuildReuse order: add then re-mutate). The added module and the changed
+// module must both end up in the dirty set -- a regression guard against the
+// dirty-set being overwritten rather than unioned across incremental steps.
+func TestIncrementalAddAndChangeSameBuild(t *testing.T) {
+	cold := `
+		arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA"] }
+		arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB"], exported: "v1" }
+	`
+	edited := `
+		arch_module { name: "A", variants: ["arm", "x86"], outputs: ["outA"], deps: ["C"] }
+		arch_module { name: "B", variants: ["arm", "x86"], outputs: ["outB"], exported: "v1" }
+		arch_module { name: "C", variants: ["arm", "x86"], outputs: ["outC"], exported: "vC" }
+	`
+	ctx := newArchCtx(t, cold)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+
+	reparsed := newArchCtx(t, edited)
+	changed, added, removed, err := ctx.DiffParsedModules(reparsed)
+	if err != nil {
+		t.Fatalf("diff: %v", err)
+	}
+	if len(added) != 1 || added[0] != "C" || len(changed) != 1 || changed["A"] == nil || len(removed) != 0 {
+		t.Fatalf("expected add C + change A, got changed=%v added=%v removed=%v", keysOf(changed), added, removed)
+	}
+	ctx.BeginIncrementalBuild()
+	if errs := ctx.IncrementalAddModules(nil, reparsed, added); len(errs) > 0 {
+		t.Fatalf("add: %v", errs)
+	}
+	if errs := ctx.ReMutate(nil, changed); len(errs) > 0 {
+		t.Fatalf("remutate: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("warm prepare: %v", errs)
+	}
+	got := writeModuleNinja(t, ctx)
+	want := archFullBuildNinja(t, edited)
+	if got != want {
+		t.Errorf("add+change ninja != full build\n--- want ---\n%s\n--- got ---\n%s", want, got)
+	}
+}
