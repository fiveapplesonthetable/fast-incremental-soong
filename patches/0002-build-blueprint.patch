new file mode 100644
index 0000000..604b916
--- /dev/null
+++ b/incremental_mutation.go
@@ -0,0 +1,1868 @@
+// Copyright 2024 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package blueprint
+
+import (
+	"fmt"
+	"hash/fnv"
+	"io"
+	"os"
+	"path/filepath"
+	"reflect"
+	"sort"
+	"strconv"
+	"strings"
+	"text/scanner"
+
+	"github.com/google/blueprint/pathtools"
+	"github.com/google/blueprint/proptools"
+)
+
+// Incremental re-mutation
+// =======================
+//
+// A resident soong_build server keeps the fully-resolved, fully-mutated module
+// graph in memory across builds (see docs/resident_incremental_build.md). A
+// no-op or graph-neutral edit can then skip parse + mutate + dep-resolution
+// entirely. A *real* Android.bp edit, however, changes a module's parsed
+// properties, so its post-mutation property structs and its emitted ninja are
+// stale. Re-running the whole mutator pipeline to fix them is the ~35 s
+// resolve_deps phase -- the single biggest cost of a warm rebuild.
+//
+// This file makes that recompute incremental. The key soundness fact is that
+// Soong mutators reach other modules only by traversing dependency edges
+// (VisitDirectDeps / WalkDeps / providers on deps). The dependency graph is
+// therefore the mutation data-flow graph, and an edit to module M can only
+// change the mutator output of M itself and of modules that *read* M -- i.e. M's
+// reverse-dependency closure -- and only as far as M's *outputs* (the providers
+// and variant structure other modules observe) actually change. So we:
+//
+//  1. Keep a pre-mutation baseline (the parsed base module) for every group, in
+//     RAM, captured on the cold build before mutators run.
+//  2. On a warm edit, reset each changed group to a fresh baseline carrying the
+//     re-parsed properties, and re-run the mutator pipeline scoped to just those
+//     groups (clean modules keep their final state and are only read).
+//  3. Repoint clean dependents' direct deps at the freshly created variants and
+//     rebuild the reverse-dep graph, then hand the changed variants to the
+//     existing targeted-generate path (generateModuleBuildActions dirty set).
+//
+// The result is byte-identical to a full build for the supported edit classes,
+// which is enforced by incremental_mutation_test.go across a corpus of edits.
+//
+// Scope of this first stage: bottom-up mutators (including variant-creating ones
+// via splitModules) and dependency edits whose changed module's observable
+// outputs (providers, variant set) don't widen beyond the changed group. Cross-
+// module provider propagation (exported-flag edits) and transition mutators
+// (arch/os/apex) are handled in later stages; ReMutateModules reports
+// errUnsupportedMutator so the caller can fall back to a full RunBlueprint when a
+// transition mutator is present in the pipeline (always correct).
+
+// residentBaseline is the pre-mutation snapshot of a single module group: the
+// parsed base module exactly as it existed after parse and before any mutator
+// ran. Kept resident so a warm rebuild can rebuild the group's variants from its
+// (possibly re-parsed) definition without touching the rest of the tree.
+type residentBaseline struct {
+	typeName          string
+	factory           ModuleFactory
+	relBlueprintsFile string
+	pos               scanner.Position
+	propertyPos       map[string]scanner.Position
+	// logicModule/properties are a deep copy taken at snapshot time. Each
+	// instantiation re-clones from these so repeated resets stay independent.
+	logicModule Module
+	properties  []interface{}
+	// parsedHash is a content hash of properties; a change is the ground-truth
+	// signal that this module's definition changed.
+	parsedHash uint64
+	// generated is true if this module was created by another module's load hook
+	// (CreateModule), not parsed directly from a .bp file. Such modules follow their
+	// creator and are not independently editable, so DiffParsedModules excludes them
+	// from add/remove detection: a throwaway re-parse may not recreate them
+	// byte-identically (re-parse fidelity), which would otherwise look like a
+	// spurious structural change and force a needless full rebuild.
+	generated bool
+}
+
+// incrementalMutation is the resident bookkeeping for incremental re-mutation.
+// nil unless SnapshotPreMutationState has been called.
+type incrementalMutation struct {
+	baselines map[string]*residentBaseline // keyed by module group name
+	// interfaceHash maps a module's stable identity (unique name + variant) to a
+	// hash of the provider values it exposes, captured after the previous build's
+	// generate. A change means dependents that read those providers must
+	// regenerate; see provider-change propagation in generateModuleBuildActions.
+	interfaceHash map[string]uint64
+	// fileHashes maps each .bp file (relBlueprintsFile) to a content hash captured
+	// at the cold parse. A warm rebuild re-hashes the files and diffs only modules
+	// whose defining file actually changed on disk -- a module cannot have changed
+	// if its file did not, regardless of any re-parse non-determinism in unrelated
+	// modules. This is both a correctness guard (no false-positive changes from
+	// re-parse jitter) and the basis for re-parsing only changed files.
+	fileHashes map[string]uint64
+}
+
+// hashBlueprintFile returns a content hash of the given .bp file (path relative to
+// the source root). It reads the real file from disk via an absolute path so the
+// cold snapshot and the warm re-check hash byte-identically (reading through two
+// different Context filesystems gave inconsistent hashes for some files). The
+// provided fallback filesystem is used only when the real file cannot be read
+// (e.g. the test mock fs). ok is false if neither source can read it.
+func (c *Context) hashBlueprintFile(rel string, fallback pathtools.FileSystem) (h uint64, ok bool) {
+	if rel == "" {
+		return 0, false
+	}
+	// Real builds set SrcDir to the source root; read by absolute path so cold and
+	// warm hash byte-identically. Tests leave SrcDir empty and use a mock fs (the
+	// fallback); reading from cwd there would pick up unrelated real files.
+	if c.SrcDir() != "" {
+		if data, err := os.ReadFile(filepath.Join(c.SrcDir(), rel)); err == nil {
+			hasher := fnv.New64a()
+			hasher.Write(data)
+			return hasher.Sum64(), true
+		}
+	}
+	if fallback == nil {
+		return 0, false
+	}
+	f, err := fallback.Open(rel)
+	if err != nil {
+		return 0, false
+	}
+	defer f.Close()
+	hasher := fnv.New64a()
+	if _, err := io.Copy(hasher, f); err != nil {
+		return 0, false
+	}
+	return hasher.Sum64(), true
+}
+
+// blueprintFileHashes hashes every distinct .bp file referenced by the current
+// baselines. Used to snapshot the cold parse's files and, on a warm rebuild, to
+// detect which files changed.
+func (c *Context) blueprintFileHashes() map[string]uint64 {
+	out := make(map[string]uint64)
+	// Iterate the full module-group list (not the bare-name-keyed baselines map,
+	// which drops duplicate-named groups' files) so every .bp file is covered.
+	for _, group := range c.moduleGroups {
+		if len(group.modules) == 0 {
+			continue
+		}
+		rel := group.modules[0].relBlueprintsFile
+		if _, done := out[rel]; done {
+			continue
+		}
+		if h, ok := c.hashBlueprintFile(rel, c.fs); ok {
+			out[rel] = h
+		}
+	}
+	return out
+}
+
+// ChangedBlueprintFiles returns the subset of .bp files whose on-disk content
+// differs from the resident cold-build snapshot, so a warm rebuild can reparse
+// only those files instead of the whole tree (the O(tree) parse_bp pass).
+//
+// currentFiles is the full list of .bp files for this build (from
+// ListModulePaths). ok is false -- meaning the caller MUST fall back to a full
+// reparse -- when the snapshot is unavailable or the SET of .bp files changed (a
+// file was added or removed): a per-file content diff cannot represent a
+// file-set change, and DiffParsedModules's added/removed detection only covers
+// modules within files that still exist. A full reparse is always correct.
+//
+// DiffParsedModules tolerates a partial reparse (one built by ParseFileList over
+// just `changed`): it scopes added/removed detection by an on-disk file-hash
+// check, so modules in files we did not reparse are correctly treated as
+// unchanged rather than removed.
+func (c *Context) ChangedBlueprintFiles(currentFiles []string) (changed []string, ok bool) {
+	if c.incMutation == nil || c.incMutation.fileHashes == nil {
+		fmt.Fprintf(os.Stderr, "ChangedBlueprintFiles: no resident snapshot -> full reparse\n")
+		return nil, false
+	}
+	// Note: a REMOVED .bp file needs no special handling here. We reparse only the
+	// files in `changed`; a deleted file simply isn't in currentFiles, and
+	// DiffParsedModules still catches it -- its baseline's fileChanged() hashes the
+	// now-missing file, fails to read it, treats it as changed, finds its modules
+	// unmatched in the reparse, and flags them removed -> the caller falls back to a
+	// full rebuild. So we never need to return ok=false for a file-set change.
+	newOrModuleless := 0
+	unreadable := 0
+	for _, rel := range currentFiles {
+		old, had := c.incMutation.fileHashes[rel]
+		if !had {
+			// No baseline hash: module-less at snapshot time, or brand new. Reparse it
+			// (cheap when module-less); a newly-defined module is flagged added ->
+			// correct full-rebuild fallback.
+			changed = append(changed, rel)
+			newOrModuleless++
+			continue
+		}
+		h, hok := c.hashBlueprintFile(rel, c.fs)
+		if !hok {
+			// Can't verify -> reparse to be safe.
+			changed = append(changed, rel)
+			unreadable++
+			continue
+		}
+		if h != old {
+			changed = append(changed, rel)
+		}
+	}
+	fmt.Fprintf(os.Stderr, "ChangedBlueprintFiles: current=%d snapshot=%d changed=%d (new/module-less=%d unreadable=%d)\n",
+		len(currentFiles), len(c.incMutation.fileHashes), len(changed), newOrModuleless, unreadable)
+	return changed, true
+}
+
+// moduleIdentity returns a stable key for a module across builds (it survives
+// re-mutation, which replaces the *moduleInfo but keeps the unique name and
+// variant). uniqueName is the namespaced unique name already computed by the
+// caller.
+func moduleIdentity(uniqueName, variantName string) string {
+	return uniqueName + "\x00" + variantName
+}
+
+// interfaceHashOf hashes the provider values a module exposes to dependents.
+// Hashing the whole provider set is a conservative interface: any provider change
+// triggers propagation, which is always sound (at worst it over-regenerates).
+func interfaceHashOf(m *moduleInfo) (uint64, bool) {
+	h, err := proptools.CalculateHashTolerant(&m.providers)
+	if err != nil {
+		return 0, false
+	}
+	return h, true
+}
+
+// SnapshotInterfaceHashes records the post-generate provider interface of every
+// module, keyed by stable identity. Call after the cold build's
+// PrepareBuildActions (cachedUniqueName is populated by generate). Reused as the
+// baseline a warm rebuild compares against to decide propagation.
+func (c *Context) SnapshotInterfaceHashes() {
+	if c.incMutation == nil {
+		return
+	}
+	hashes := make(map[string]uint64, 4096)
+	for m := range c.iterateAllVariants() {
+		if h, ok := interfaceHashOf(m); ok {
+			hashes[moduleIdentity(m.cachedUniqueName, m.variant.name)] = h
+		}
+	}
+	c.incMutation.interfaceHash = hashes
+}
+
+// depInterfaceChanged reports whether any direct dependency of module had its
+// exposed provider interface change during the current incremental generate pass.
+// The generate visit is bottom-up, so a dep's interfaceChanged flag is final
+// before its dependents are visited.
+func (c *Context) depInterfaceChanged(module *moduleInfo) bool {
+	for _, dep := range module.directDeps {
+		if dep.module.interfaceChanged {
+			return true
+		}
+	}
+	// Implicit ordering deps within the same group (earlier variants) can also feed
+	// providers; treat a changed same-group earlier variant as a trigger too.
+	return false
+}
+
+// commitInterfaceHashes folds the new provider interface of every regenerated
+// module back into the resident baseline so the next warm rebuild compares
+// against current values.
+func (c *Context) commitInterfaceHashes() {
+	if c.incMutation == nil || c.incMutation.interfaceHash == nil {
+		return
+	}
+	for m := range c.iterateAllVariants() {
+		if m.interfaceChanged {
+			if h, ok := interfaceHashOf(m); ok {
+				c.incMutation.interfaceHash[moduleIdentity(m.cachedUniqueName, m.variant.name)] = h
+			}
+		}
+	}
+}
+
+// SnapshotPreMutationState captures the pre-mutation baseline of every module
+// group. It must be called after ParseFileList and before mutators run (i.e.
+// before ResolveDependencies), on the cold build, so the captured base modules
+// have not yet been split into variants or had their properties transformed.
+func (c *Context) SnapshotPreMutationState() error {
+	im := &incrementalMutation{baselines: make(map[string]*residentBaseline, len(c.moduleGroups))}
+	for _, group := range c.moduleGroups {
+		if len(group.modules) != 1 {
+			return fmt.Errorf("SnapshotPreMutationState: group %q has %d modules; must be called before mutators run", group.name, len(group.modules))
+		}
+		base := group.modules[0]
+		logic, props := c.cloneLogicModule(base)
+		hash, err := proptools.CalculateHashTolerant(base.properties)
+		if err != nil {
+			return fmt.Errorf("SnapshotPreMutationState: hashing %q: %w", group.name, err)
+		}
+		im.baselines[group.name] = &residentBaseline{
+			typeName:          base.typeName,
+			factory:           base.factory,
+			relBlueprintsFile: base.relBlueprintsFile,
+			pos:               base.pos,
+			propertyPos:       base.propertyPos,
+			logicModule:       logic,
+			properties:        props,
+			parsedHash:        hash,
+			generated:         base.createdBy != nil,
+		}
+	}
+	c.incMutation = im
+	im.fileHashes = c.blueprintFileHashes()
+	return nil
+}
+
+// instantiateBaseline builds a fresh pre-mutation base moduleInfo from a
+// baseline, attached to the given (already-registered) group. The logicModule
+// and properties are re-cloned so the returned module is independent of the
+// stored baseline and of any previous instantiation.
+func (c *Context) instantiateBaseline(bl *residentBaseline, group *moduleGroup) *moduleInfo {
+	newLogic, newProps := bl.factory()
+	if len(newProps) != len(bl.properties) {
+		panic(fmt.Errorf("instantiateBaseline: property count mismatch for %q", group.name))
+	}
+	for i := range newProps {
+		proptools.CopyProperties(reflect.ValueOf(newProps[i]), reflect.ValueOf(bl.properties[i]))
+	}
+	m := &moduleInfo{
+		logicModule:       newLogic,
+		factory:           bl.factory,
+		typeName:          bl.typeName,
+		relBlueprintsFile: bl.relBlueprintsFile,
+		pos:               bl.pos,
+		propertyPos:       bl.propertyPos,
+		properties:        newProps,
+		group:             group,
+		startedMutator:    -1,
+		finishedMutator:   -1,
+	}
+	newLogic.setInfo(m)
+	return m
+}
+
+// SetBaselineProperties replaces the stored baseline properties for a module
+// (simulating a re-parse of its Android.bp). The properties slice must match the
+// module factory's shape. Used by the re-parse front-end and by tests.
+func (c *Context) SetBaselineProperties(name string, properties []interface{}) error {
+	if c.incMutation == nil {
+		return fmt.Errorf("SetBaselineProperties: no resident baseline; call SnapshotPreMutationState first")
+	}
+	bl, ok := c.incMutation.baselines[name]
+	if !ok {
+		return fmt.Errorf("SetBaselineProperties: unknown module %q", name)
+	}
+	if len(properties) != len(bl.properties) {
+		return fmt.Errorf("SetBaselineProperties: property count mismatch for %q", name)
+	}
+	hash, err := proptools.CalculateHashTolerant(properties)
+	if err != nil {
+		return err
+	}
+	bl.properties = properties
+	bl.parsedHash = hash
+	return nil
+}
+
+// scratchBase builds a throwaway base module carrying the given parsed properties,
+// not attached to the live graph's module list. Used to run structural decisions
+// (Split) without mutating the live graph.
+func (c *Context) scratchBase(bl *residentBaseline, props []interface{}, group *moduleGroup) *moduleInfo {
+	newLogic, newProps := bl.factory()
+	for i := range newProps {
+		proptools.CopyProperties(reflect.ValueOf(newProps[i]), reflect.ValueOf(props[i]))
+	}
+	scratch := &moduleInfo{
+		logicModule:       newLogic,
+		factory:           bl.factory,
+		typeName:          bl.typeName,
+		relBlueprintsFile: bl.relBlueprintsFile,
+		pos:               bl.pos,
+		propertyPos:       bl.propertyPos,
+		properties:        newProps,
+		group:             group,
+		startedMutator:    -1,
+		finishedMutator:   -1,
+	}
+	newLogic.setInfo(scratch)
+	return scratch
+}
+
+// scratchSplits computes the top-level transition Split variations that the given
+// parsed properties would produce (one entry per transition mutator), by running
+// each transition mutator's Split on a throwaway base. Used by the structure-
+// neutrality gate: an edit is variant-structure-neutral iff every transition's
+// Split is unchanged. (Only the structure matters; dependency edits are handled
+// by the in-place re-derive re-running the dependency mutators per variant.)
+func (c *Context) scratchSplits(config interface{}, bl *residentBaseline, props []interface{}, group *moduleGroup) map[string][]string {
+	scratch := c.scratchBase(bl, props, group)
+	splits := map[string][]string{}
+	for _, mi := range c.mutatorInfo {
+		if mi.transitionMutator == nil {
+			continue
+		}
+		mctx := &mutatorContext{
+			baseModuleContext: baseModuleContext{context: c, config: config, module: scratch},
+			mutator:           mi,
+			pauseFunc:         func(*moduleInfo) {},
+		}
+		var vars []string
+		func() {
+			defer func() { recover() }()
+			for _, ti := range mi.transitionMutator.mutator.Split(mctx) {
+				vars = append(vars, ti.Variation())
+			}
+		}()
+		splits[mi.name] = vars
+	}
+	return splits
+}
+
+// targetVariant is one variant the transition pipeline would produce: its full
+// variation map (across all transition dimensions), the variant name, and the
+// per-dimension TransitionInfo.
+type targetVariant struct {
+	name            string
+	variations      variationMap
+	transitionInfos []TransitionInfo
+}
+
+// variationKey is a stable identity for a variation map (order-independent), used
+// to match target variants against existing ones.
+func variationKey(vm variationMap) string {
+	keys := make([]string, 0, len(vm.variations))
+	for k := range vm.variations {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	var b strings.Builder
+	for _, k := range keys {
+		b.WriteString(k)
+		b.WriteByte('=')
+		b.WriteString(vm.variations[k])
+		b.WriteByte(';')
+	}
+	return b.String()
+}
+
+// enumerateTargetVariants computes the full set of variants the transition
+// pipeline would produce for the given parsed properties, by running each
+// transition mutator's Split NESTED over the partial combos built so far (Split is
+// module-local and needs no resolved deps, so this is safe on a scratch base and
+// sidesteps the deps-ordering wall). It mirrors the framework's own variant
+// creation: a Split of [""] does not add a dimension or extend the name (the
+// "not split" path), while any other Split extends each combo, setting the
+// variation in the map and appending non-empty variations to the name -- exactly
+// as createVariations + newVariant do. The result is the multi-dimensional combo
+// set (arch x os x ...).
+func (c *Context) enumerateTargetVariants(config interface{}, bl *residentBaseline, props []interface{}, group *moduleGroup) []targetVariant {
+	scratch := c.scratchBase(bl, props, group)
+	cur := []targetVariant{{
+		name:            "",
+		variations:      variationMap{variations: map[string]string{}},
+		transitionInfos: make([]TransitionInfo, len(c.transitionMutators)),
+	}}
+	for _, mi := range c.mutatorInfo {
+		if mi.transitionMutator == nil {
+			continue
+		}
+		var next []targetVariant
+		for _, tv := range cur {
+			// Present the partial combo to Split so transition-dependent splits see it.
+			scratch.variant = variant{name: tv.name, variations: tv.variations}
+			scratch.transitionInfos = tv.transitionInfos
+			mctx := &mutatorContext{
+				baseModuleContext: baseModuleContext{context: c, config: config, module: scratch},
+				mutator:           mi,
+				pauseFunc:         func(*moduleInfo) {},
+			}
+			var splits []TransitionInfo
+			func() {
+				defer func() { recover() }()
+				splits = mi.transitionMutator.mutator.Split(mctx)
+			}()
+			if len(splits) == 1 && splits[0].Variation() == "" {
+				// Not split: keep the combo, but record the transition info.
+				tis := append([]TransitionInfo(nil), tv.transitionInfos...)
+				tis[mi.transitionMutator.index] = splits[0]
+				next = append(next, targetVariant{tv.name, tv.variations, tis})
+				continue
+			}
+			for _, ti := range splits {
+				v := ti.Variation()
+				nv := tv.variations.clone()
+				nv.set(mi.name, v)
+				tis := append([]TransitionInfo(nil), tv.transitionInfos...)
+				tis[mi.transitionMutator.index] = ti
+				name := tv.name
+				if v != "" {
+					if name == "" {
+						name = v
+					} else {
+						name = name + "_" + v
+					}
+				}
+				next = append(next, targetVariant{name, nv, tis})
+			}
+		}
+		cur = next
+	}
+	return cur
+}
+
+// IsStructureNeutral reports whether re-parsing module `name` with `reparsedProps`
+// leaves its VARIANT structure unchanged -- the same transition Split variations
+// as its current (baseline) definition. A module's variant set is Split(self) plus
+// the variations its (unedited) dependents request, so for an edit to `name` only
+// Split(self) can change. When true, the in-place re-derive is sound (it keeps the
+// variant set and re-runs every per-variant mutator, including the dependency
+// mutators, so property AND dependency edits are handled). When false, the edit
+// changes the variant set and needs a full rebuild.
+func (c *Context) IsStructureNeutral(config interface{}, name string, reparsedProps []interface{}) (bool, error) {
+	if c.incMutation == nil {
+		return false, fmt.Errorf("IsStructureNeutral: no resident baseline")
+	}
+	bl := c.incMutation.baselines[name]
+	group := c.moduleGroupFromName(name, nil)
+	if bl == nil || group == nil {
+		return false, nil // unknown/added module: not neutral, force full rebuild
+	}
+	if len(reparsedProps) != len(bl.properties) {
+		return false, nil
+	}
+	oldSplits := c.scratchSplits(config, bl, bl.properties, group)
+	newSplits := c.scratchSplits(config, bl, reparsedProps, group)
+	return splitsEqual(oldSplits, newSplits), nil
+}
+
+func splitsEqual(a, b map[string][]string) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for k, av := range a {
+		if !stringsEqual(av, b[k]) {
+			return false
+		}
+	}
+	return true
+}
+
+func stringsEqual(a, b []string) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for i := range a {
+		if a[i] != b[i] {
+			return false
+		}
+	}
+	return true
+}
+
+// errUnsupportedMutator is returned by ReMutateModules when the mutator pipeline
+// contains a mutator class not yet handled incrementally (e.g. a transition
+// mutator). The caller should fall back to a full RunBlueprint, which is always
+// correct.
+var errUnsupportedMutator = fmt.Errorf("incremental re-mutation: unsupported mutator in pipeline")
+
+// errStructuralChange is returned by ReMutate when an edit changes a module's
+// structure (its transition Split variations or its dependency edges) in a
+// pipeline that uses transition mutators, which the incremental path does not yet
+// handle. The caller should fall back to a full RunBlueprint.
+var errStructuralChange = fmt.Errorf("incremental re-mutation: structural change requires full rebuild")
+
+// ErrFallbackToFullBuild reports whether an error returned by ReMutate means the
+// edit could not be handled incrementally and the caller should do a full
+// RunBlueprint (always correct). Both conditions are normal, not failures.
+func ErrFallbackToFullBuild(err error) bool {
+	return err == errUnsupportedMutator || err == errStructuralChange
+}
+
+// DiffParsedModules compares a freshly re-parsed context (the same source tree
+// re-parsed after an edit, before mutators run) against this resident context's
+// baselines, and returns: the changed modules' new parsed properties (keyed by
+// name), the names of added modules, and the names of removed modules. The
+// caller drives a warm rebuild from this: added/removed modules require a full
+// RunBlueprint; otherwise the changed map feeds ReMutate.
+//
+// Comparison is by a hash of the parsed (pre-mutation) properties, which is the
+// ground-truth signal that a module's definition changed; comment/whitespace
+// edits produce no entries.
+func (c *Context) DiffParsedModules(reparsed *Context) (changed map[string][]interface{}, added, removed []string, err error) {
+	if c.incMutation == nil {
+		return nil, nil, nil, fmt.Errorf("DiffParsedModules: no resident baseline")
+	}
+	changed = map[string][]interface{}{}
+
+	// A module's identity for incremental diffing is its CONTENT -- the Blueprints
+	// file it is defined in, its type, and its parsed properties -- not its Name().
+	// Some module types name themselves non-deterministically (e.g.
+	// soong_config_module_type_import's Name() embeds fmt.Sprintf("%p", m)), so the
+	// same logical module gets a different name in the cold parse and the warm
+	// re-parse. Matching purely by name would report every such module as both
+	// removed and added on every build, forcing a needless full rebuild. So we match
+	// by name first (the common, stable case) and reconcile the leftovers by content.
+	contentKey := func(file, typeName string, h uint64) string {
+		return file + "\x00" + typeName + "\x00" + strconv.FormatUint(h, 16)
+	}
+
+	// File-scoped diff. A module can only have changed/appeared/disappeared if its
+	// defining .bp file changed on disk. Re-hash the files and restrict the diff to
+	// modules in changed files; modules in unchanged files are unchanged by
+	// definition, so any re-parse non-determinism in them (volatile names, value
+	// jitter from soong_config conditionals, etc.) is ignored. If fileHashes was not
+	// captured (older snapshot), fall back to diffing everything.
+	fileChanged := func(rel string) bool { return true }
+	if c.incMutation.fileHashes != nil {
+		memo := make(map[string]bool)
+		fileChanged = func(rel string) bool {
+			if rel == "" {
+				return true // unknown origin -- be conservative
+			}
+			if ch, done := memo[rel]; done {
+				return ch
+			}
+			// Hash the current on-disk file (fall back to the re-parse fs for tests)
+			// and compare against the cold snapshot's hash.
+			h, ok := c.hashBlueprintFile(rel, reparsed.fs)
+			old, had := c.incMutation.fileHashes[rel]
+			ch := !ok || !had || h != old
+			memo[rel] = ch
+			return ch
+		}
+	}
+
+	// Duplicate bare names: soong allows the same module name in different namespaces
+	// (e.g. per-device "wpa_supplicant.conf"). The baselines map is keyed by bare
+	// name, so duplicates collide and cannot be diffed reliably by name. Identify
+	// them up front: exclude them from the diff when their file is unchanged (they
+	// cannot have changed), and force a full rebuild if a duplicate-named module is
+	// in a changed file (we cannot tell which instance the edit touched).
+	nameCount := make(map[string]int, len(reparsed.moduleGroups))
+	for _, group := range reparsed.moduleGroups {
+		nameCount[group.name]++
+	}
+	dupName := func(n string) bool { return nameCount[n] > 1 }
+
+	type rpModule struct {
+		name string
+		mod  *moduleInfo
+		hash uint64
+	}
+	reByName := make(map[string]*rpModule, len(reparsed.moduleGroups))
+	reByContent := make(map[string][]*rpModule, len(reparsed.moduleGroups))
+	for _, group := range reparsed.moduleGroups {
+		if len(group.modules) != 1 {
+			return nil, nil, nil, fmt.Errorf("DiffParsedModules: reparsed group %q has %d modules; pass a pre-mutation context", group.name, len(group.modules))
+		}
+		m := group.modules[0]
+		// Modules created by another module's load hook (CreateModule) follow their
+		// creator and are not directly editable; skip them so a re-parse that doesn't
+		// recreate them identically does not look like a structural change.
+		if m.createdBy != nil {
+			continue
+		}
+		// Only modules in changed files can differ; skip the rest.
+		if !fileChanged(m.relBlueprintsFile) {
+			continue
+		}
+		if dupName(group.name) {
+			// Ambiguous bare name in a changed file -- fall back to a full rebuild.
+			return nil, nil, nil, fmt.Errorf("DiffParsedModules: duplicate module name %q in changed file %q; full rebuild required", group.name, m.relBlueprintsFile)
+		}
+		h, herr := proptools.CalculateHashTolerant(m.properties)
+		if herr != nil {
+			return nil, nil, nil, herr
+		}
+		rp := &rpModule{name: group.name, mod: m, hash: h}
+		reByName[group.name] = rp
+		ck := contentKey(m.relBlueprintsFile, m.typeName, h)
+		reByContent[ck] = append(reByContent[ck], rp)
+	}
+
+	matchedBaseline := make(map[string]bool, len(c.incMutation.baselines))
+	usedRe := make(map[*rpModule]bool, len(reByName))
+
+	// updatePos refreshes a matched resident module group's source position from the
+	// re-parse. An edit that adds/removes lines shifts the line numbers of every
+	// later module in the same file; their content (and build actions) are unchanged
+	// but the emitted "# Defined: file:line" comment moves. Update the position and,
+	// for content-unchanged modules, record them so the delta write re-serializes
+	// them (wasRegenerated). Only fires for modules in changed files (reByName is
+	// already restricted to those).
+	updatePos := func(name string, newPos scanner.Position) {
+		rg := c.moduleGroupFromName(name, nil)
+		if rg == nil || len(rg.modules) == 0 {
+			return
+		}
+		cur := rg.modules[0].pos
+		if cur.Line == newPos.Line && cur.Column == newPos.Column && cur.Filename == newPos.Filename {
+			return
+		}
+		for _, v := range rg.modules {
+			v.pos = newPos
+			c.posShiftedModules[v] = true
+		}
+	}
+
+	// Pass 1: match by name. A name present in both is the same module; record it as
+	// changed iff its property hash differs.
+	for name, bl := range c.incMutation.baselines {
+		rp := reByName[name]
+		if rp == nil {
+			continue
+		}
+		matchedBaseline[name] = true
+		usedRe[rp] = true
+		updatePos(name, rp.mod.pos)
+		if rp.hash != bl.parsedHash {
+			// A .bp value edit changes property values, never the NUMBER of property
+			// structs (that is fixed by the module type: factory + soong_config
+			// conditionals + load hooks). So a differing struct count is re-parse
+			// non-determinism (e.g. a soong_config module type's conditional property
+			// set evaluated differently in the throwaway re-parse), not a real edit.
+			// Keep the resident graph's authoritative version rather than mis-flag it
+			// as changed (which would also fail SetBaselineProperties' count check).
+			if len(rp.mod.properties) != len(bl.properties) {
+				continue
+			}
+			changed[name] = rp.mod.properties
+		}
+	}
+
+	// Pass 2: reconcile leftovers by content. An unmatched baseline that has a
+	// content-identical unmatched re-parse module is the same module under a volatile
+	// name -- unchanged, not removed/added.
+	for name, bl := range c.incMutation.baselines {
+		if matchedBaseline[name] || bl.generated || !fileChanged(bl.relBlueprintsFile) {
+			continue
+		}
+		ck := contentKey(bl.relBlueprintsFile, bl.typeName, bl.parsedHash)
+		for _, rp := range reByContent[ck] {
+			if usedRe[rp] {
+				continue
+			}
+			matchedBaseline[name] = true
+			usedRe[rp] = true
+			updatePos(name, rp.mod.pos)
+			break
+		}
+	}
+
+	for name, bl := range c.incMutation.baselines {
+		if matchedBaseline[name] || bl.generated || !fileChanged(bl.relBlueprintsFile) {
+			continue
+		}
+		removed = append(removed, name)
+	}
+	for name, rp := range reByName {
+		if !usedRe[rp] {
+			added = append(added, name)
+		}
+	}
+	sort.Strings(added)
+	sort.Strings(removed)
+	return changed, added, removed, nil
+}
+
+// IncrementalAddModules adds brand-new modules to the resident graph from a
+// freshly re-parsed context, without a full rebuild. For each added name it clones
+// the re-parsed base module into the live context, registers it (addModule, which
+// also records a baseline), computes its transition Split, creates its variants
+// directly with their variations (so their deps resolve on the post-split graph),
+// and re-derives each variant's per-variant state. Single-transition only; an
+// added module with multiple transition mutators, or whose dependency lacks a
+// matching variant, returns errStructuralChange so the caller falls back.
+//
+// Modules that depend on a newly added module are handled separately: they appear
+// in the changed set (their parsed deps changed) and are re-mutated by ReMutate,
+// which resolves the now-present new module.
+func (c *Context) IncrementalAddModules(config interface{}, reparsed *Context, addedNames []string) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("IncrementalAddModules: no resident baseline")}
+	}
+
+	dirty := map[*moduleInfo]bool{}
+	for _, name := range addedNames {
+		rg := reparsed.moduleGroupFromName(name, nil)
+		if rg == nil || len(rg.modules) != 1 {
+			return []error{errStructuralChange}
+		}
+		rbase := rg.modules[0]
+
+		// Clone the re-parsed base into a fresh live module and register it.
+		logic, props := c.cloneLogicModule(rbase)
+		base := &moduleInfo{
+			logicModule:       logic,
+			factory:           rbase.factory,
+			typeName:          rbase.typeName,
+			relBlueprintsFile: rbase.relBlueprintsFile,
+			pos:               rbase.pos,
+			propertyPos:       rbase.propertyPos,
+			properties:        props,
+			startedMutator:    -1,
+			finishedMutator:   -1,
+		}
+		logic.setInfo(base)
+		if aerrs := c.addModule(base); len(aerrs) > 0 {
+			return aerrs
+		}
+		group := base.group
+
+		// Record a baseline so future edits to this module are incremental too.
+		blLogic, blProps := c.cloneLogicModule(base)
+		h, herr := proptools.CalculateHashTolerant(base.properties)
+		if herr != nil {
+			return []error{herr}
+		}
+		c.incMutation.baselines[name] = &residentBaseline{
+			typeName:          base.typeName,
+			factory:           base.factory,
+			relBlueprintsFile: base.relBlueprintsFile,
+			pos:               base.pos,
+			propertyPos:       base.propertyPos,
+			logicModule:       blLogic,
+			properties:        blProps,
+			parsedHash:        h,
+		}
+
+		// Create the module's variants directly from the full nested-Split combo set
+		// (post-split, so deps resolve by variation), then re-derive each variant.
+		bl := c.incMutation.baselines[name]
+		targets := c.enumerateTargetVariants(config, bl, bl.properties, group)
+		if len(targets) > 0 {
+			var variants moduleList
+			for _, t := range targets {
+				variants = append(variants, c.cloneVariantFromTarget(base, t))
+			}
+			group.modules = variants
+		}
+		for _, m := range group.modules {
+			dirty[m] = true
+			c.incrementalAddedModules = append(c.incrementalAddedModules, m)
+		}
+	}
+
+	cgs := make([]changedGroup, 0, len(addedNames))
+	for _, name := range addedNames {
+		group := c.moduleGroupFromName(name, nil)
+		cgs = append(cgs, changedGroup{group, c.incMutation.baselines[name]})
+	}
+	rdDirty, revDeps, _, rerrs := c.reDeriveInPlace(config, cgs)
+	if len(rerrs) > 0 {
+		return rerrs
+	}
+	for m := range rdDirty {
+		dirty[m] = true
+	}
+	rd := map[*moduleInfo][]depInfo{}
+	for _, r := range revDeps {
+		rd[r.module] = append(rd[r.module], r.dep)
+	}
+	for module, deps := range rd {
+		sort.Sort(depSorter{deps, c.nameInterface})
+		module.directDeps = append(module.directDeps, deps...)
+	}
+	if errs = c.updateDependencies(); len(errs) > 0 {
+		return errs
+	}
+	for m := range dirty {
+		_, m.pristineProperties = c.cloneLogicModule(m)
+		m.pristineProviders = append([]interface{}(nil), m.providers...)
+		c.resetModuleBuildActions(m)
+	}
+	c.markDirty(dirty)
+	c.membershipChanged = true
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return nil
+}
+
+// ModuleRemover is the optional interface a NameInterface implements to support
+// incremental module removal. SimpleNameInterface implements it.
+type ModuleRemover interface {
+	RemoveModule(name string)
+}
+
+// IncrementalRemoveModules removes deleted modules from the resident graph without
+// a full rebuild: it drops each removed group from the module list, the name
+// interface, and the baselines, then rebuilds the dependency graph. It is safe
+// only when nothing outside the removed set still depends on a removed module
+// (otherwise the edit is part of a larger structural change); that case, a name
+// interface without RemoveModule, or a removed module that created other modules,
+// all return errStructuralChange so the caller falls back.
+func (c *Context) IncrementalRemoveModules(removedNames []string) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("IncrementalRemoveModules: no resident baseline")}
+	}
+	remover, ok := c.nameInterface.(ModuleRemover)
+	if !ok {
+		return []error{errStructuralChange}
+	}
+
+	removedGroups := map[*moduleGroup]bool{}
+	removedModules := map[*moduleInfo]bool{}
+	for _, name := range removedNames {
+		group := c.moduleGroupFromName(name, nil)
+		if group == nil {
+			return []error{errStructuralChange}
+		}
+		removedGroups[group] = true
+		for _, m := range group.modules {
+			removedModules[m] = true
+		}
+	}
+
+	// Refuse if a surviving module still depends on a removed one (that is a
+	// dangling reference a full build must diagnose, or part of a larger edit).
+	for m := range c.iterateAllVariants() {
+		if removedGroups[m.group] {
+			continue
+		}
+		for _, d := range m.directDeps {
+			if d.module != nil && removedModules[d.module] {
+				return []error{errStructuralChange}
+			}
+		}
+		if m.createdBy != nil && removedModules[m.createdBy] {
+			return []error{errStructuralChange}
+		}
+	}
+
+	// Drop the removed groups from the module list and the name interface.
+	var kept []*moduleGroup
+	for _, group := range c.moduleGroups {
+		if removedGroups[group] {
+			remover.RemoveModule(group.name)
+			continue
+		}
+		kept = append(kept, group)
+	}
+	c.moduleGroups = kept
+	c.cachedSortedModuleGroups = nil
+	for _, name := range removedNames {
+		delete(c.incMutation.baselines, name)
+	}
+
+	if errs = c.updateDependencies(); len(errs) > 0 {
+		return errs
+	}
+	// The removed modules are gone from the module set, so their ninja shards now look
+	// clean (no surviving module in them is dirty) and the delta write would skip them,
+	// leaving the deleted modules' stale text behind. Force-rewrite each removed
+	// module's shard, computed from its stable identity hash. The main and incremental
+	// shard sets use the same index space, so marking the index covers both.
+	if n := ninjaShardCount(); n > 0 {
+		if c.forcedDirtyShards == nil {
+			c.forcedDirtyShards = map[int]bool{}
+		}
+		for m := range removedModules {
+			c.forcedDirtyShards[stableShardIndex(m.cachedUniqueName, m.variant.name, n)] = true
+		}
+	}
+	// No surviving module is dirty from the removal itself (nothing regenerates), so
+	// don't add to the dirty set -- just ensure it is non-nil so generate uses the
+	// targeted (skip-clean) path. The manifest must drop the removed modules, so
+	// force the ninja write even though NinjaUnchanged would otherwise skip it.
+	c.markDirty(nil)
+	c.forceNinjaWrite = true
+	c.membershipChanged = true
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return nil
+}
+
+// BeginIncrementalBuild resets per-build incremental state before a warm rebuild
+// that may apply several incremental steps (remove, add, re-mutate). It clears the
+// dirty set and the force-write flag, and resets every module's interfaceChanged
+// flag so stale provider-propagation state from a previous build cannot leak. Each
+// incremental step then UNIONS its changes into the dirty set (markDirty).
+func (c *Context) BeginIncrementalBuild() {
+	c.dirtyModules = map[*moduleInfo]bool{}
+	c.forceNinjaWrite = false
+	c.membershipChanged = false
+	c.regeneratedModules = nil
+	c.posShiftedModules = map[*moduleInfo]bool{}
+	c.forcedDirtyShards = nil
+	c.incrementalAddedModules = nil
+	// Keep the previous full build's complete liveGlobals so package-variable
+	// naming (makeUniquePackageNames) is computed over the SAME package set as a
+	// cold build. Otherwise a warm targeted regenerate rebuilds liveGlobals from
+	// only the regenerated subset, sees fewer packages, misses a short-name
+	// collision, and emits e.g. "g.config" where cold emits
+	// "g.android.soong.java.config" -- a dangling variable reference that crashes
+	// n2. (MarkModulesDirty sets this on the non-resident path; the resident path
+	// goes through markDirty, which does not, so set it here.)
+	c.preserveLiveGlobals = true
+	for m := range c.iterateAllVariants() {
+		m.interfaceChanged = false
+	}
+}
+
+// markDirty unions the given modules into the build's dirty set, initializing it
+// if a step runs without BeginIncrementalBuild (e.g. a single-op unit test).
+func (c *Context) markDirty(dirty map[*moduleInfo]bool) {
+	if c.dirtyModules == nil {
+		c.dirtyModules = map[*moduleInfo]bool{}
+	}
+	for m := range dirty {
+		c.dirtyModules[m] = true
+	}
+}
+
+// ReMutate is the single entry point for an incremental warm rebuild. Given the
+// re-parsed properties of the edited modules (keyed by module name), it chooses
+// the correct strategy and applies it, leaving the changed variants in the
+// targeted-generate dirty set:
+//
+//   - No transition mutators in the pipeline: scoped re-mutation (ReMutateModules)
+//     re-runs the mutator pipeline over just the changed groups, which correctly
+//     handles property AND dependency edits.
+//   - Transition mutators present, edit is structure-neutral (same Split
+//     variations + same dep edges, checked by IsStructureNeutral before baselines
+//     are updated): the in-place property re-derive (ReMutateModulesInPlace).
+//   - Transition mutators present, edit is structural: errStructuralChange, so the
+//     caller falls back to a full RunBlueprint.
+//
+// Callers should treat ErrFallbackToFullBuild(err)==true as "do a full build",
+// not a failure.
+func (c *Context) ReMutate(config interface{}, reparsedPropsByName map[string][]interface{}) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("ReMutate: no resident baseline; call SnapshotPreMutationState first")}
+	}
+
+	changedNames := make([]string, 0, len(reparsedPropsByName))
+	for name := range reparsedPropsByName {
+		changedNames = append(changedNames, name)
+	}
+	sort.Strings(changedNames) // deterministic order
+
+	hasTransition := false
+	for _, mi := range c.mutatorInfo {
+		if mi.transitionMutator != nil || mi.transitionPropagateMutator != nil {
+			hasTransition = true
+			break
+		}
+	}
+
+	// Decide the transition strategy BEFORE updating the baselines (the neutrality
+	// gate and the faithfulness self-check compare the current baseline against the
+	// re-parsed properties / live graph).
+	structureNeutral := true
+	if hasTransition {
+		for _, name := range changedNames {
+			neutral, err := c.IsStructureNeutral(config, name, reparsedPropsByName[name])
+			if err != nil {
+				return []error{err}
+			}
+			if !neutral {
+				fmt.Fprintf(os.Stderr, "ReMutate: %s not structure-neutral\n", name)
+				structureNeutral = false
+				break
+			}
+		}
+		if structureNeutral {
+			// Self-verify that the in-place re-derive reproduces the live variants from
+			// the current baseline. With the full per-variant replay this holds by
+			// construction; if it ever does not (a mutator whose base/variant behavior
+			// differs), fall back rather than risk a wrong build.
+			cg, err := c.resolveChangedGroups(changedNames)
+			if err != nil {
+				return []error{err}
+			}
+			faithful, ferr := c.inPlaceFaithful(config, cg)
+			if ferr != nil {
+				return []error{ferr}
+			}
+			if !faithful {
+				return []error{errStructuralChange}
+			}
+		}
+	}
+
+	for _, name := range changedNames {
+		if err := c.SetBaselineProperties(name, reparsedPropsByName[name]); err != nil {
+			return []error{err}
+		}
+	}
+
+	// Apply the chosen strategy. If incremental re-mutation hits any error (e.g. an
+	// added dependency that cannot be resolved on the variantized graph -- a
+	// cascade), treat it as a fallback signal rather than a fatal error: the
+	// resident graph may be partially mutated, so the caller discards it and does a
+	// full RunBlueprint, which is authoritative and reports any genuine error.
+	var rerrs []error
+	switch {
+	case !hasTransition:
+		rerrs = c.ReMutateModules(config, changedNames)
+	case structureNeutral:
+		rerrs = c.ReMutateModulesInPlace(config, changedNames)
+	default:
+		// The edit changed a module's variant set: surgically add/remove variants.
+		rerrs = c.ReMutateModulesStructural(config, changedNames)
+	}
+	if len(rerrs) > 0 {
+		fmt.Fprintf(os.Stderr, "ReMutate: re-mutate strategy error -> fallback: %v\n", rerrs[0])
+		return []error{errStructuralChange}
+	}
+	return nil
+}
+
+// ReMutateModules re-runs the mutator pipeline scoped to the named changed
+// module groups, rebuilding their variants and transformed properties from the
+// resident baselines, then rebuilds the dependency graph. After it returns, the
+// re-mutated variants are marked dirty so a following PrepareBuildActions
+// regenerates only them (clean modules keep their build actions).
+//
+// It returns errUnsupportedMutator if the pipeline contains a mutator class this
+// stage does not handle, leaving the caller to fall back to a full build.
+func (c *Context) ReMutateModules(config interface{}, changedNames []string) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("ReMutateModules: no resident baseline; call SnapshotPreMutationState first")}
+	}
+
+	// Capability boundary. Scoped re-mutation is sound only for mutators that
+	// reach other modules purely through forward dependency edges and transform
+	// their own module's properties. Mutators that create variants (transition),
+	// create modules, rename/replace modules, add reverse dependencies, or mutate
+	// global state cannot be replayed on a subset without risking a corrupt graph,
+	// so their presence forces a correct full-build fallback (errUnsupportedMutator).
+	// This is a precise, conservative boundary: covered edits are byte-identical;
+	// everything else is correct (just not yet sub-second).
+	mutatorGroups := coalesceMutators(c.mutatorInfo)
+	for _, mg := range mutatorGroups {
+		for _, m := range mg {
+			if m.transitionMutator != nil || m.transitionPropagateMutator != nil ||
+				m.usesCreateModule || m.usesRename || m.usesReplaceDependencies ||
+				m.usesReverseDependencies || m.mutatesGlobalState {
+				return []error{errUnsupportedMutator}
+			}
+		}
+	}
+
+	// Reset each changed group to a fresh pre-mutation base carrying the current
+	// (re-parsed) baseline properties. Capture the old variants first so dependents
+	// can be repointed afterwards.
+	changedGroups := map[*moduleGroup]bool{}
+	oldByGroup := map[*moduleGroup]moduleList{}
+	dirty := map[*moduleInfo]bool{}
+	for _, name := range changedNames {
+		group := c.moduleGroupFromName(name, nil)
+		if group == nil {
+			return []error{fmt.Errorf("ReMutateModules: unknown module %q", name)}
+		}
+		bl := c.incMutation.baselines[name]
+		if bl == nil {
+			return []error{fmt.Errorf("ReMutateModules: no baseline for %q", name)}
+		}
+		oldByGroup[group] = group.modules
+		base := c.instantiateBaseline(bl, group)
+		group.modules = moduleList{base}
+		changedGroups[group] = true
+		dirty[base] = true
+	}
+
+	// Re-run the mutator pipeline scoped to the changed groups' modules.
+	for _, mg := range mutatorGroups {
+		if newErrs := c.runMutatorScoped(config, mg, bottomUpMutator, changedGroups, dirty); len(newErrs) > 0 {
+			return newErrs
+		}
+	}
+
+	// Repoint clean dependents at the freshly created variants (matched by variant
+	// name), then rebuild the whole reverse/forward dep graph.
+	replacedBy := map[*moduleInfo]*moduleInfo{}
+	for group, olds := range oldByGroup {
+		for _, old := range olds {
+			if nw := group.moduleByVariantName(old.variant.name); nw != nil {
+				replacedBy[old] = nw
+			}
+		}
+	}
+	if len(replacedBy) > 0 {
+		for m := range c.iterateAllVariants() {
+			for i := range m.directDeps {
+				if nw, ok := replacedBy[m.directDeps[i].module]; ok {
+					m.directDeps[i].module = nw
+				}
+			}
+		}
+	}
+	if errs = c.updateDependencies(); len(errs) > 0 {
+		return errs
+	}
+
+	// Give the new variants the pre-generate pristine snapshot the resident
+	// generate path expects, then hand them to the targeted-generate dirty set.
+	for m := range dirty {
+		_, m.pristineProperties = c.cloneLogicModule(m)
+		m.pristineProviders = append([]interface{}(nil), m.providers...)
+		c.resetModuleBuildActions(m)
+	}
+	c.markDirty(dirty)
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return nil
+}
+
+// coalescablePropertyMutator reports whether a mutator is a pure property
+// transform that can be safely re-run on an existing variant in place: it runs
+// bottom-up, is not a transition (structure) mutator, and does not create
+// modules, rename/replace, add reverse deps, mutate global state, or mutate
+// dependencies. This is the same predicate coalesceMutators uses to decide a
+// mutator can be reordered, which exactly characterizes "reads + transforms its
+// own module's properties (and reads deps) with no structural side effects".
+func coalescablePropertyMutator(m *mutatorInfo) bool {
+	return m.bottomUpMutator != nil &&
+		m.transitionMutator == nil &&
+		m.transitionPropagateMutator == nil &&
+		!m.usesCreateModule &&
+		!m.usesReplaceDependencies &&
+		!m.usesReverseDependencies &&
+		!m.usesRename &&
+		!m.mutatesGlobalState &&
+		!m.mutatesDependencies
+}
+
+// ReMutateModulesInPlace recomputes the transformed properties of the named
+// modules' EXISTING variants without replaying structure. It is the fast path for
+// a structure-neutral edit (cflags/srcs/exported value) to a transition-
+// variantized module (arch/os/apex): the variant set and dependency edges are
+// unchanged, so only the per-variant property transforms need redoing.
+//
+// For each existing variant it resets the properties to the re-parsed baseline,
+// then re-runs every coalescable property-transform mutator (including the
+// transition `name_mutate` phase, which re-applies the arch/os property merge
+// using the variant's retained transitionInfos) in pipeline order. Structural
+// mutators (Split/createVariations), dependency mutators, and reverse-dep/
+// global-state mutators are skipped because their outputs are unchanged. The
+// re-derived variants are handed to the targeted-generate dirty set, and
+// provider-change propagation regenerates affected dependents.
+//
+// SOUNDNESS CONTRACT: the caller must guarantee the edit is structure-neutral
+// (it does not change Split output, transition decisions, or dependency edges).
+// The resident re-parse front-end is responsible for that gate (compare the
+// edited module's structural properties + Split output against the baseline; fall
+// back to a full RunBlueprint otherwise). See docs §9.4.
+type changedGroup struct {
+	group *moduleGroup
+	bl    *residentBaseline
+}
+
+// resolveChangedGroups looks up the changed module groups and their baselines.
+func (c *Context) resolveChangedGroups(changedNames []string) ([]changedGroup, error) {
+	var out []changedGroup
+	for _, name := range changedNames {
+		group := c.moduleGroupFromName(name, nil)
+		if group == nil {
+			return nil, fmt.Errorf("unknown module %q", name)
+		}
+		bl := c.incMutation.baselines[name]
+		if bl == nil {
+			return nil, fmt.Errorf("no baseline for %q", name)
+		}
+		out = append(out, changedGroup{group, bl})
+	}
+	return out, nil
+}
+
+// reDeriveInPlace recomputes a structure-neutral edit's effect on the EXISTING
+// variants of the changed groups, without re-splitting. It resets each variant to
+// its baseline properties, clears its direct dependencies, and re-runs the full
+// bottom-up mutator pipeline -- EXCEPT the transition structure mutators (Split /
+// createVariations) -- over the existing variants in pipeline order. This works
+// even on the already-variantized graph because dependency resolution on a
+// variant matches by the variant's own variations (unlike a pre-split base), and
+// it captures EVERY mutator's contribution (coalescable or not: arch property
+// merge, sanitizer/lto flags + their deps, etc.), so there is no contribution
+// loss. The variant objects are reused, so dependents need no repointing.
+//
+// Returns the re-derived variants, the reverse-dependencies the mutators added,
+// and whether any direct-dependency edge actually changed (so the caller can skip
+// the O(tree) updateDependencies when it didn't -- the common property-edit case).
+// An error means a re-run mutator changed structure (created a variant/module),
+// i.e. the edit was not actually structure-neutral.
+func (c *Context) reDeriveInPlace(config interface{}, changedGroups []changedGroup) (map[*moduleInfo]bool, []reverseDep, bool, []error) {
+	// Mutators re-run in-place are the non-transition bottom-up ones (the transition
+	// STRUCTURE mutators -- Split propagate + createVariations -- are skipped; we keep
+	// the existing variant set and only recompute per-variant mutation). Providers
+	// set by these mutators must be cleared before the replay so SetProvider does not
+	// hit the write-once double-set guard; providers set by transition mutators or by
+	// generate are kept.
+	rerun := map[string]bool{}
+	for _, m := range c.mutatorInfo {
+		if m.bottomUpMutator != nil && m.transitionMutator == nil {
+			rerun[m.name] = true
+		}
+	}
+	clearProvider := make([]bool, len(providerRegistry))
+	for i := range providerRegistry {
+		if rerun[providerRegistry[i].mutator] {
+			clearProvider[i] = true
+		}
+	}
+	lastMutatorIndex := -1
+	if n := len(c.mutatorInfo); n > 0 {
+		lastMutatorIndex = c.mutatorInfo[n-1].index
+	}
+
+	dirty := map[*moduleInfo]bool{}
+	oldDeps := map[*moduleInfo][]depInfo{}
+	oldForward := map[*moduleInfo][]*moduleInfo{}
+	for _, cg := range changedGroups {
+		for _, v := range cg.group.modules {
+			oldDeps[v] = append([]depInfo(nil), v.directDeps...)         // snapshot to detect dep changes
+			oldForward[v] = append([]*moduleInfo(nil), v.forwardDeps...) // snapshot to restore when deps are unchanged
+			c.resetVariantToBaseline(v, cg.bl)
+			// Clear providers set by the mutators we are about to replay so they can be
+			// re-set, and rewind this variant's mutator phase to pre-mutation.
+			for i := range v.providers {
+				if i < len(clearProvider) && clearProvider[i] {
+					v.providers[i] = nil
+					if i < len(v.providerInitialValueHashes) {
+						v.providerInitialValueHashes[i] = 0
+					}
+				}
+			}
+			v.startedMutator = -1
+			v.finishedMutator = -1
+			v.directDeps = v.directDeps[:0] // re-added by the dependency mutators below
+			dirty[v] = true
+		}
+	}
+
+	// Re-run the mutators in dependency order (a variant's changed deps before the
+	// variant itself), mirroring the cold build's bottom-up order, so a mutator that
+	// reads another changed variant's provider sees it already set/finished. Order by
+	// the snapshotted pre-edit deps (oldDeps); a structure-neutral edit keeps the dep
+	// structure, so this order is valid for the replay.
+	changedSet := map[*moduleInfo]bool{}
+	for _, cg := range changedGroups {
+		for _, v := range cg.group.modules {
+			changedSet[v] = true
+		}
+	}
+	var orderedVariants []*moduleInfo
+	visited := map[*moduleInfo]bool{}
+	var visit func(v *moduleInfo)
+	visit = func(v *moduleInfo) {
+		if visited[v] {
+			return
+		}
+		visited[v] = true
+		for _, d := range oldDeps[v] {
+			if d.module != nil && changedSet[d.module] {
+				visit(d.module)
+			}
+		}
+		orderedVariants = append(orderedVariants, v)
+	}
+	for _, cg := range changedGroups {
+		for _, v := range cg.group.modules {
+			visit(v)
+		}
+	}
+
+	var allReverseDeps []reverseDep
+	for _, m := range c.mutatorInfo {
+		// Skip the transition STRUCTURE mutators: the top-down propagate (Split) and
+		// the bottom-up createVariations. We keep the existing variant structure and
+		// only recompute per-variant mutation. The transition name_mutate phase is a
+		// plain bottom-up mutator (transitionMutator==nil) and IS re-run below.
+		if m.bottomUpMutator == nil || m.transitionMutator != nil {
+			continue
+		}
+		// A provider scoped to m may be (re)set while m runs. The global
+		// finishedMutators[m] is true (set by the cold build), which would make the
+		// provider system reject the SetProvider; clear it for the duration of the
+		// replay. Unchanged modules are still covered by their per-module
+		// finishedMutator (left at the cold final index), so their provider reads work.
+		savedFinished := c.finishedMutators[m.index]
+		c.finishedMutators[m.index] = false
+		group := []*mutatorInfo{m}
+		for _, v := range orderedVariants {
+			// Put the variant "inside" m: started m, not yet finished m, so
+			// SetProvider for m's providers is allowed.
+			v.startedMutator = m.index
+			v.finishedMutator = m.index - 1
+			mctx := &mutatorContext{
+				baseModuleContext: baseModuleContext{context: c, config: config, module: v},
+				mutator:           m,
+				pauseFunc:         func(*moduleInfo) {},
+			}
+			var perr []error
+			func() {
+				defer func() {
+					if r := recover(); r != nil {
+						perr = append(perr, newPanicErrorf(r, fmt.Sprintf("in-place %q for %s", m.name, v)))
+					}
+				}()
+				bottomUpMutator.run(group, mctx)
+			}()
+			v.finishedMutator = m.index // m is now done for this variant
+			if len(perr) > 0 {
+				c.finishedMutators[m.index] = savedFinished
+				return nil, nil, false, perr
+			}
+			if len(mctx.errs) > 0 {
+				c.finishedMutators[m.index] = savedFinished
+				return nil, nil, false, mctx.errs
+			}
+			// Re-running must not create new structure (a structure-neutral edit
+			// keeps the variant set); if it did, the edit is structural -- error so
+			// the caller handles it correctly rather than corrupt the graph.
+			if v.splitModules != nil || len(mctx.newModules) > 0 {
+				c.finishedMutators[m.index] = savedFinished
+				return nil, nil, false, []error{fmt.Errorf("reDeriveInPlace: mutator %q changed structure for %s", m.name, v)}
+			}
+			allReverseDeps = append(allReverseDeps, mctx.reverseDeps...)
+		}
+		c.finishedMutators[m.index] = savedFinished
+	}
+	// Mark the re-derived variants fully mutated so generate (and post-generate
+	// provider reads) treat them as past every mutator, matching cold modules.
+	for _, v := range orderedVariants {
+		v.startedMutator = lastMutatorIndex
+		v.finishedMutator = lastMutatorIndex
+	}
+
+	// Detect whether any direct-dependency edge changed. If not (and no reverse
+	// deps were added), the dependency graph is identical, so the caller can skip
+	// the O(tree) updateDependencies -- the common property-edit fast path.
+	depsChanged := len(allReverseDeps) > 0
+	if !depsChanged {
+		for _, cg := range changedGroups {
+			for _, v := range cg.group.modules {
+				if !depInfosEqual(oldDeps[v], v.directDeps) {
+					depsChanged = true
+					break
+				}
+			}
+			if depsChanged {
+				break
+			}
+		}
+	}
+
+	if !depsChanged {
+		// Deps are identical, but AddDependency re-appended the re-resolved deps to
+		// forwardDeps (and left transient newDirectDeps), so forwardDeps is now
+		// doubled. Restore the exact pre-edit forwardDeps. reverseDeps was never
+		// touched (AddDependency only writes the source module's forward/direct deps),
+		// so the whole dep graph is now identical to before -- the caller can skip the
+		// O(tree) updateDependencies entirely.
+		for _, cg := range changedGroups {
+			for _, v := range cg.group.modules {
+				v.forwardDeps = oldForward[v]
+				v.newDirectDeps = nil
+			}
+		}
+	}
+	return dirty, allReverseDeps, depsChanged, nil
+}
+
+// depInfosEqual reports whether two direct-dependency lists are identical (same
+// dep module objects and tags, in order).
+func depInfosEqual(a, b []depInfo) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for i := range a {
+		if a[i].module != b[i].module || a[i].tag != b[i].tag {
+			return false
+		}
+	}
+	return true
+}
+
+// inPlaceFaithful self-verifies that the in-place re-derive captures ALL of a
+// pipeline's property contributions for the changed modules. It re-derives the
+// changed variants from their CURRENT (unedited) baselines and checks the result
+// matches the live post-mutation properties exactly. If a pipeline has
+// non-coalescable mutators that also contribute properties (e.g. sanitizer/lto in
+// real Soong), the re-derive will not match and this returns false, so the caller
+// falls back to a full rebuild. Must be called before the baselines are updated.
+//
+// Side effect: on success the changed variants are left re-derived-from-baseline,
+// which equals their pre-edit state (verified equal); the caller then applies the
+// edit and re-derives again. On failure the caller falls back (the graph is
+// discarded), so the partially re-derived state does not matter.
+func (c *Context) inPlaceFaithful(config interface{}, changedGroups []changedGroup) (bool, error) {
+	// Compare the re-derive against the POST-MUTATE pristine snapshot, NOT the live
+	// (post-generate) properties. Live properties carry generate-time additions
+	// (e.g. license Effective_* fields applied to every module, even a filegroup)
+	// that the mutate-only re-derive can never reproduce -- comparing against them
+	// made every real module edit fall back. Comparing against pristineProperties
+	// asks the right question: does re-running the mutator pipeline reproduce the
+	// cold build's post-mutate state?
+	want := map[*moduleInfo]uint64{}
+	for _, cg := range changedGroups {
+		for _, v := range cg.group.modules {
+			if v.pristineProperties == nil {
+				return false, nil // no post-mutate snapshot -> can't prove -> fall back
+			}
+			h, err := proptools.CalculateHashTolerant(v.pristineProperties)
+			if err != nil {
+				return false, err
+			}
+			want[v] = h
+		}
+	}
+	if _, _, _, errs := c.reDeriveInPlace(config, changedGroups); len(errs) > 0 {
+		fmt.Fprintf(os.Stderr, "inPlaceFaithful: re-derive error -> fallback: %v\n", errs[0])
+		return false, nil // a structural side effect during re-derive => not faithful
+	}
+	for v, h := range want {
+		nh, err := proptools.CalculateHashTolerant(v.properties)
+		if err != nil {
+			return false, err
+		}
+		if nh != h {
+			fmt.Fprintf(os.Stderr, "inPlaceFaithful: post-mutate mismatch for %s -> fallback\n", v.Name())
+			return false, nil // re-derive did not reproduce the post-mutate snapshot
+		}
+	}
+	return true, nil
+}
+
+// cloneVariantWithVariation builds a new variant of template's group carrying the
+// single-transition variation nv: a fresh logicModule + properties, the variant
+// identity set to {T: nv}, the transition info derived from nv, and empty deps
+// (the per-variant pipeline re-resolves them). Used by variant-set surgery to add
+// a variant on the post-split graph without re-splitting from the base.
+func (c *Context) cloneVariantFromTarget(template *moduleInfo, tv targetVariant) *moduleInfo {
+	logic, props := c.cloneLogicModule(template)
+	m := *template
+	nm := &m
+	nm.logicModule = logic
+	nm.properties = props
+	logic.setInfo(nm)
+
+	nm.variant = variant{name: tv.name, variations: tv.variations.clone()}
+	nm.directDeps = nil
+	nm.reverseDeps = nil
+	nm.forwardDeps = nil
+	nm.newDirectDeps = nil
+	nm.splitModules = nil
+	nm.obsoletedByNewVariants = false
+	nm.transitionInfos = append([]TransitionInfo(nil), tv.transitionInfos...)
+	if len(nm.transitionInfos) == 0 {
+		nm.transitionInfos = make([]TransitionInfo, len(c.transitionMutators))
+	}
+	return nm
+}
+
+// reconstructIncomingCombos returns, as target variants, the full combo
+// variations of `group` that some dependent currently requests. These must
+// survive a Split change because a (clean) dependent's edge points at them. The
+// dependent's referenced variant is the source of truth for the combo's name,
+// variations, and transition infos.
+func (c *Context) reconstructIncomingCombos(group *moduleGroup) []targetVariant {
+	seen := map[string]bool{}
+	var out []targetVariant
+	for m := range c.iterateAllVariants() {
+		if m.group == group {
+			continue
+		}
+		for _, d := range m.directDeps {
+			if d.module == nil || d.module.group != group {
+				continue
+			}
+			k := variationKey(d.module.variant.variations)
+			if seen[k] {
+				continue
+			}
+			seen[k] = true
+			out = append(out, targetVariant{
+				name:            d.module.variant.name,
+				variations:      d.module.variant.variations,
+				transitionInfos: d.module.transitionInfos,
+			})
+		}
+	}
+	return out
+}
+
+// ReMutateModulesStructural handles an edit that changes a module's transition
+// Split variant set (any number of transition mutators -- arch x os x ...), by
+// surgically adding/removing variants on the post-split graph rather than
+// re-splitting from the base (which would hit the deps-ordering wall). The target
+// variant set is the full nested-Split combo set (enumerateTargetVariants) plus
+// any combos dependents still request; added combos are created directly with
+// their variation map (so their deps resolve post-split), dropped combos are
+// removed, the variant order is preserved to match a full build, and every
+// variant's per-variant state is re-derived via reDeriveInPlace. An added variant
+// whose dependency lacks a matching variant (a cascade) surfaces an error so the
+// caller falls back to a full rebuild.
+func (c *Context) ReMutateModulesStructural(config interface{}, changedNames []string) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("ReMutateModulesStructural: no resident baseline")}
+	}
+
+	changedGroups, err := c.resolveChangedGroups(changedNames)
+	if err != nil {
+		return []error{fmt.Errorf("ReMutateModulesStructural: %w", err)}
+	}
+
+	// Surgically reconcile each changed group's variant set to the new combo set.
+	for _, cg := range changedGroups {
+		// Ordered target combos: the nested Split enumeration (matches a full build's
+		// variant order), then any dependent-requested combos not already present.
+		var ordered []targetVariant
+		seen := map[string]bool{}
+		appendTarget := func(t targetVariant) {
+			k := variationKey(t.variations)
+			if !seen[k] {
+				seen[k] = true
+				ordered = append(ordered, t)
+			}
+		}
+		for _, t := range c.enumerateTargetVariants(config, cg.bl, cg.bl.properties, cg.group) {
+			appendTarget(t)
+		}
+		for _, t := range c.reconstructIncomingCombos(cg.group) {
+			appendTarget(t)
+		}
+		if len(ordered) == 0 {
+			return []error{errStructuralChange} // would empty the group; out of scope
+		}
+
+		have := map[string]*moduleInfo{}
+		for _, m := range cg.group.modules {
+			have[variationKey(m.variant.variations)] = m
+		}
+		if len(cg.group.modules) == 0 {
+			return []error{errStructuralChange}
+		}
+		template := cg.group.modules[0]
+
+		var kept moduleList
+		for _, t := range ordered {
+			if m := have[variationKey(t.variations)]; m != nil {
+				kept = append(kept, m)
+			} else {
+				kept = append(kept, c.cloneVariantFromTarget(template, t))
+			}
+		}
+		cg.group.modules = kept
+	}
+
+	// Re-derive per-variant state (properties + deps) for every variant of the
+	// changed groups, including the newly added ones. A new variant whose dep lacks
+	// a matching variant surfaces an error here (caller falls back).
+	dirty, revDeps, _, rerrs := c.reDeriveInPlace(config, changedGroups)
+	if len(rerrs) > 0 {
+		return rerrs
+	}
+	rd := map[*moduleInfo][]depInfo{}
+	for _, r := range revDeps {
+		rd[r.module] = append(rd[r.module], r.dep)
+	}
+	for module, deps := range rd {
+		sort.Sort(depSorter{deps, c.nameInterface})
+		module.directDeps = append(module.directDeps, deps...)
+	}
+	if errs = c.updateDependencies(); len(errs) > 0 {
+		return errs
+	}
+	for v := range dirty {
+		_, v.pristineProperties = c.cloneLogicModule(v)
+		c.resetModuleBuildActions(v)
+	}
+	c.markDirty(dirty)
+	c.membershipChanged = true
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return nil
+}
+
+func (c *Context) ReMutateModulesInPlace(config interface{}, changedNames []string) (errs []error) {
+	if c.incMutation == nil {
+		return []error{fmt.Errorf("ReMutateModulesInPlace: no resident baseline; call SnapshotPreMutationState first")}
+	}
+	changedGroups, err := c.resolveChangedGroups(changedNames)
+	if err != nil {
+		return []error{fmt.Errorf("ReMutateModulesInPlace: %w", err)}
+	}
+
+	dirty, revDeps, depsChanged, rerrs := c.reDeriveInPlace(config, changedGroups)
+	if len(rerrs) > 0 {
+		return rerrs
+	}
+
+	// Apply reverse dependencies the re-run mutators added (appended to the
+	// destination module's direct deps, matching runMutator); updateDependencies
+	// rebuilds the reverse links from directDeps next.
+	rd := map[*moduleInfo][]depInfo{}
+	for _, r := range revDeps {
+		rd[r.module] = append(rd[r.module], r.dep)
+	}
+	for module, deps := range rd {
+		sort.Sort(depSorter{deps, c.nameInterface})
+		module.directDeps = append(module.directDeps, deps...)
+	}
+
+	// Rebuild the dep graph only if a dependency edge actually changed. When it
+	// didn't (the common property edit), reDeriveInPlace already restored the exact
+	// pre-edit forward/reverse deps, so the graph is identical and we skip the
+	// O(tree) updateDependencies -- making a property edit's analysis cost scale
+	// with the edit, not the whole tree.
+	if depsChanged {
+		if errs = c.updateDependencies(); len(errs) > 0 {
+			return errs
+		}
+	}
+
+	// Update the pre-generate pristine *properties* to the freshly transformed
+	// values, then hand the variants to the targeted-generate dirty set.
+	// pristineProviders is left as captured by the cold build's cloneModules (the
+	// post-mutation, pre-generate provider state): the property-transform mutators
+	// re-run above set properties, not providers, so the mutator-set provider state
+	// is unchanged. resetModuleBuildActions restores from it so generate can set its
+	// own providers without a double-set.
+	for v := range dirty {
+		_, v.pristineProperties = c.cloneLogicModule(v)
+		c.resetModuleBuildActions(v)
+	}
+	c.markDirty(dirty)
+	c.preserveLiveGlobals = true
+	c.buildActionsReady = false
+	return nil
+}
+
+// resetVariantToBaseline restores one existing variant's properties to a fresh
+// clone of the re-parsed baseline while preserving all of its structural state
+// (variant identity, dependency edges, transition infos, reverse deps). Used by
+// the in-place property re-derive.
+func (c *Context) resetVariantToBaseline(v *moduleInfo, bl *residentBaseline) {
+	newLogic, newProps := bl.factory()
+	if len(newProps) != len(bl.properties) {
+		panic(fmt.Errorf("resetVariantToBaseline: property count mismatch for %q", v.group.name))
+	}
+	for i := range newProps {
+		proptools.CopyProperties(reflect.ValueOf(newProps[i]), reflect.ValueOf(bl.properties[i]))
+	}
+	v.logicModule = newLogic
+	v.properties = newProps
+	newLogic.setInfo(v)
+}
+
+// runMutatorScoped runs one (coalesced) mutator group over only the variants
+// belonging to the changed groups, mirroring runMutator's per-module work and
+// post-processing (splice new variants, apply reverse deps / new modules /
+// renames / replacements) but restricted to the scoped set. Visiting is serial:
+// the dirty set is small on an incremental rebuild, and serial visiting in group
+// order avoids depending on parallelVisit's whole-graph wait counts. Cross-module
+// reads of clean modules see their final (post-all-mutators) state, which equals
+// their post-this-mutator state for provider reads (providers are write-once and
+// set by an earlier mutator).
+func (c *Context) runMutatorScoped(config interface{}, mutatorGroup []*mutatorInfo,
+	direction mutatorDirection, changedGroups map[*moduleGroup]bool, dirty map[*moduleInfo]bool) []error {
+
+	var errs []error
+	var allReverseDeps []reverseDep
+	var newModules []*moduleInfo
+	var renames []rename
+	var replaces []replace
+
+	// In scoped serial order every dependency is either a clean module (already
+	// past all mutators) or a changed module visited earlier in this pass, so a
+	// pause never needs to block.
+	pause := func(until *moduleInfo) {}
+
+	for group := range changedGroups {
+		modules := append(moduleList(nil), group.modules...)
+		for _, module := range modules {
+			if module.obsoletedByNewVariants {
+				continue
+			}
+			mctx := &mutatorContext{
+				baseModuleContext: baseModuleContext{context: c, config: config, module: module},
+				mutator:           mutatorGroup[0],
+				pauseFunc:         pause,
+			}
+			module.startedMutator = mutatorGroup[0].index
+			func() {
+				defer func() {
+					if r := recover(); r != nil {
+						in := fmt.Sprintf("%s %q for %s", direction, mutatorGroup[0].name, module)
+						if err, ok := r.(panicError); ok {
+							err.addIn(in)
+							mctx.error(err)
+						} else {
+							mctx.error(newPanicErrorf(r, in))
+						}
+					}
+				}()
+				direction.run(mutatorGroup, mctx)
+			}()
+			module.finishedMutator = mutatorGroup[len(mutatorGroup)-1].index
+
+			if len(mctx.errs) > 0 {
+				errs = append(errs, mctx.errs...)
+				continue
+			}
+			allReverseDeps = append(allReverseDeps, mctx.reverseDeps...)
+			newModules = append(newModules, mctx.newModules...)
+			renames = append(renames, mctx.rename...)
+			replaces = append(replaces, mctx.replace...)
+		}
+	}
+	if len(errs) > 0 {
+		return errs
+	}
+
+	// Splice newly created variants into their groups and add them to the dirty set.
+	for group := range changedGroups {
+		for i := 0; i < len(group.modules); i++ {
+			module := group.modules[i]
+			if module.splitModules != nil {
+				group.modules, i = spliceModules(group.modules, i, module.splitModules)
+			}
+		}
+		for _, module := range group.modules {
+			dirty[module] = true
+		}
+	}
+
+	// Apply reverse dependencies added by the mutator (appended to the destination
+	// module's direct deps, matching runMutator). updateDependencies rebuilds the
+	// reverse links from directDeps afterwards.
+	reverseDeps := map[*moduleInfo][]depInfo{}
+	for _, r := range allReverseDeps {
+		reverseDeps[r.module] = append(reverseDeps[r.module], r.dep)
+	}
+	for module, deps := range reverseDeps {
+		sort.Sort(depSorter{deps, c.nameInterface})
+		module.directDeps = append(module.directDeps, deps...)
+	}
+
+	for _, module := range newModules {
+		if nerrs := c.addModule(module); len(nerrs) > 0 {
+			return nerrs
+		}
+		dirty[module] = true
+	}
+	if len(renames) > 0 {
+		if nerrs := c.handleRenames(renames); len(nerrs) > 0 {
+			return nerrs
+		}
+	}
+	if len(replaces) > 0 {
+		if nerrs := c.handleReplacements(replaces); len(nerrs) > 0 {
+			return nerrs
+		}
+	}
+	return nil
+}
