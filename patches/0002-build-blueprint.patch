+// TestIncrementalSequentialEdits exercises a long-lived resident server: many
+// warm rebuilds in a row on the same Context. Each rebuild must be byte-identical
+// to a full build of that step's graph, which also verifies the interface-hash
+// baseline is correctly updated build-to-build (a later edit reverting an earlier
+// one must still match).
+func TestIncrementalSequentialEdits(t *testing.T) {
+	bp := func(aOut, bExp string) string {
+		return `
+			prov_module { name: "A", outputs: ["` + aOut + `"], deps: ["B"] }
+			prov_module { name: "B", outputs: ["outB"], exported: "` + bExp + `" }
+		`
+	}
+	steps := []struct {
+		bp      string
+		changed []string
+	}{
+		{bp("outA2", "v1"), []string{"A"}}, // edit A's own output
+		{bp("outA2", "v2"), []string{"B"}}, // edit B's exported -> propagates to A
+		{bp("outA2", "v1"), []string{"B"}}, // revert B's exported -> propagates to A
+		{bp("outA3", "v1"), []string{"A"}}, // edit A again
+	}
+
+	ctx := newIncCtx(t, bp("outA1", "v1"))
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("cold resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("cold prepare: %v", errs)
+	}
+	ctx.SnapshotInterfaceHashes()
+
+	for i, step := range steps {
+		ctx.BeginIncrementalBuild() // reset per-build incremental state
+		for _, name := range step.changed {
+			props := reparseModuleProps(t, step.bp, name)
+			if err := ctx.SetBaselineProperties(name, props); err != nil {
+				t.Fatalf("step %d SetBaselineProperties(%q): %v", i, name, err)
+			}
+		}
+		if errs := ctx.ReMutateModules(nil, step.changed); len(errs) > 0 {
+			t.Fatalf("step %d ReMutateModules: %v", i, errs)
+		}
+		if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+			t.Fatalf("step %d prepare: %v", i, errs)
+		}
+		got := writeModuleNinja(t, ctx)
+		want := fullBuildNinja(t, step.bp)
+		if got != want {
+			t.Fatalf("step %d not byte-identical\n--- want ---\n%s\n--- got ---\n%s", i, want, got)
+		}
+	}
+}
