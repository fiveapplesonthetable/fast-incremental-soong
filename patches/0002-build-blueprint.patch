+// RegenerateBuildActions re-generates build actions and rewrites the ninja file
+// on a Context whose dependency graph was already resolved by a previous
+// RunBlueprint call. It deliberately skips list_modules, parse_bp and
+// ResolveDependencies -- the O(whole-tree) phases that dominate a no-change /
+// local-edit rebuild (~34.5s + ~5s on a full AOSP tree) -- and only re-runs
+// PrepareBuildActions and the ninja write. This is the "graph residency" fast
+// path used by the resident soong_build server.
+//
+// The caller must first mark which modules to regenerate via
+// Context.MarkModulesDirty (clean modules keep their existing build actions); the
+// resolved graph must still be valid for the current sources (otherwise call
+// RunBlueprint). The result should be byte-verified against a full build.
+func RegenerateBuildActions(args Args, ctx *blueprint.Context, config interface{}) ([]string, error) {
+	if !ctx.DependenciesReady() {
+		return nil, fmt.Errorf("RegenerateBuildActions: dependencies are not resolved; a full RunBlueprint is required first")
+	}
+
+	var ninjaDeps []string
+	ninjaDeps = append(ninjaDeps, args.ModuleListFile)
+	// Keep the per-Android.bp content dependencies in the regenerated depfile (the
+	// resident path rewrites it). Otherwise a resident rebuild would drop the .bp
+	// files that the cold build listed, and the next content edit would not be
+	// detected by executors that rely on the depfile (see RunBlueprint).
+	if files, err := ctx.ListModulePaths("."); err == nil {
+		ninjaDeps = append(ninjaDeps, files...)
+	}
+
+	if ctx.BeforePrepareBuildActionsHook != nil {
+		if err := ctx.BeforePrepareBuildActionsHook(); err != nil {
+			return nil, colorizeErrs([]error{err})
+		}
+	}
+
+	if buildActionsDeps, errs := ctx.PrepareBuildActions(config); len(errs) > 0 {
+		return nil, colorizeErrs(errs)
+	} else {
+		ninjaDeps = append(ninjaDeps, buildActionsDeps...)
+	}
+
+	// If nothing was dirty, no build action changed, so the existing ninja file is
+	// already current -- skip rewriting it (the 553 MB write is the dominant cost
+	// of an otherwise no-op regenerate). Touch the output so its mtime is newer than
+	// the just-edited Android.bp; without this an mtime-based ninja would consider
+	// the manifest stale (it depends on every .bp) and regenerate it forever.
+	if ctx.NinjaUnchanged() {
+		out := blueprint.JoinPath(ctx.SrcDir(), args.OutFile)
+		now := time.Now()
+		if err := os.Chtimes(out, now, now); err != nil {
+			return nil, fmt.Errorf("error touching Ninja file: %s", err)
+		}
+		return ninjaDeps, nil
+	}
+
+	if args.EmptyNinjaFile {
+		if err := os.WriteFile(blueprint.JoinPath(ctx.SrcDir(), args.OutFile), []byte(nil), blueprint.OutFilePermissions); err != nil {
+			return nil, fmt.Errorf("error writing empty Ninja file: %s", err)
+		}
+		return ninjaDeps, nil
+	}
+
+	f, err := os.OpenFile(blueprint.JoinPath(ctx.SrcDir(), args.OutFile), os.O_WRONLY|os.O_CREATE|os.O_TRUNC, blueprint.OutFilePermissions)
+	if err != nil {
+		return nil, fmt.Errorf("error opening Ninja file: %s", err)
+	}
+	defer f.Close()
+	buf := bufio.NewWriterSize(f, 16*1024*1024)
+
+	if err := ctx.WriteBuildFile(buf, !strings.Contains(args.OutFile, "bootstrap.ninja"), args.OutFile); err != nil {
+		return nil, fmt.Errorf("error writing Ninja file contents: %s", err)
+	}
+	if err := buf.Flush(); err != nil {
+		return nil, fmt.Errorf("error flushing Ninja file contents: %s", err)
+	}
+
+	return ninjaDeps, nil
+}
+
 func colorizeErrs(errs []error) error {
 	red := "\x1b[31m"
 	unred := "\x1b[0m"
