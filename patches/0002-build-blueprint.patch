+// provModule is a test module whose emitted ninja depends on its direct deps'
+// providers: it appends "dep_<exported>" to its outputs for each dep, and exports
+// its own Exported property via the provider. Editing a module's Exported value
+// therefore changes the ninja of every module that depends on it, exercising
+// cross-module provider-change propagation.
+type provModule struct {
+	ModuleBase
+	SimpleName
+	props struct {
+		Deps     []string
+		Exported string
+		Outputs  []string
+	}
+}
+
+func newProvModule() (Module, []interface{}) {
+	m := &provModule{}
+	return m, []interface{}{&m.props, &m.SimpleName.Properties}
+}
+
+func (m *provModule) Deps() []string       { return m.props.Deps }
+func (m *provModule) IgnoreDeps() []string { return nil }
+
+func (m *provModule) GenerateBuildActions(ctx ModuleContext) {
+	outs := append([]string(nil), m.props.Outputs...)
+	ctx.VisitDirectDeps(func(dep Module) {
+		if p, ok := OtherModuleProvider(ctx, dep, IncrementalTestProviderKey); ok {
+			outs = append(outs, "dep_"+p.Value)
+		}
+	})
+	ctx.Build(pctx, BuildParams{Rule: Phony, Outputs: outs})
+	SetProvider(ctx, IncrementalTestProviderKey, IncrementalTestProvider{Value: m.props.Exported})
+}
+
+// chainModule is a test module whose EXPORTED provider value is derived from its
+// deps' provider values (Exported + each dep's value). Editing a leaf's Exported
+// therefore changes the provider hash of every module up the chain -- so the
+// modules regenerated by propagation (not just the edited one) have changed
+// provider hashes. This is what forces the incremental provider-hash fold to patch
+// the whole regenerated set, not only c.dirtyModules.
+type chainModule struct {
+	ModuleBase
+	SimpleName
+	props struct {
+		Deps     []string
+		Exported string
+		Outputs  []string
+	}
+}
+
+func newChainModule() (Module, []interface{}) {
+	m := &chainModule{}
+	return m, []interface{}{&m.props, &m.SimpleName.Properties}
+}
+
+func (m *chainModule) Deps() []string       { return m.props.Deps }
+func (m *chainModule) IgnoreDeps() []string { return nil }
+
+func (m *chainModule) GenerateBuildActions(ctx ModuleContext) {
+	val := m.props.Exported
+	ctx.VisitDirectDeps(func(dep Module) {
+		if p, ok := OtherModuleProvider(ctx, dep, IncrementalTestProviderKey); ok {
+			val += "+" + p.Value
+		}
+	})
+	outs := append([]string(nil), m.props.Outputs...)
+	outs = append(outs, "v_"+val)
+	ctx.Build(pctx, BuildParams{Rule: Phony, Outputs: outs})
+	SetProvider(ctx, IncrementalTestProviderKey, IncrementalTestProvider{Value: val})
+}
+
+// archProvModule is a transition-variantized test module (like an arch/os cc
+// module): it Splits into the variants named in "variants", the transition Mutate
+// bakes the chosen variation into a property, and its ninja emits Outputs + the
+// variant + each dep's exported provider. Editing Outputs/Exported is structure-
+// neutral; editing Variants is structural.
+type archProvModule struct {
+	ModuleBase
+	SimpleName
+	props struct {
+		Deps        []string
+		Variants    []string
+		Os_variants []string
+		Outputs     []string
+		Exported    string
+		Variant     string `blueprint:"mutated"`
+		Os          string `blueprint:"mutated"`
+		Sanitized   string `blueprint:"mutated"`
+	}
+}
+
+func newArchProvModule() (Module, []interface{}) {
+	m := &archProvModule{}
+	return m, []interface{}{&m.props, &m.SimpleName.Properties}
+}
+
+func (m *archProvModule) Deps() []string       { return m.props.Deps }
+func (m *archProvModule) IgnoreDeps() []string { return nil }
+
+func (m *archProvModule) GenerateBuildActions(ctx ModuleContext) {
+	outs := append([]string(nil), m.props.Outputs...)
+	outs = append(outs, "variant_"+m.props.Variant)
+	if m.props.Os != "" {
+		outs = append(outs, "os_"+m.props.Os)
+	}
+	if m.props.Sanitized != "" {
+		outs = append(outs, "san_"+m.props.Sanitized)
+	}
+	ctx.VisitDirectDeps(func(dep Module) {
+		if p, ok := OtherModuleProvider(ctx, dep, IncrementalTestProviderKey); ok {
+			outs = append(outs, "dep_"+p.Value)
+		}
+	})
+	ctx.Build(pctx, BuildParams{Rule: Phony, Outputs: outs})
+	SetProvider(ctx, IncrementalTestProviderKey, IncrementalTestProvider{Value: m.props.Exported})
+}
+
+// sanitizeLikeMutator models a real-Soong mutator that BOTH adds a dependency
+// (so it is non-coalescable) AND contributes a property (sets Sanitized). The
+// in-place property re-derive skips it (it is not coalescable), so resetting to
+// baseline loses its contribution -- which is exactly what inPlaceFaithful must
+// detect, forcing a full-rebuild fallback.
+func sanitizeLikeMutator(mctx BottomUpMutatorContext) {
+	if m, ok := mctx.Module().(*archProvModule); ok {
+		m.props.Sanitized = "on"
+	}
+}
+
+// archLikeMutator is a transition mutator that splits a module into the variants
+// it names, and records the chosen variation in the module via Mutate.
+type archLikeMutator struct{}
+
+func (archLikeMutator) TransitionInfoFromVariation(s string) TransitionInfo {
+	return testTransitionInfo(s)
+}
+
+func (archLikeMutator) Split(ctx BaseModuleContext) []TransitionInfo {
+	if vs := ctx.Module().(*archProvModule).props.Variants; len(vs) > 0 {
+		var ti []TransitionInfo
+		for _, v := range vs {
+			ti = append(ti, testTransitionInfo(v))
+		}
+		return ti
+	}
+	return []TransitionInfo{testTransitionInfo("")}
+}
+
+func (archLikeMutator) OutgoingTransition(ctx OutgoingTransitionContext, src TransitionInfo) TransitionInfo {
+	return src
+}
+
+func (archLikeMutator) IncomingTransition(ctx IncomingTransitionContext, in TransitionInfo) TransitionInfo {
+	return in
+}
+
+func (archLikeMutator) Mutate(ctx BottomUpMutatorContext, variation TransitionInfo) {
+	if variation != nil {
+		ctx.Module().(*archProvModule).props.Variant = variation.Variation()
+	}
+}
+
+// osLikeMutator is a SECOND transition mutator (models os on top of arch), so a
+// module is split into the arch x os combo variants of real Soong. It records the
+// chosen os variation in a separate mutated property.
+type osLikeMutator struct{}
+
+func (osLikeMutator) TransitionInfoFromVariation(s string) TransitionInfo {
+	return testTransitionInfo(s)
+}
+
+func (osLikeMutator) Split(ctx BaseModuleContext) []TransitionInfo {
+	if vs := ctx.Module().(*archProvModule).props.Os_variants; len(vs) > 0 {
+		var ti []TransitionInfo
+		for _, v := range vs {
+			ti = append(ti, testTransitionInfo(v))
+		}
+		return ti
+	}
+	return []TransitionInfo{testTransitionInfo("")}
+}
+
+func (osLikeMutator) OutgoingTransition(ctx OutgoingTransitionContext, src TransitionInfo) TransitionInfo {
+	return src
+}
+func (osLikeMutator) IncomingTransition(ctx IncomingTransitionContext, in TransitionInfo) TransitionInfo {
+	return in
+}
+func (osLikeMutator) Mutate(ctx BottomUpMutatorContext, variation TransitionInfo) {
+	if variation != nil {
+		ctx.Module().(*archProvModule).props.Os = variation.Variation()
+	}
+}
