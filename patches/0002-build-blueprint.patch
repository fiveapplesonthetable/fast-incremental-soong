+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package incr
+
+import (
+	"bytes"
+	"fmt"
+	"strings"
+)
+
+// droidstubs is the Soong type that invokes metalava over a Java source set
+// to produce stubs (.srcjar), the API signature file, the removed-api file,
+// the lint baseline / lint output, and (optionally) an annotations zip.
+//
+// What the emitter captures here:
+//
+//   - srcs is the Java source set fed to metalava. Reordering or adding a src
+//     file changes both the stubs jar and the API signature: the resolved def
+//     hash already captures that, so the engine recomputes only this module
+//     and its dependents.
+//   - libs is the classpath. A change to any classpath dep (e.g. a transitive
+//     defaults edit that adds a lib) reaches us through depHashes.
+//   - flags is a passthrough of the metalava command-line knobs (--stub-packages,
+//     --hide, --error etc.); a single-character change here means metalava
+//     produces different stubs, so it has to be part of the content hash --
+//     and the canonical-properties layer already ensures that.
+//   - check_api parameters (api_file / removed_api_file / last_released) are
+//     part of the resolved def too; we surface their presence so a textual diff
+//     against the real ninja is recognisable.
+//
+// The emitter produces three build statements that mirror Soong's grouping:
+// stubs.srcjar, api.txt, and a lint stamp. They all share the same content
+// hash because Soong emits them from a single metalava invocation; using a
+// shared id keeps a future reverse-lookup ("which droidstubs produced this
+// .srcjar?") simple.
+//
+// Two synthetic variants of this type, droidstubs__loadHookModule and
+// droidstubs__bottomUpMutatorModule, appear in real Soong .ninja output for
+// programmatically-created modules; they are registered in their own files so
+// each variant's registration can carry its own provenance comment.
+func emitDroidstubs(name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	id := fmt.Sprintf("%016x", hashBytes(resolvedDef))
+	dep := fmt.Sprintf("%016x", hashBytes(depHashes))
+	srcs := strings.TrimSpace(res.props["srcs"])
+	libs := strings.TrimSpace(res.props["libs"])
+	flags := strings.TrimSpace(res.props["flags"])
+	hasCheckApi := strings.TrimSpace(res.props["check_api"]) != ""
+
+	// Variant tag for the optional load-hook / mutator suffix so the emitted
+	// fragment is self-describing.
+	variant := ""
+	if strings.HasSuffix(res.typ, "__loadHookModule") {
+		variant = " [loadHookModule]"
+	} else if strings.HasSuffix(res.typ, "__bottomUpMutatorModule") {
+		variant = " [bottomUpMutatorModule]"
+	}
+
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "# module %s (droidstubs%s)\n", name, variant)
+	fmt.Fprintf(&b, "build out/soong/.intermediates/%s/stubs.srcjar: metalava\n", name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	if srcs != "" {
+		fmt.Fprintf(&b, "    srcs = %s\n", srcs)
+	}
+	if libs != "" {
+		fmt.Fprintf(&b, "    libs = %s\n", libs)
+	}
+	if flags != "" {
+		fmt.Fprintf(&b, "    flags = %s\n", flags)
+	}
+	fmt.Fprintf(&b, "build out/soong/.intermediates/%s/api.txt: metalava_api\n", name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "build out/soong/.intermediates/%s/lint.stamp: metalava_lint\n", name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	if hasCheckApi {
+		fmt.Fprintf(&b, "    check_api = present\n")
+	}
+	return b.Bytes()
+}
+
+func init() {
+	registerEmitter("droidstubs", emitDroidstubs)
+}
