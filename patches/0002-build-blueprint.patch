+// TestIncrementalProviderFoldMembershipFallback asserts that add/remove module
+// flips membershipChanged, which routes the warm fold to a full recompute rather
+// than the per-module delta (whose stable-identity assumption an add/remove breaks).
+func TestIncrementalProviderFoldMembershipFallback(t *testing.T) {
+	orig := `
+		prov_module { name: "A", outputs: ["oA"], deps: ["B"] }
+		prov_module { name: "B", outputs: ["oB"], exported: "v1" }
+	`
+	added := `
+		prov_module { name: "A", outputs: ["oA"], deps: ["B"] }
+		prov_module { name: "B", outputs: ["oB"], exported: "v1" }
+		prov_module { name: "C", outputs: ["oC"], exported: "v9" }
+	`
+	ctx := newIncCtx(t, orig)
+	ctx.SetKeepPristineModules(true)
+	if err := ctx.SnapshotPreMutationState(); err != nil {
+		t.Fatalf("snapshot: %v", err)
+	}
+	if _, errs := ctx.ResolveDependencies(nil); len(errs) > 0 {
+		t.Fatalf("resolve: %v", errs)
+	}
+	if _, errs := ctx.PrepareBuildActions(nil); len(errs) > 0 {
+		t.Fatalf("prepare: %v", errs)
+	}
+	ctx.calculateProvidersHashes()
+	ctx.SnapshotInterfaceHashes()
+
+	ctx.BeginIncrementalBuild()
+	if ctx.membershipChanged {
+		t.Fatalf("membershipChanged should be false after BeginIncrementalBuild")
+	}
+	reparsed := newIncCtx(t, added)
+	if errs := ctx.IncrementalAddModules(nil, reparsed, []string{"C"}); len(errs) > 0 {
+		t.Fatalf("IncrementalAddModules: %v", errs)
+	}
+	if !ctx.membershipChanged {
+		t.Errorf("IncrementalAddModules must set membershipChanged so the fold falls back to full recompute")
+	}
+}
