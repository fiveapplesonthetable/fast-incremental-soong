diff --git a/incr/emit_module_exports.go b/incr/emit_module_exports.go
new file mode 100644
index 0000000..6bbda74
--- /dev/null
+++ b/incr/emit_module_exports.go
@@ -0,0 +1,115 @@
+// Copyright 2026 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package incr
+
+import (
+	"bytes"
+	"fmt"
+	"sort"
+	"strings"
+)
+
+// module_exports is one of Soong's two snapshot aggregator types (the other
+// is sdk; see emit_sdk.go). It bundles a list of already-built modules --
+// java_libs, native_libs, native_binaries, native_shared_libs, native_static_libs,
+// java_header_libs etc. -- into a self-contained snapshot zip that can be
+// shipped as a prebuilt to another tree. The canonical use is mainline modules
+// exporting their host tools for branches that don't build them from source
+// (art-module-host-exports, i18n-module-host-exports, etc.).
+//
+// The Soong ninja for a module_exports has the same shape as for an sdk
+// (snapshot/ tree of copies, SnapshotZipFiles into a .zip, rawFileCopy into a
+// .info, then install of both into out/soong/mainline-sdks/). What
+// distinguishes module_exports from sdk is policy, not shape: module_exports
+// is the unsealed form that doesn't enforce API compat, while sdk is the
+// public, API-checked form. The ninja-level emitter therefore mirrors what
+// the sdk emitter does, just under a module_exports type tag, and the two
+// share a helper.
+//
+// What the emitter captures here:
+//
+//   - The aggregator's members: every list-valued export-like property is
+//     surfaced so the engine's content-addressing covers them. Adding a
+//     member to a snapshot must invalidate the snapshot; the canonical
+//     properties layer already folds those values into resolvedDef, so we
+//     reflect them in the fragment for legibility / textual diffability.
+//   - The standard outputs: <name>-current.zip and <name>-current.info under
+//     out/soong/mainline-sdks/, matching the real ninja install paths.
+//
+// host_supported is surfaced as a tag so a diff against real ninja recognises
+// the host-only variants (art-module-host-exports etc.).
+func emitModuleExports(name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	return emitSnapshotAggregator(name, "module_exports", res, resolvedDef, depHashes)
+}
+
+// emitSnapshotAggregator renders a snapshot-zip ninja fragment for either a
+// module_exports or an sdk module: same Soong build actions, same install
+// paths under out/soong/mainline-sdks/, differing only in the type tag and
+// the surfaced member-list properties.
+func emitSnapshotAggregator(name, typ string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	id := fmt.Sprintf("%016x", hashBytes(resolvedDef))
+	dep := fmt.Sprintf("%016x", hashBytes(depHashes))
+
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "# module %s (%s)\n", name, typ)
+	if v := strings.TrimSpace(res.props["host_supported"]); v != "" {
+		fmt.Fprintf(&b, "# host_supported %s\n", v)
+	}
+
+	// Surface every membership property in sorted order so the fragment is
+	// deterministic regardless of map iteration order.
+	memberKeys := make([]string, 0, len(snapshotMemberProps))
+	for k := range snapshotMemberProps {
+		memberKeys = append(memberKeys, k)
+	}
+	sort.Strings(memberKeys)
+	for _, k := range memberKeys {
+		if v := strings.TrimSpace(res.props[k]); v != "" {
+			fmt.Fprintf(&b, "    %s = %s\n", k, v)
+		}
+	}
+
+	fmt.Fprintf(&b, "build out/soong/mainline-sdks/%s-current.zip: g.sdk.SnapshotZipFiles\n", name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	fmt.Fprintf(&b, "build out/soong/mainline-sdks/%s-current.info: g.android.rawFileCopy\n", name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	return b.Bytes()
+}
+
+// snapshotMemberProps lists the property names that name member modules of a
+// sdk / module_exports snapshot. They are the keys whose values bind the
+// snapshot's contents; an edit to any of them must regenerate the zip, which
+// the canonical properties layer already ensures.
+var snapshotMemberProps = map[string]bool{
+	"java_libs":              true,
+	"java_header_libs":       true,
+	"java_sdk_libs":          true,
+	"java_systemserver_libs": true,
+	"java_boot_libs":         true,
+	"native_libs":            true,
+	"native_shared_libs":     true,
+	"native_static_libs":     true,
+	"native_header_libs":     true,
+	"native_binaries":        true,
+	"native_objects":         true,
+	"bootclasspath_fragments": true,
+	"systemserverclasspath_fragments": true,
+	"apexes":                 true,
+}
+
+func init() {
+	registerEmitter("module_exports", emitModuleExports)
+}
