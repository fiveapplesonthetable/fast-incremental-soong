+// form needs to emit anything extra (e.g. the parent module's name in a comment),
+// branch inside emitDroidstubs on res.typ rather than fork the function.
+func init() {
+	registerEmitter("droidstubs__bottomUpMutatorModule", emitDroidstubs)
+}
