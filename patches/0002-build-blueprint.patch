+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package incr
+
+// sdk is the second of Soong's two snapshot aggregator types (the first is
+// module_exports; see emit_module_exports.go). Unlike module_exports, an sdk
+// is API-checked: its java_sdk_libs / native_libs / bootclasspath_fragments
+// have stable interfaces and the snapshot ships the public API surface, so
+// downstream branches can build against the prebuilt snapshot without source.
+// Canonical examples: art-module-sdk, i18n-module-sdk, conscrypt-module-sdk,
+// each one defined alongside a matching module_exports in the same Android.bp.
+//
+// The ninja Soong emits for an sdk module has the SAME shape as for a
+// module_exports -- a snapshot/ tree of file copies, a SnapshotZipFiles into
+// the current.zip, a rawFileCopy of the current.info, and installs of both
+// under out/soong/mainline-sdks/. The two diverge in API-enforcement policy
+// (Soong-side compat checking), not in ninja-level emission. So this emitter
+// reuses emitSnapshotAggregator from emit_module_exports.go and merely
+// supplies "sdk" as the type tag; the canonical-properties layer already
+// covers any sdk-specific properties (traits, prefer_stable, etc.) by hashing
+// them into the resolved def.
+//
+// Surfaces host_supported and every member-list property, in sorted order, so
+// the fragment is deterministic regardless of map iteration.
+func emitSdk(name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	return emitSnapshotAggregator(name, "sdk", res, resolvedDef, depHashes)
+}
+
+func init() {
+	registerEmitter("sdk", emitSdk)
+}
diff --git a/incr/emitters.go b/incr/emitters.go
new file mode 100644
index 0000000..4e2d861
--- /dev/null
+++ b/incr/emitters.go
@@ -0,0 +1,68 @@
+// Copyright 2026 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package incr
+
+// Native emitters. The gen:<path>/<name> query asks the resolved module what
+// its type is and dispatches to a per-type EmitFunc, which returns the ninja
+// fragment for that one module. Each emitter is a pure function of the resolved
+// def + the direct deps' resolved hashes; the engine's content-addressing then
+// guarantees that a warm rebuild reuses the cached fragment unless the
+// function's inputs actually changed, and recomputed fragments early-cut off
+// when the bytes are unchanged.
+//
+// Why per-type: a generic phony stamp is enough to prove the engine, but real
+// Soong emits radically different ninja for, say, droidstubs (metalava
+// invocation, stubs/api/lint outputs) vs blueprint_go_binary (compile+link of
+// a host go program). A per-type emitter lets the warm path produce the SAME
+// ninja a cold build would, at the granularity Soong actually rebuilds at.
+//
+// Adding a new type: write `func emitFoo(...) []byte`, register it in
+// emitterTable below keyed on the .bp type string. If a module type appears
+// programmatically with the suffix "__loadHookModule" or "__bottomUpMutatorModule"
+// (i.e. created by a load hook or a bottom-up mutator instead of a top-level
+// .bp stanza), register the suffixed variant explicitly: it is a distinct
+// Soong module type, even though it shares the underlying factory.
+
+// EmitFunc produces the ninja fragment for one module. name is the module's
+// declared name, res is the merged (post-defaults) resolved def, resolvedDef is
+// the canonical bytes of res that the engine content-hashes, and depHashes is
+// the concatenation of each direct dep's resolvedDef bytes.
+type EmitFunc func(name string, res *resolved, resolvedDef, depHashes []byte) []byte
+
+// emitterTable maps a .bp module type to its native emitter. Keys are exact
+// type strings (including any "__loadHookModule" / "__bottomUpMutatorModule"
+// synthetic suffix Soong appends to programmatically-created modules).
+var emitterTable = map[string]EmitFunc{}
+
+// registerEmitter installs an EmitFunc for a given module type. Panics if the
+// type already has an emitter, so that two source files do not silently shadow
+// each other.
+func registerEmitter(typ string, fn EmitFunc) {
+	if _, ok := emitterTable[typ]; ok {
+		panic("incr: duplicate emitter for type " + typ)
+	}
+	emitterTable[typ] = fn
+}
+
+// emit dispatches to the registered EmitFunc for typ, falling back to the
+// generic phony stamp if no native emitter is registered. The fallback is what
+// keeps the engine able to analyze a tree containing types we haven't written
+// emitters for yet -- we lose per-type granularity but keep correctness.
+func emit(typ, name string, res *resolved, resolvedDef, depHashes []byte) []byte {
+	if fn, ok := emitterTable[typ]; ok {
+		return fn(name, res, resolvedDef, depHashes)
+	}
+	return genericEmit(name, resolvedDef, depHashes)
+}
diff --git a/incr/engine.go b/incr/engine.go
new file mode 100644
index 0000000..37195d2
--- /dev/null
+++ b/incr/engine.go
@@ -0,0 +1,230 @@
+// Copyright 2026 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+// Package incr is a content-addressed, demand-driven incremental computation
+// engine (the Salsa / Adapton / Buck2-DICE model) for build analysis.
+//
+// The premise that motivates it: today's Soong analysis is not correct-by-
+// construction, so an incremental ("warm") re-derive cannot be trusted to match
+// a cold build. That forces a faithfulness self-check and, when it fails (any
+// non-trivial frameworks/base edit), a full cold fallback that costs minutes.
+//
+// This engine removes the need for both. Every derivation is a pure query keyed
+// on the content of its inputs; the engine records, per query, exactly which
+// other queries it read; on an edit it recomputes only the queries whose inputs
+// actually changed, with EARLY CUTOFF (if a recomputed query produces the same
+// content hash, its dependents are not recomputed). The warm result therefore
+// equals the cold result BY CONSTRUCTION -- there is no self-check and no
+// fallback, and the recompute cost is O(edit), not O(tree).
+package incr
+
+import (
+	"fmt"
+	"hash/fnv"
+)
+
+// Key identifies a query instance, e.g. "parse:frameworks/base/Android.bp" or
+// "gen:frameworks/base/Android.bp/framework-ike-shared-srcs".
+type Key string
+
+// Result is what a query produces. Bytes is the canonical content: it is what
+// the engine hashes for content-addressing, and for terminal queries (ninja
+// fragments) it is also the output. Data is an optional structured payload that
+// downstream queries may read without re-serializing.
+type Result struct {
+	Bytes []byte
+	Data  interface{}
+}
+
+// QueryFunc computes a Result, demanding other queries via ctx.Get (which
+// records the dependency edge automatically). It must be a pure function of the
+// queries it reads -- no ambient I/O, clock, or global state.
+type QueryFunc func(ctx *Ctx) (Result, error)
+
+type node struct {
+	key      Key
+	fn       QueryFunc // nil => input (leaf) node
+	res      Result
+	hash     uint64
+	deps     []Key
+
+	// changedAt is the revision at which this node's content hash last changed.
+	// verifiedAt is the revision at which we last confirmed the node is current.
+	// A derived node is stale iff some dependency's changedAt is newer than this
+	// node's verifiedAt -- the standard Salsa red/green invariant.
+	changedAt  uint64
+	verifiedAt uint64
+	computed   bool
+}
+
+// Engine holds the memo table and the global revision clock.
+type Engine struct {
+	nodes     map[Key]*node
+	resolvers []func(Key) (QueryFunc, bool)
+	revision  uint64
+
+	// Per-Build stats (reset at the start of each Build).
+	Recomputed int // queries whose function actually ran
+	Cutoff     int // ran but produced an identical hash (dependents spared)
+	Verified   int // confirmed current without running
+}
+
+func New() *Engine { return &Engine{nodes: map[Key]*node{}} }
+
+// Register installs the function for a derived query key.
+func (e *Engine) Register(key Key, fn QueryFunc) {
+	n := e.nodes[key]
+	if n == nil {
+		n = &node{key: key}
+		e.nodes[key] = n
+	}
+	n.fn = fn
+}
+
+// AddResolver installs a handler that lazily materializes derived queries whose
+// keys are not pre-registered (e.g. "gen:<file>/<name>" for any module). This is
+// what lets a newly added module be analyzed without re-registering anything.
+func (e *Engine) AddResolver(r func(Key) (QueryFunc, bool)) {
+	e.resolvers = append(e.resolvers, r)
+}
+
+func hashBytes(b []byte) uint64 {
+	h := fnv.New64a()
+	h.Write(b)
+	return h.Sum64()
+}
+
+// SetInput sets the content of an input (leaf) query. It bumps the global
+// revision and marks the input changed iff its content actually differs, so a
+// no-op re-set is free.
+func (e *Engine) SetInput(key Key, content []byte) {
+	n := e.nodes[key]
+	h := hashBytes(content)
+	if n != nil && n.computed && n.fn == nil && n.hash == h {
+		return // identical content -> not a change
+	}
+	if n == nil {
+		n = &node{key: key}
+		e.nodes[key] = n
+	}
+	e.revision++
+	n.fn = nil
+	n.res = Result{Bytes: content}
+	n.hash = h
+	n.changedAt = e.revision
+	n.verifiedAt = e.revision
+	n.computed = true
+}
+
+// Ctx is handed to a QueryFunc; Get demands another query and records the edge.
+type Ctx struct {
+	e    *Engine
+	deps []Key
+}
+
+// Get demands the value of another query, recording a dependency on it.
+func (c *Ctx) Get(key Key) (Result, error) {
+	c.deps = append(c.deps, key)
+	n, err := c.e.bring(key)
+	if err != nil {
+		return Result{}, err
+	}
+	return n.res, nil
+}
+
+// Build brings target (and transitively its dependencies) up to date at the
+// current revision and returns its Result. Only queries whose inputs actually
+// changed since the last Build are recomputed.
+func (e *Engine) Build(target Key) (Result, error) {
+	e.Recomputed, e.Cutoff, e.Verified = 0, 0, 0
+	n, err := e.bring(target)
+	if err != nil {
+		return Result{}, err
+	}
+	return n.res, nil
+}
+
+func (e *Engine) lookup(key Key) *node {
+	if n := e.nodes[key]; n != nil {
+		return n
+	}
+	for _, r := range e.resolvers {
+		if fn, ok := r(key); ok {
+			n := &node{key: key, fn: fn}
+			e.nodes[key] = n
+			return n
+		}
+	}
+	return nil
+}
+
+func (e *Engine) bring(key Key) (*node, error) {
+	n := e.lookup(key)
+	if n == nil {
+		return nil, fmt.Errorf("incr: no such query %q", key)
+	}
+	// Already confirmed current this revision (the per-build memo).
+	if n.computed && n.verifiedAt == e.revision {
+		e.Verified++
+		return n, nil
+	}
+	// Inputs are current by definition once set.
+	if n.fn == nil {
+		n.verifiedAt = e.revision
+		return n, nil
+	}
+	// Derived: verify dependencies and find the newest dependency change.
+	if n.computed {
+		var maxDepChanged uint64
+		for _, dk := range n.deps {
+			dn, err := e.bring(dk)
+			if err != nil {
+				return nil, err
+			}
+			if dn.changedAt > maxDepChanged {
+				maxDepChanged = dn.changedAt
+			}
+		}
+		if maxDepChanged <= n.verifiedAt {
+			// No dependency changed since we last verified this query: still good.
+			n.verifiedAt = e.revision
+			e.Verified++
+			return n, nil
+		}
+	}
+	// Recompute. The function re-declares its dependencies via ctx.Get.
+	ctx := &Ctx{e: e}
+	res, err := n.fn(ctx)
+	if err != nil {
+		return nil, err
+	}
+	e.Recomputed++
+	h := hashBytes(res.Bytes)
+	n.deps = ctx.deps
+	prevHash, wasComputed := n.hash, n.computed
+	n.res = res
+	n.computed = true
+	n.verifiedAt = e.revision
+	if wasComputed && h == prevHash {
+		// EARLY CUTOFF: identical content, so dependents need not recompute.
+		e.Cutoff++
+	} else {
+		n.hash = h
+		n.changedAt = e.revision
+	}
+	return n, nil
+}
+
+// NodeCount returns the number of materialized query nodes (for diagnostics).
+func (e *Engine) NodeCount() int { return len(e.nodes) }
