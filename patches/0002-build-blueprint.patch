+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package incr
+
+import (
+	"bytes"
+	"fmt"
+	"os"
+	"sort"
+	"strings"
+
+	"github.com/google/blueprint/parser"
+)
+
+func readFileBytes(path string) ([]byte, error) { return os.ReadFile(path) }
+
+// The pipeline wires a real .bp -> ninja analysis onto the engine as pure,
+// content-addressed queries. Query keys:
+//
+//   file:<path>            input: the raw bytes of an Android.bp file.
+//   parse:<path>           parse <path> into name -> parsed module. Depends on
+//                          file:<path>.
+//   mod:<path>/<name>      one module's RAW canonical def (pre-defaults), sliced
+//                          out of parse:<path>. Depends on parse:<path>; its hash
+//                          changes only when THAT module's own text changes.
+//   resolved:<path>/<name> the module's def after MERGING its `defaults:` modules
+//                          (defaults are the base; the module overrides). Depends
+//                          on mod:<path>/<name> and resolved:<...> of each default
+//                          -- a real cross-module edge. Editing a widely-used
+//                          defaults module re-resolves only its users (early
+//                          cutoff stops anything whose merged result is unchanged).
+//   gen:<path>/<name>      the ninja fragment for one module, names content-
+//                          addressed. Depends on resolved:<path>/<name>.
+//   manifest               concatenation of all gen fragments in (path,name)
+//                          order.
+//
+// Correct-by-construction: names are hashes of the module's resolved identity,
+// the canonical encoding sorts property keys, and assembly sorts by (path,name).
+// A warm rebuild after an edit is byte-identical to a cold build of the edited
+// tree -- no faithfulness check, no fallback.
+
+const (
+	filePrefix  = "file:"
+	parsePrefix = "parse:"
+	modPrefix   = "mod:"
+	resPrefix   = "resolved:"
+	genPrefix   = "gen:"
+	manifestKey = "manifest"
+)
+
+// pmod is a parsed module: its canonical own-property text (keys sorted, value
+// order preserved), the names listed in its `defaults:` property, and the module
+// names it depends on (from *_libs etc. and ":name" srcs references).
+type pmod struct {
+	canon    string            // "type{key:val;...}" of the module's OWN properties
+	props    map[string]string // key -> canonical value, for merging
+	typ      string
+	defaults []string
+	deps     []string
+}
+
+// resolved is the result of a resolved:<module> query: the merged property map
+// (after defaults), the merged dependency name list, and the module's type
+// (which the gen layer dispatches on to pick a native emitter).
+type resolved struct {
+	typ   string
+	props map[string]string
+	deps  []string
+}
+
+// depProps are the list-valued properties whose entries name other modules.
+var depProps = map[string]bool{
+	"static_libs": true, "libs": true, "shared_libs": true, "whole_static_libs": true,
+	"header_libs": true, "runtime_libs": true, "system_shared_libs": true,
+	"plugins": true, "required": true, "exported_plugins": true,
+}
+
+// Pipeline registers the queries for a fixed set of .bp files on an engine.
+type Pipeline struct {
+	e          *Engine
+	files      []string
+	nameToFile map[string]string // module name -> defining file (for dep resolution)
+}
+
+// NewPipeline registers file/parse queries and the lazy mod:/resolved:/gen:
+// resolvers plus the manifest query. It first does a one-time plain parse to map
+// each module name to its file so defaults can be resolved across files.
+func NewPipeline(e *Engine, files []string) *Pipeline {
+	p := &Pipeline{e: e, files: append([]string(nil), files...), nameToFile: map[string]string{}}
+	sort.Strings(p.files)
+
+	// One-time index: module name -> file. (A real backend would maintain this as
+	// its own incremental query; static is fine for the demo's fixed file set.)
+	for _, f := range p.files {
+		if b, err := readFileBytes(f); err == nil {
+			for name := range parseModules(f, b) {
+				p.nameToFile[name] = f
+			}
+		}
+	}
+
+	for _, f := range p.files {
+		path := f
+		e.Register(Key(parsePrefix+path), func(ctx *Ctx) (Result, error) {
+			src, err := ctx.Get(Key(filePrefix + path))
+			if err != nil {
+				return Result{}, err
+			}
+			return parseFile(path, src.Bytes)
+		})
+	}
+
+	// mod:<path>/<name> -- one module's raw (pre-defaults) canonical def.
+	e.AddResolver(func(k Key) (QueryFunc, bool) {
+		if !strings.HasPrefix(string(k), modPrefix) {
+			return nil, false
+		}
+		path, name := splitPathName(string(k)[len(modPrefix):])
+		return func(ctx *Ctx) (Result, error) {
+			pr, err := ctx.Get(Key(parsePrefix + path))
+			if err != nil {
+				return Result{}, err
+			}
+			m, ok := pr.Data.(map[string]*pmod)[name]
+			if !ok {
+				return Result{}, fmt.Errorf("module %q not in %s", name, path)
+			}
+			return Result{Bytes: []byte(m.canon), Data: m}, nil
+		}, true
+	})
+
+	// resolved:<path>/<name> -- the module after merging its defaults modules.
+	e.AddResolver(func(k Key) (QueryFunc, bool) {
+		if !strings.HasPrefix(string(k), resPrefix) {
+			return nil, false
+		}
+		path, name := splitPathName(string(k)[len(resPrefix):])
+		return func(ctx *Ctx) (Result, error) {
+			mr, err := ctx.Get(Key(modPrefix + path + "/" + name))
+			if err != nil {
+				return Result{}, err
+			}
+			m := mr.Data.(*pmod)
+			// Merge: defaults are the base (in listed order), module overrides.
+			merged := map[string]string{}
+			var deps []string
+			for _, d := range m.defaults {
+				df, ok := p.nameToFile[d]
+				if !ok {
+					continue // unknown defaults module: skip (matches lenient soong)
+				}
+				dr, err := ctx.Get(Key(resPrefix + df + "/" + d))
+				if err != nil {
+					return Result{}, err
+				}
+				rd := dr.Data.(*resolved)
+				for k2, v := range rd.props {
+					merged[k2] = v
+				}
+				deps = append(deps, rd.deps...)
+			}
+			for k2, v := range m.props {
+				merged[k2] = v // module's own props override defaults
+			}
+			deps = append(deps, m.deps...)
+			return Result{Bytes: []byte(canonProps(m.typ, merged)), Data: &resolved{typ: m.typ, props: merged, deps: deps}}, nil
+		}, true
+	})
+
+	// gen:<path>/<name> -- ninja fragment from the RESOLVED module AND its direct
+	// deps' resolved identities (a module's build action reflects what it links
+	// against), so editing a library propagates to its dependents -- scoped to the
+	// reverse-dep closure, with early cutoff when a dep's resolved is unchanged.
+	e.AddResolver(func(k Key) (QueryFunc, bool) {
+		if !strings.HasPrefix(string(k), genPrefix) {
+			return nil, false
+		}
+		path, name := splitPathName(string(k)[len(genPrefix):])
+		return func(ctx *Ctx) (Result, error) {
+			rr, err := ctx.Get(Key(resPrefix + path + "/" + name))
+			if err != nil {
+				return Result{}, err
+			}
+			res := rr.Data.(*resolved)
+			var depHashes []byte
+			for _, d := range res.deps {
+				df, ok := p.nameToFile[d]
+				if !ok {
+					continue
+				}
+				dr, err := ctx.Get(Key(resPrefix + df + "/" + d))
+				if err != nil {
+					return Result{}, err
+				}
+				depHashes = append(depHashes, dr.Bytes...)
+			}
+			return Result{Bytes: emit(res.typ, name, res, rr.Bytes, depHashes)}, nil
+		}, true
+	})
+
+	e.Register(Key(manifestKey), func(ctx *Ctx) (Result, error) {
+		type ref struct{ path, name string }
+		var refs []ref
+		for _, f := range p.files {
+			pr, err := ctx.Get(Key(parsePrefix + f))
+			if err != nil {
+				return Result{}, err
+			}
+			for name := range pr.Data.(map[string]*pmod) {
+				refs = append(refs, ref{f, name})
+			}
+		}
+		sort.Slice(refs, func(i, j int) bool {
+			if refs[i].path != refs[j].path {
+				return refs[i].path < refs[j].path
+			}
+			return refs[i].name < refs[j].name
+		})
+		var buf bytes.Buffer
+		for _, r := range refs {
+			frag, err := ctx.Get(Key(genPrefix + r.path + "/" + r.name))
+			if err != nil {
+				return Result{}, err
+			}
+			buf.Write(frag.Bytes)
+		}
+		return Result{Bytes: buf.Bytes()}, nil
+	})
+
+	return p
+}
+
+// SetFile feeds the current bytes of a .bp file into the engine.
+func (p *Pipeline) SetFile(path string, content []byte) {
+	p.e.SetInput(Key(filePrefix+path), content)
+}
+
+func splitPathName(s string) (path, name string) {
+	i := strings.LastIndex(s, "/")
+	if i < 0 {
+		return s, ""
+	}
+	return s[:i], s[i+1:]
+}
+
+// parseFile parses a real Android.bp into a deterministic name -> *pmod map.
+func parseFile(path string, content []byte) (Result, error) {
+	defs := parseModules(path, content)
+	if defs == nil {
+		return Result{}, fmt.Errorf("parse %s failed", path)
+	}
+	// Canonical bytes for hashing the whole file: sorted "name=canon" lines.
+	names := make([]string, 0, len(defs))
+	for n := range defs {
+		names = append(names, n)
+	}
+	sort.Strings(names)
+	var buf bytes.Buffer
+	for _, n := range names {
+		buf.WriteString(n)
+		buf.WriteByte('=')
+		buf.WriteString(defs[n].canon)
+		buf.WriteByte('\n')
+	}
+	return Result{Bytes: buf.Bytes(), Data: defs}, nil
+}
+
+// parseModules parses a .bp and returns name -> *pmod (nil on parse error).
+func parseModules(path string, content []byte) map[string]*pmod {
+	file, errs := parser.Parse(path, bytes.NewReader(content))
+	if len(errs) > 0 {
+		return nil
+	}
+	out := make(map[string]*pmod)
+	for _, d := range file.Defs {
+		m, ok := d.(*parser.Module)
+		if !ok {
+			continue
+		}
+		name := ""
+		props := map[string]string{}
+		var defaults []string
+		var deps []string
+		for _, prop := range m.Properties {
+			if prop.Name == "name" {
+				if s, ok := prop.Value.(*parser.String); ok {
+					name = s.Value
+				}
+			}
+			if prop.Name == "defaults" {
+				if l, ok := prop.Value.(*parser.List); ok {
+					for _, e := range l.Values {
+						if s, ok := e.(*parser.String); ok {
+							defaults = append(defaults, s.Value)
+						}
+					}
+				}
+			}
+			if depProps[prop.Name] {
+				if l, ok := prop.Value.(*parser.List); ok {
+					for _, e := range l.Values {
+						if s, ok := e.(*parser.String); ok {
+							deps = append(deps, s.Value)
+						}
+					}
+				}
+			}
+			if prop.Name == "srcs" {
+				if l, ok := prop.Value.(*parser.List); ok {
+					for _, e := range l.Values {
+						if s, ok := e.(*parser.String); ok && strings.HasPrefix(s.Value, ":") {
+							deps = append(deps, strings.TrimPrefix(s.Value, ":"))
+						}
+					}
+				}
+			}
+			props[prop.Name] = strings.Join(strings.Fields(prop.Value.String()), " ")
+		}
+		if name == "" {
+			continue
+		}
+		out[name] = &pmod{canon: canonProps(m.Type, props), props: props, typ: m.Type, defaults: defaults, deps: deps}
+	}
+	return out
+}
+
+// canonProps renders "type{key:val;key:val;...}" with property keys sorted and
+// each value's own textual order preserved.
+func canonProps(typ string, props map[string]string) string {
+	keys := make([]string, 0, len(props))
+	for k := range props {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	var b strings.Builder
+	b.WriteString(typ)
+	b.WriteByte('{')
+	for i, k := range keys {
+		if i > 0 {
+			b.WriteByte(';')
+		}
+		b.WriteString(k)
+		b.WriteByte(':')
+		b.WriteString(props[k])
+	}
+	b.WriteByte('}')
+	return b.String()
+}
+
+// genericEmit produces the fallback ninja fragment used for any module type
+// without a dedicated native emitter. The output name is CONTENT-ADDRESSED: the
+// stamp is keyed on the module's resolved def, not on visitation order or an
+// accumulating counter -- the structural fix for the dedup / namespace
+// nondeterminism that defeats Soong's warm path.
+func genericEmit(name string, resolvedDef, depHashes []byte) []byte {
+	id := fmt.Sprintf("%016x", hashBytes(resolvedDef))
+	dep := fmt.Sprintf("%016x", hashBytes(depHashes))
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "# module %s\n", name)
+	fmt.Fprintf(&b, "build out/m_%s/%s.stamp: phony\n", id, name)
+	fmt.Fprintf(&b, "    def_hash = %s\n", id)
+	fmt.Fprintf(&b, "    deps_hash = %s\n", dep)
+	return b.Bytes()
+}
