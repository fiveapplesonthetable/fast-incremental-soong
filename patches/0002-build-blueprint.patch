+				foo_module { name: "B", outputs: ["outB1"], deps: ["C"] }
+				bar_module { name: "C", outputs: ["outC1"] }
+			`,
+			edited: `
+				foo_module { name: "A", outputs: ["outA1"], deps: ["B"] }
+				foo_module { name: "B", outputs: ["outB2"], deps: ["C"] }
+				bar_module { name: "C", outputs: ["outC1"] }
