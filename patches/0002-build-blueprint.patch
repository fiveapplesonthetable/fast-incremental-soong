+// CalculateHashTolerant is like CalculateHash but, instead of erroring on a field
+// it cannot hash (func, chan, unsafe.Pointer), folds in a constant and continues.
+// Soong module properties legitimately carry func-valued fields (e.g. the
+// postProcessors in Srcs) that are set by Go code, not by .bp text, so they never
+// change with a .bp edit and are safe to ignore for content/change detection.
+func CalculateHashTolerant(value interface{}) (uint64, error) {
+	hasher := hasherPool.Get()
+	defer hasherPool.Put(hasher)
+	hasher.reset()
+	hasher.skipUnhashable = true
+	v := reflect.ValueOf(value)
+	var err error
+	if v.IsValid() {
+		err = hasher.calculateHash(v)
+	}
+	return hasher.Sum64(), err
+}
