@@ -233,6 +233,19 @@ func (r *NameResolver) NewModule(ctx blueprint.NamespaceContext, moduleGroup blu
 	return ns, nil
 }
 
+// RemoveModule implements the optional blueprint.ModuleRemover interface so the
+// resident incremental-remove path (IncrementalRemoveModules) can drop a deleted
+// module from the name index without a full rebuild. The bare name is unique within
+// a namespace, so removing it from every namespace's container drops the one that
+// holds it and is a no-op everywhere else.
+func (r *NameResolver) RemoveModule(name string) {
+	for _, namespace := range r.sortedNamespaces.sortedItems() {
+		if remover, ok := namespace.moduleContainer.(blueprint.ModuleRemover); ok {
+			remover.RemoveModule(name)
+		}
+	}
+}
+
 func (r *NameResolver) NewSkippedModule(ctx blueprint.NamespaceContext, name string, skipInfo blueprint.SkippedModuleInfo) {
 	r.rootNamespace.moduleContainer.NewSkippedModule(ctx, name, skipInfo)
 }
