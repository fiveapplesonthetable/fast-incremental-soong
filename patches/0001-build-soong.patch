+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package main
+
+// Resident ("persistent") soong_build server.
+//
+// Normally soong_ui spawns soong_build as a fresh process for every build,
+// which pays the Go runtime start-up, a cold heap, and (with incremental
+// analysis) re-opening the multi-GB on-disk action cache every time. When
+// SOONG_PERSISTENT=true, soong_ui sets SOONG_PERSISTENT_SOCK in the soong_build
+// invocation's environment. soong_build then runs in one of two roles:
+//
+//   - client: the short-lived process ninja actually invokes. It forwards its
+//     own command-line args to the resident server over a unix socket (spawning
+//     the server on first use) and exits with the server's status.
+//   - server: a detached, long-lived process started by the first client. It
+//     listens on the socket and runs one analysis per request, staying warm
+//     between builds.
+//
+// Correctness: each request runs a complete analysis on a fresh android.Context,
+// so it is equivalent to a one-shot run. The per-request flags are re-parsed
+// onto a fresh FlagSet so no flag state leaks between builds. Soong's module
+// type / mutator / singleton registration lives in process-global tables that
+// are populated once by init() and only read (never re-populated) by
+// Context.Register(), so re-running analysis in the same process is safe.
+//
+// This is the foundation for incremental resident analysis (reusing the resolved
+// graph across builds); that lands in follow-up changes and is not enabled here.
+//
+// Limitation: a running server is pinned to the soong_build binary that spawned
+// it. If you rebuild soong_build itself, kill the resident server so the next
+// build re-spawns the new binary (see persistentSelfStamp).
+
+import (
+	"bufio"
+	"encoding/json"
+	"flag"
+	"fmt"
+	"net"
+	"os"
+	"os/exec"
+	"strings"
+	"syscall"
+	"time"
+
+	"android/soong/android"
+
+	"github.com/google/blueprint"
+)
+
+// persistentSockEnv is the environment variable soong_ui sets to opt a build
+// into persistent mode; its value is the unix socket path.
+const persistentSockEnv = "SOONG_PERSISTENT_SOCK"
+
+// persistentReuseGraphEnv, when "true", enables the EXPERIMENTAL graph-residency
+// fast path (Phase 2): the resident server keeps the resolved+mutated Blueprint
+// graph in memory and, on subsequent builds, skips parse + ResolveDependencies
+// and only re-generates build actions. See the warnings on
+// blueprint.Context.ResetBuildActionsForReanalysis -- it does not yet re-apply
+// edited Android.bp properties through mutators, so it is for measurement and
+// development only, not correct for arbitrary edits.
+const persistentReuseGraphEnv = "SOONG_PERSISTENT_REUSE_GRAPH"
+
+// reuseGraphMode is set once at server startup from persistentReuseGraphEnv.
+var reuseGraphMode bool
+
+// residentBuildCtx holds the resolved Context from the previous build so the
+// graph-residency fast path can reuse it. nil until the first full build
+// completes. Only used when reuseGraphMode is true.
+var residentBuildCtx *android.Context
+
+// residentCache is the process-resident in-memory build-action cache, created
+// once when the server starts and reused (read on hits, populated on misses) by
+// every build the server handles. It is nil outside persistent server mode, and
+// runBuild() keys its persistent-mode behavior off it being non-nil.
+var residentCache *blueprint.BuildActionCache
+
+// residentReqCount counts builds served since the cache was created. The first
+// build (count 0) populates the cache (analysis=false); later builds read it
+// (analysis=true).
+var residentReqCount int
+
+// detectChangedModules returns the names of modules whose Android.bp definition
+// changed since the resident graph was built. The targeted regenerate path uses
+// this to regenerate only those modules (plus their reverse-dependency closure).
+//
+// TODO(next): re-parse the changed Android.bp files (detected via mtime/inotify)
+// and diff each module's properties against the resident graph. For now this
+// returns nil, which is exactly correct for edits that change no module (e.g.
+// comment- or whitespace-only edits) and lets us validate the targeted-regenerate
+// mechanism (clean modules keep their build actions; output must be byte-identical
+// to a full build).
+func detectChangedModules() []string {
+	return nil
+}
+
+// persistentRequest is sent by the client for each build. Args are exactly the
+// command-line arguments ninja invoked soong_build with (os.Args[1:]); the
+// server re-parses them on a fresh FlagSet.
+type persistentRequest struct {
+	Args []string `json:"args"`
+	// Stamp identifies the client's soong_build binary. If it does not match the
+	// server's, the server exits so a fresh binary can take over.
+	Stamp string `json:"stamp"`
+}
+
+// persistentResponse reports the outcome of a single build request.
+type persistentResponse struct {
+	OK    bool   `json:"ok"`
+	Err   string `json:"err,omitempty"`
+	Stale bool   `json:"stale,omitempty"` // server is shutting down; client should retry
+}
+
+// persistentSelfStamp returns a stamp identifying this soong_build binary so a
+// stale resident server (left over after soong_build was rebuilt) can be
+// detected and replaced.
+func persistentSelfStamp() string {
+	self, err := os.Executable()
+	if err != nil {
+		self = os.Args[0]
+	}
+	if fi, err := os.Stat(self); err == nil {
+		return fmt.Sprintf("%s@%d", self, fi.ModTime().UnixNano())
+	}
+	return self
+}
+
+// ----------------------------------------------------------------------------
+// Server
+// ----------------------------------------------------------------------------
+
+// runPersistentServer listens on the given unix socket and serves one build per
+// connection until the process is killed or a stale-binary request arrives. It
+// does not return under normal operation.
+func runPersistentServer(sockPath string) {
+	// A stale socket file from a previously crashed server would block Listen.
+	_ = os.Remove(sockPath)
+
+	listener, err := net.Listen("unix", sockPath)
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "soong_build persistent: cannot listen on %s: %v\n", sockPath, err)
+		os.Exit(1)
+	}
+	defer listener.Close()
+
+	reuseGraphMode = os.Getenv(persistentReuseGraphEnv) == "true"
+
+	// Create the resident in-memory action cache once; it is reused across every
+	// build this server handles (see runBuild in main.go). The graph-residency
+	// fast path regenerates all modules instead, so it does not use this cache.
+	if !reuseGraphMode {
+		residentCache = blueprint.NewInMemoryBuildActionCache()
+	}
+
+	stamp := persistentSelfStamp()
+	fmt.Fprintf(os.Stderr, "soong_build persistent: ready on %s (pid %d, %s)\n", sockPath, os.Getpid(), stamp)
+
+	for {
+		conn, err := listener.Accept()
+		if err != nil {
+			fmt.Fprintf(os.Stderr, "soong_build persistent: accept failed: %v\n", err)
+			continue
+		}
+		if serveOneBuild(conn, stamp) {
+			// A client with a newer binary connected; step aside.
+			fmt.Fprintf(os.Stderr, "soong_build persistent: binary changed, exiting\n")
+			return
+		}
+	}
+}
+
+// serveOneBuild reads a request, runs a single analysis pass, and replies. It
+// returns true if the server should shut down (the client's binary differs from
+// ours).
+//
+// Note: runBuild() still calls os.Exit on fatal analysis errors via maybeQuit;
+// in that case the server process exits and the client re-spawns it. The happy
+// path returns normally and the loop continues warm.
+func serveOneBuild(conn net.Conn, stamp string) (shutdown bool) {
+	defer conn.Close()
+
+	var req persistentRequest
+	if err := json.NewDecoder(bufio.NewReader(conn)).Decode(&req); err != nil {
+		writePersistentResponse(conn, persistentResponse{Err: fmt.Sprintf("decode request: %v", err)})
+		return false
+	}
+
+	fmt.Fprintf(os.Stderr, "soong_build persistent: request received (stampMatch=%v reuseGraphMode=%v haveResidentGraph=%v)\n",
+		req.Stamp == stamp, reuseGraphMode, residentBuildCtx != nil)
+
+	if req.Stamp != "" && req.Stamp != stamp {
+		writePersistentResponse(conn, persistentResponse{Stale: true})
+		return true
+	}
+
+	// Re-parse this request's flags onto a fresh FlagSet. A new FlagSet (rather
+	// than re-using flag.CommandLine) resets every bound variable to its default
+	// first, so values from the previous build cannot leak.
+	fs := flag.NewFlagSet("soong_build", flag.ContinueOnError)
+	registerFlags(fs)
+	if err := fs.Parse(req.Args); err != nil {
+		writePersistentResponse(conn, persistentResponse{Err: fmt.Sprintf("parse args: %v", err)})
+		return false
+	}
+
+	runBuild()
+
+	writePersistentResponse(conn, persistentResponse{OK: true})
+	return false
+}
+
+func writePersistentResponse(conn net.Conn, resp persistentResponse) {
+	if err := json.NewEncoder(conn).Encode(resp); err != nil {
+		fmt.Fprintf(os.Stderr, "soong_build persistent: cannot write response: %v\n", err)
+	}
+}
+
+// ----------------------------------------------------------------------------
+// Client
+// ----------------------------------------------------------------------------
+
+// runPersistentClient forwards this build's args to the resident server at
+// sockPath, spawning the server on first use, and exits with its status.
+func runPersistentClient(sockPath string) {
+	stamp := persistentSelfStamp()
+
+	for attempt := 0; attempt < 2; attempt++ {
+		conn, err := dialOrSpawnServer(sockPath)
+		if err != nil {
+			fmt.Fprintf(os.Stderr, "soong_build persistent: %v\n", err)
+			os.Exit(1)
+		}
+
+		if err := json.NewEncoder(conn).Encode(persistentRequest{Args: os.Args[1:], Stamp: stamp}); err != nil {
+			conn.Close()
+			fmt.Fprintf(os.Stderr, "soong_build persistent: send request: %v\n", err)
+			os.Exit(1)
+		}
+		var resp persistentResponse
+		if err := json.NewDecoder(conn).Decode(&resp); err != nil {
+			conn.Close()
+			fmt.Fprintf(os.Stderr, "soong_build persistent: read response: %v\n", err)
+			os.Exit(1)
+		}
+		conn.Close()
+
+		if resp.Stale {
+			// Old server is stepping aside; loop will re-spawn the new binary.
+			time.Sleep(100 * time.Millisecond)
+			continue
+		}
+		if !resp.OK {
+			fmt.Fprintf(os.Stderr, "soong_build persistent: build failed: %s\n", resp.Err)
+			os.Exit(1)
+		}
+		runBpgenTakeoverFromPersistentClient()
+		return
+	}
+	fmt.Fprintf(os.Stderr, "soong_build persistent: server kept reporting stale\n")
+	os.Exit(1)
+}
+
+// dialOrSpawnServer returns a connection to the resident server, spawning it if
+// it is not already running.
+func dialOrSpawnServer(sockPath string) (net.Conn, error) {
+	if conn, err := net.Dial("unix", sockPath); err == nil {
+		return conn, nil
+	}
+
+	if err := spawnServer(sockPath); err != nil {
+		return nil, fmt.Errorf("spawn server: %w", err)
+	}
+
+	deadline := time.Now().Add(120 * time.Second)
+	for time.Now().Before(deadline) {
+		if conn, err := net.Dial("unix", sockPath); err == nil {
+			return conn, nil
+		}
+		time.Sleep(50 * time.Millisecond)
+	}
+	return nil, fmt.Errorf("resident server did not come up on %s", sockPath)
+}
+
+// spawnServer starts a detached resident soong_build server process.
+func spawnServer(sockPath string) error {
+	self, err := os.Executable()
+	if err != nil {
+		self = os.Args[0]
+	}
+
+	logFile, err := os.Create(sockPath + ".log")
+	if err != nil {
+		return err
+	}
+	defer logFile.Close()
+
+	cmd := exec.Command(self, "--top", topDir, "--persistent", sockPath)
+	cmd.Stdout = logFile
+	cmd.Stderr = logFile
+	// Drop SOONG_PERSISTENT_SOCK so the child runs as a server, not a client.
+	cmd.Env = envWithout(os.Environ(), persistentSockEnv)
+	// Detach into its own session so it outlives this short-lived client.
+	cmd.SysProcAttr = &syscall.SysProcAttr{Setsid: true}
+	return cmd.Start()
+}
+
+func envWithout(env []string, key string) []string {
+	prefix := key + "="
+	out := make([]string, 0, len(env))
+	for _, e := range env {
+		if strings.HasPrefix(e, prefix) {
+			continue
+		}
+		out = append(out, e)
+	}
+	return out
+}
