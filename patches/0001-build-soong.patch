+// runBuildReuse is the EXPERIMENTAL graph-residency fast path (Phase 2). It
+// reuses the resolved+mutated Context from the previous build (residentBuildCtx),
+// skipping list_modules + parse_bp + ResolveDependencies (the ~40s O(whole-tree)
+// phases) and only re-generating build actions and rewriting the ninja file.
+//
+// EXPERIMENTAL/INCOMPLETE: it does not re-parse changed Android.bp files or
+// re-run mutators (see blueprint.Context.ResetBuildActionsForReanalysis), so the
+// regenerated actions reflect the property state of the last full analysis. It
+// is for measuring the graph-residency ceiling and developing the incremental
+// re-mutation path; it is NOT yet correct for arbitrary edits.
+func runBuildReuse(soongStartTime time.Time) {
+	ctx := residentBuildCtx
+	configuration := ctx.Config()
+	metricsDir := parseAvailableEnv()["LOG_DIR"]
+
+	// The EventHandler on the resident Context accumulates events across builds;
+	// clear the previous build's events so this build's metrics don't collide
+	// (CompletedEvents panics on duplicate event ids).
+	ctx.EventHandler.Reset()
+
+	// Start a fresh background metrics collector for this build. writeMetrics ->
+	// collectMetrics sends on perfCollector.stop, which deadlocks without a live
+	// collector goroutine (the previous build's collector already stopped).
+	android.StartBackgroundMetrics(configuration)
+
+	fullRebuild := func(reason string) {
+		fmt.Fprintf(os.Stderr, "soong_build persistent: incremental fallback (%s) -> full rebuild\n", reason)
+		residentBuildCtx = nil // discard the resident graph; runBuild does a cold build
+		runBuild()
+	}
+
+	// Re-parse the source tree into a throwaway context (parse only, pre-mutation)
+	// and diff it against the resident baselines to find exactly what changed.
+	tReparse := time.Now()
+	reparseCtx := newContext(configuration)
+	reparseCtx.Register()
+	// Fast path: reparse only the .bp files whose content changed, instead of the
+	// whole tree (the O(tree) parse_bp pass, ~4s at AOSP scale). DiffParsedModules
+	// tolerates a partial reparse -- its added/removed detection is scoped by an
+	// on-disk file-hash check, so modules in files we don't reparse are correctly
+	// treated as unchanged. Falls back to a full RunBlueprint when the SET of .bp
+	// files changed (add/remove) or the changed set can't be determined; a full
+	// reparse is always correct.
+	partialReparse := false
+	reparseCtx.SetModuleListFile(cmdlineArgs.ModuleListFile)
+	currentFiles, lerr := reparseCtx.ListModulePaths(".")
+	if lerr != nil {
+		fmt.Fprintf(os.Stderr, "soong_build persistent: ListModulePaths failed (%v) -> full reparse\n", lerr)
+	}
+	if lerr == nil {
+		if changedFiles, okc := ctx.ChangedBlueprintFiles(currentFiles); okc {
+			if len(changedFiles) > 0 {
+				if _, errs := reparseCtx.ParseFileList(".", changedFiles, reparseCtx.Config()); len(errs) > 0 {
+					fullRebuild(fmt.Sprintf("partial reparse error: %v", errs[0]))
+					return
+				}
+			}
+			partialReparse = true
+			fmt.Fprintf(os.Stderr, "soong_build persistent: changed-file reparse: %d of %d .bp files\n",
+				len(changedFiles), len(currentFiles))
+		}
+	}
+	if !partialReparse {
+		if _, err := bootstrap.RunBlueprint(cmdlineArgs.Args, bootstrap.StopBeforeResolveDependencies, reparseCtx.Context, reparseCtx.Config()); err != nil {
+			fullRebuild(fmt.Sprintf("reparse error: %v", err))
+			return
+		}
+	}
+	fmt.Fprintf(os.Stderr, "soong_build persistent: reparse took %v\n", time.Since(tReparse))
+
+	// Reset per-build incremental state BEFORE DiffParsedModules. The diff records
+	// line-shifted clean modules into posShiftedModules, so that map must be
+	// initialized first (else a nil-map write panics) and must not be wiped by a
+	// later reset (which would drop the line-shift tracking and emit stale
+	// "# Defined: file:line" comments -> byte mismatch vs a cold build).
+	ctx.BeginIncrementalBuild()
+
+	changed, added, removed, err := ctx.DiffParsedModules(reparseCtx.Context)
+	if err != nil {
+		fullRebuild(fmt.Sprintf("diff error: %v", err))
+		return
+	}
+
+	// Adding or removing a module splices it into/out of the resident graph
+	// (IncrementalAddModules/Remove), then re-runs the whole-graph singletons over
+	// the new module set (singletonsNeedRegen is true on a membership change;
+	// generateSingletonBuildActions resets each singleton's single-use state first so
+	// the re-run is clean), and rewrites the full manifest (delta write is disabled on
+	// a membership change because shard assignment reshuffles). Structural cases the
+	// incremental path can't represent return ErrFallbackToFullBuild -> full rebuild.
+	if len(removed) > 0 {
+		if errs := ctx.IncrementalRemoveModules(removed); len(errs) > 0 {
+			if blueprint.ErrFallbackToFullBuild(errs[0]) {
+				fullRebuild(fmt.Sprintf("incremental remove fell back: %v", errs[0]))
+				return
+			}
+			maybeQuit(errs[0], "resident incremental remove failed")
+		}
+	}
+	if len(added) > 0 {
+		if errs := ctx.IncrementalAddModules(configuration, reparseCtx.Context, added); len(errs) > 0 {
+			if blueprint.ErrFallbackToFullBuild(errs[0]) {
+				fullRebuild(fmt.Sprintf("incremental add fell back: %v", errs[0]))
+				return
+			}
+			maybeQuit(errs[0], "resident incremental add failed")
+		}
+	}
+	if len(changed) > 0 {
+		if errs := ctx.ReMutate(configuration, changed); len(errs) > 0 {
+			if blueprint.ErrFallbackToFullBuild(errs[0]) {
+				fullRebuild(errs[0].Error())
+				return
+			}
+			maybeQuit(errs[0], "resident re-mutation failed")
+		}
+	}
+	// NOTE: dependent regeneration is handled inside generateTargeted, which expands
+	// the affected set via each regenerated module's interfaceChanged flag (precise:
+	// it only follows reverse-deps when a module's exported provider interface
+	// actually changed). No separate reverse-dep closure here.
+
+	fmt.Fprintf(os.Stderr, "soong_build persistent: REUSING resolved graph (skip parse+resolve+full mutate); %d changed, %d added, %d removed module(s) handled incrementally\n", len(changed), len(added), len(removed))
+
+	tRegen := time.Now()
+	ninjaDeps, err := bootstrap.RegenerateBuildActions(cmdlineArgs.Args, ctx.Context, configuration)
+	maybeQuit(err, "")
+	fmt.Fprintf(os.Stderr, "soong_build persistent: regenerate+write took %v\n", time.Since(tRegen))
+	runBpgenTakeoverAfterSoong(configuration)
+	finalOutputFile := cmdlineArgs.OutFile
+
+	ninjaDeps = append(ninjaDeps, configuration.ProductVariablesFileName)
+	ninjaDeps = append(ninjaDeps, usedEnvFile)
+
+	writeDepFile(finalOutputFile, ctx.EventHandler, ninjaDeps)
+	writeMetrics(configuration, ctx.EventHandler, metricsDir)
+	writeUsedEnvironmentFile(configuration)
+	err = writeGlobFile(ctx.EventHandler, finalOutputFile, ctx.Globs(), soongStartTime)
+	maybeQuit(err, "")
+	touch(shared.JoinPath(topDir, finalOutputFile))
+}
+
+func runBpgenTakeoverAfterSoong(configuration android.Config) {
+	if persistentListen != "" {
+		trackBpgenTakeoverEnv(configuration)
+		return
+	}
+	runBpgenTakeoverIfEnabled(configuration)
+}
+
+func runBpgenTakeoverFromPersistentClient() {
+	topPath, err := filepath.Abs(topDir)
+	maybeQuit(err, "resolving top dir for bpgen")
+	err = os.Chdir(topPath)
+	maybeQuit(err, "changing to top dir for bpgen")
+
+	availableEnv := parseAvailableEnv()
+	configuration, err := android.NewConfig(cmdlineArgs, availableEnv)
+	maybeQuit(err, "")
+	runBpgenTakeoverIfEnabled(configuration)
+}
+
+func trackBpgenTakeoverEnv(configuration android.Config) {
+	if !configuration.IsEnvTrue("SOONG_BPGEN") {
+		return
+	}
+	configuration.Getenv("SOONG_BPGEN_BINARY")
+	configuration.Getenv("SOONG_NINJA_SHARDS")
+	configuration.GetenvWithDefault("SOONG_BPGEN_LOG_LEVEL", "warn")
+	configuration.GetenvWithDefault("SOONG_BPGEN_RAYON_THREADS", "8")
+}
+
+func runBpgenTakeoverIfEnabled(configuration android.Config) {
+	if !configuration.IsEnvTrue("SOONG_BPGEN") {
+		return
+	}
+	if configuration.BuildMode != android.AnalysisNoBazel {
+		return
+	}
+	if !configuration.HasDeviceProduct() {
+		maybeQuit(fmt.Errorf("SOONG_BPGEN=true requires a product build"), "")
+	}
+
+	bpgenBinary := configuration.Getenv("SOONG_BPGEN_BINARY")
+	if bpgenBinary == "" {
+		bpgenBinary = filepath.Join("out", "host", runtime.GOOS+"-x86", "bin", "bpgen")
+	}
+
+	topPath, err := filepath.Abs(topDir)
+	maybeQuit(err, "resolving top dir for bpgen")
+	soongOutDir, err := absolutePathUnderTop(topPath, configuration.SoongOutDir())
+	maybeQuit(err, "resolving Soong out dir for bpgen")
+	bpgenBinary, err = absolutePathUnderTop(topPath, bpgenBinary)
+	maybeQuit(err, "resolving bpgen binary")
+
+	args := []string{
+		"--top", topPath,
+		"--out", soongOutDir,
+		"--product", configuration.DeviceProduct(),
+		"--soong-oracle-output", soongOutDir,
+	}
+	if shards := configuration.Getenv("SOONG_NINJA_SHARDS"); shards != "" {
+		if _, err := strconv.Atoi(shards); err != nil {
+			maybeQuit(fmt.Errorf("invalid SOONG_NINJA_SHARDS=%q: %w", shards, err), "")
+		}
+		args = append(args, "--shards", shards)
+	}
+	if logLevel := configuration.GetenvWithDefault("SOONG_BPGEN_LOG_LEVEL", "warn"); logLevel != "" {
+		args = append(args, "--log-level", logLevel)
+	}
+	rayonThreads := configuration.GetenvWithDefault("SOONG_BPGEN_RAYON_THREADS", "8")
+	if rayonThreads != "" {
+		threads, err := strconv.Atoi(rayonThreads)
+		if err != nil || threads <= 0 {
+			maybeQuit(fmt.Errorf("invalid SOONG_BPGEN_RAYON_THREADS=%q", rayonThreads), "")
+		}
+	}
+
+	start := time.Now()
+	fmt.Fprintf(os.Stderr, "soong_build: SOONG_BPGEN=true, rewriting ninja shards with %s\n", bpgenBinary)
+	cmd := exec.Command(bpgenBinary, args...)
+	cmd.Dir = topPath
+	if rayonThreads != "" {
+		cmd.Env = append(os.Environ(), "RAYON_NUM_THREADS="+rayonThreads)
+	}
+	cmd.Stdout = os.Stderr
+	cmd.Stderr = os.Stderr
+	if err := cmd.Run(); err != nil {
+		maybeQuit(fmt.Errorf("bpgen takeover failed: %w", err), "")
+	}
+	fmt.Fprintf(os.Stderr, "soong_build: bpgen takeover completed in %v\n", time.Since(start))
+}
+
+func absolutePathUnderTop(topPath, path string) (string, error) {
+	if filepath.IsAbs(path) {
+		return filepath.Clean(path), nil
+	}
+	return filepath.Abs(filepath.Join(topPath, path))
 }
 
 func writeUsedEnvironmentFile(configuration android.Config) {
diff --git a/cmd/soong_build/persistent.go b/cmd/soong_build/persistent.go
new file mode 100644
index 000000000..54b7a0871
--- /dev/null
+++ b/cmd/soong_build/persistent.go
@@ -0,0 +1,329 @@
+// Copyright 2026 Google Inc. All rights reserved.
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
