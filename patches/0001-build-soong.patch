+package build
+
+import (
+	"bufio"
+	"fmt"
+	"net"
+	"os"
+	"os/exec"
+	"path/filepath"
+	"strconv"
+	"strings"
+	"syscall"
+	"time"
+)
+
+// Resident n2 executor. When SOONG_PERSISTENT_REUSE_GRAPH is set and the n2
+// backend is in use, the ninja phase talks to a long-lived n2 process that holds
+// the parsed build graph in RAM across invocations. soong's delta manifest write
+// leaves the large subninja files mtime-unchanged, so on each build the resident
+// n2 re-reads only the tiny top-level manifest plus the one shard that changed
+// (splice), instead of re-reading the multi-GB manifest from scratch.
+
+func n2ResidentSock(config Config) string {
+	return filepath.Join(config.OutDir(), ".n2_resident.sock")
+}
+
+// runResidentN2 connects to the resident n2 server (starting it if needed) and
+// asks it to build the requested targets. Returns false if the resident path is
+// not usable so the caller can fall back to a normal spawn.
+func runResidentN2(ctx Context, config Config, ninjaArgs []string) bool {
+	sock := n2ResidentSock(config)
+	conn, err := net.Dial("unix", sock)
+	if err != nil {
+		if !startN2Server(ctx, config, sock) {
+			return false
+		}
+		conn = waitN2Server(ctx, sock, 240*time.Second)
+		if conn == nil {
+			return false
+		}
+	}
+	defer conn.Close()
+
+	req := "BUILD " + strings.Join(ninjaArgs, " ") + "\n"
+	if _, err := conn.Write([]byte(req)); err != nil {
+		ctx.Fatalf("n2 resident: write request: %v", err)
+	}
+	resp, err := bufio.NewReader(conn).ReadString('\n')
+	if err != nil && resp == "" {
+		ctx.Fatalf("n2 resident: read response: %v", err)
+	}
+	resp = strings.TrimSpace(resp)
+	fmt.Fprintf(os.Stderr, "n2 resident: %s\n", resp)
+	if !strings.HasPrefix(resp, "OK") {
+		ctx.Fatalf("n2 resident build failed: %s", resp)
+	}
+	return true
+}
+
+// startN2Server spawns the resident n2 server detached (its own session, no
+// sandbox) so it survives across soong_ui invocations. Returns false if n2 is
+// not available.
+func startN2Server(ctx Context, config Config, sock string) bool {
+	n2 := config.N2Bin()
+	if _, err := os.Stat(n2); err != nil {
+		fmt.Fprintf(os.Stderr, "n2 resident: n2 binary %q not found: %v\n", n2, err)
+		return false
+	}
+	os.Remove(sock)
+	logPath := filepath.Join(config.OutDir(), ".n2_resident.log")
+	lf, err := os.Create(logPath)
+	if err != nil {
+		return false
+	}
+	wd, _ := os.Getwd()
+	cmd := exec.Command(n2,
+		"--serve", sock,
+		"-f", config.CombinedNinjaFile(),
+		"-j", strconv.Itoa(config.Parallel()),
+	)
+	cmd.Dir = wd
+	cmd.Stdout = lf
+	cmd.Stderr = lf
+	cmd.SysProcAttr = &syscall.SysProcAttr{Setsid: true}
+	if err := cmd.Start(); err != nil {
+		fmt.Fprintf(os.Stderr, "n2 resident: failed to start server: %v\n", err)
+		return false
+	}
+	fmt.Fprintf(os.Stderr, "n2 resident: started server pid %d, loading graph (log: %s)\n",
+		cmd.Process.Pid, logPath)
+	return true
+}
+
+// waitN2Server polls the socket until the server is accepting connections (the
+// graph finished loading) or the deadline passes.
+func waitN2Server(ctx Context, sock string, timeout time.Duration) net.Conn {
+	deadline := time.Now().Add(timeout)
+	for time.Now().Before(deadline) {
+		if conn, err := net.Dial("unix", sock); err == nil {
+			return conn
+		}
+		time.Sleep(200 * time.Millisecond)
+	}
+	fmt.Fprintf(os.Stderr, "n2 resident: server did not become ready within %s\n", timeout)
+	return nil
+}
